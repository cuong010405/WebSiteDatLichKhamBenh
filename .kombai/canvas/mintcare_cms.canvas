bg-white rounded-[40px] border border-slate-200 shadow-2xl overflow-hidden flex flex-col\" data-kid=\"295\">\n            <div class=\"p-8 border-b border-slate-100 flex items-center justify-between bg-white shrink-0\" data-kid=\"296\">\n               <div class=\"flex items-center gap-6\" data-kid=\"297\">\n                  <div class=\"relative\" data-kid=\"298\">\n                    <img id=\"detail-avatar\" src=\"https://i.pravatar.cc/150?u=sandra\" class=\"w-16 h-16 rounded-3xl object-cover ring-4 ring-emerald-50\" data-kid=\"299\">\n                    <div id=\"detail-status\" class=\"absolute -bottom-1 -right-1 w-5 h-5 bg-emerald-500 border-4 border-white rounded-full\" data-kid=\"300\"></div>\n                  </div>\n                  <div data-kid=\"301\">\n                    <h2 id=\"detail-title\" class=\"text-xl font-bold text-slate-900\" data-kid=\"302\">Sandra Bullock</h2>\n                    <div class=\"flex items-center gap-2 mt-1\" data-kid=\"303\">\n                      <span class=\"text-xs font-bold text-slate-500 bg-slate-100 px-2 py-0.5 rounded-lg\" data-kid=\"304\">Floor 4</span>\n                      <span class=\"text-xs font-bold text-emerald-600 bg-emerald-50 px-2 py-0.5 rounded-lg\" data-kid=\"305\">Shift: 08:00 — 19:00</span>\n                    </div>\n                  </div>\n               </div>\n               <div class=\"text-right\" data-kid=\"306\">\n                 <p class=\"text-2xl font-black text-slate-900 leading-tight\" data-kid=\"307\">72%</p>\n                 <p class=\"text-[10px] font-bold text-slate-400 uppercase tracking-widest\" data-kid=\"308\">Daily Capacity</p>\n               </div>\n            </div>\n\n            <div class=\"flex-1 overflow-y-auto p-10 space-y-10 scrollbar-hide\" id=\"detail-timeline-content\" data-kid=\"309\">\n               \n               <div class=\"flex items-center justify-between mb-2\" data-kid=\"310\">\n                 <h3 class=\"text-xs font-bold text-slate-400 uppercase tracking-widest\" data-kid=\"311\">Agenda for June 18, 2026</h3>\n                 <span class=\"text-xs font-bold text-emerald-600 bg-emerald-50 px-3 py-1 rounded-full\" data-kid=\"312\">4 Sessions • 6h 30m Total</span>\n               </div>\n\n               <div class=\"space-y-0\" data-kid=\"313\">\n                  \n                  <div class=\"relative pl-12 pb-12 border-l-2 border-slate-100\" data-kid=\"314\">\n                    <div class=\"absolute -left-[9px] top-0 w-4 h-4 rounded-full bg-white border-4 border-emerald-500\" data-kid=\"315\"></div>\n                    <div class=\"absolute left-0 top-0 text-[11px] font-mono font-bold text-slate-400 -translate-x-full pr-6 mt-0.5\" data-kid=\"316\">08:00</div>\n                    \n                    <div class=\"task-card bg-emerald-50/50 border border-emerald-100 rounded-[32px] p-6 cursor-pointer group\" data-kid=\"317\">\n                      <div class=\"flex justify-between items-start mb-4\" data-kid=\"318\">\n                        <div data-kid=\"319\">\n                          <span class=\"text-[10px] font-bold text-emerald-600 bg-white border border-emerald-100 px-2 py-0.5 rounded-md uppercase tracking-wider\" data-kid=\"320\">Clinical</span>\n                          <h4 class=\"text-lg font-bold text-slate-900 mt-1 group-hover:text-emerald-700 transition-colors\" data-kid=\"321\">Regular Dressing Change</h4>\n                        </div>\n                        <div class=\"text-right\" data-kid=\"322\">\n                          <p class=\"text-sm font-bold text-slate-900\" data-kid=\"323\">08:00 — 09:30</p>\n                          <p class=\"text-[11px] text-slate-500 font-medium\" data-kid=\"324\">Room 402 • Patient: Evelyn G.</p>\n                        </div>\n                      </div>\n                      <div class=\"flex items-center gap-4\" data-kid=\"325\">\n                        <div class=\"flex -space-x-2\" data-kid=\"326\">\n                          <img src=\"https://i.pravatar.cc/50?u=evelyn\" class=\"w-7 h-7 rounded-xl border-2 border-white shadow-sm\" data-kid=\"327\">\n                        </div>\n                        <p class=\"text-xs text-slate-600\" data-kid=\"328\">Requires sterile kit v2. Check vitals before procedure.</p>\n                      </div>\n                    </div>\n                  </div>\n\n                  \n                  <div class=\"relative pl-12 pb-12 border-l-2 border-slate-100\" data-kid=\"329\">\n                    <div class=\"absolute -left-[9px] top-0 w-4 h-4 rounded-full bg-white border-4 border-amber-500\" data-kid=\"330\"></div>\n                    <div class=\"absolute left-0 top-0 text-[11px] font-mono font-bold text-slate-400 -translate-x-full pr-6 mt-0.5\" data-kid=\"331\">12:30</div>\n                    <div class=\"py-4 px-6 bg-slate-50 rounded-2xl flex items-center gap-4 border border-slate-100\" data-kid=\"332\">\n                      <div class=\"w-10 h-10 rounded-full bg-amber-100 flex items-center justify-center text-amber-600\" data-kid=\"333\">\n                        <i class=\"ti ti-coffee text-xl\" data-kid=\"334\"></i>\n                      </div>\n                      <div data-kid=\"335\">\n                        <span class=\"text-sm font-bold text-slate-900\" data-kid=\"336\">Scheduled Lunch Break</span>\n                        <p class=\"text-xs text-slate-500\" data-kid=\"337\">45 minutes • Ends at 13:15</p>\n                      </div>\n                    </div>\n                  </div>\n\n                  \n                  <div class=\"relative pl-12 pb-0 border-l-2 border-slate-100 last:border-0\" data-kid=\"338\">\n                    <div class=\"absolute -left-[9px] top-0 w-4 h-4 rounded-full bg-white border-4 border-emerald-500\" data-kid=\"339\"></div>\n                    <div class=\"absolute left-0 top-0 text-[11px] font-mono font-bold text-slate-400 -translate-x-full pr-6 mt-0.5\" data-kid=\"340\">14:00</div>\n                    \n                    <div class=\"task-card bg-white border border-slate-100 rounded-[32px] p-6 shadow-sm cursor-pointer group\" data-kid=\"341\">\n                      <div class=\"flex justify-between items-start mb-4\" data-kid=\"342\">\n                        <div data-kid=\"343\">\n                          <span class=\"text-[10px] font-bold text-emerald-600 bg-emerald-50 px-2 py-0.5 rounded-md uppercase tracking-wider\" data-kid=\"344\">Clinical</span>\n                          <h4 class=\"text-lg font-bold text-slate-900 mt-1\" data-kid=\"345\">Post-Op Observation</h4>\n                        </div>\n                        <div class=\"text-right\" data-kid=\"346\">\n                          <p class=\"text-sm font-bold text-slate-900\" data-kid=\"347\">14:00 — 16:30</p>\n                          <p class=\"text-[11px] text-slate-500 font-medium\" data-kid=\"348\">Room 102 • Patient: Arthur D.</p>\n                        </div>\n                      </div>\n                      <div class=\"flex items-center gap-3\" data-kid=\"349\">\n                        <i class=\"ti ti-notes text-slate-300\" data-kid=\"350\"></i>\n                        <p class=\"text-xs text-slate-400\" data-kid=\"351\">Continuous monitoring of heart rate and O2 levels.</p>\n                      </div>\n                    </div>\n                  </div>\n               </div>\n            </div>\n          </div>\n        </div>\n      </section>\n\n    </div>\n  </main>\n\n  \n  <div class=\"fixed bottom-8 right-8 flex flex-col items-end gap-3 z-50\" data-kid=\"352\">\n     <div id=\"quick-actions\" class=\"hidden flex flex-col gap-2 mb-2 items-end\" data-kid=\"353\">\n       <button class=\"flex items-center gap-3 px-4 py-2 bg-white border border-slate-200 rounded-xl shadow-lg hover:bg-slate-50 scale-0 origin-bottom-right\" style=\"transition-delay: 100ms;\" data-kid=\"354\">\n         <span class=\"text-xs font-bold text-slate-600\" data-kid=\"355\">Urgent Alert</span>\n         <div class=\"p-2 bg-red-100 text-red-500 rounded-lg\" data-kid=\"356\"><i class=\"ti ti-alert-triangle\" data-kid=\"357\"></i></div>\n       </button>\n       <button class=\"flex items-center gap-3 px-4 py-2 bg-white border border-slate-200 rounded-xl shadow-lg hover:bg-slate-50 scale-0 origin-bottom-right\" style=\"transition-delay: 50ms;\" data-kid=\"358\">\n         <span class=\"text-xs font-bold text-slate-600\" data-kid=\"359\">Book Patient</span>\n         <div class=\"p-2 bg-blue-100 text-blue-500 rounded-lg\" data-kid=\"360\"><i class=\"ti ti-user-plus\" data-kid=\"361\"></i></div>\n       </button>\n     </div>\n     <button id=\"fab\" class=\"w-14 h-14 bg-linear-to-br from-slate-800 to-slate-950 text-white rounded-2xl shadow-2xl flex items-center justify-center hover:scale-105 transition-transform active:scale-95 group border border-slate-700\" data-kid=\"362\">\n       <i class=\"ti ti-plus text-2xl group-hover:rotate-90 transition-transform duration-300\" data-kid=\"363\"></i>\n     </button>\n  </div>\n\n</div>\n\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" data-kid=\"364\">\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"365\"></script>\n\n<script data-kid=\"366\">\n  function selectStaff(element, staffId) {\n    // 1. Manage Active Class in Sidebar\n    const items = document.querySelectorAll('.staff-item');\n    items.forEach(item => {\n      item.classList.remove('active', 'bg-emerald-50', 'border-emerald-500');\n      item.classList.add('border-transparent');\n    });\n    \n    if (element) {\n      element.classList.add('active', 'bg-emerald-50', 'border-emerald-500');\n      element.classList.remove('border-transparent');\n    }\n\n    const viewOverview = document.getElementById('view-overview');\n    const viewDetail = document.getElementById('view-detail');\n\n    if (staffId === 'all') {\n      // Switch to Overview\n      gsap.to(viewDetail, { \n        opacity: 0, \n        y: 20, \n        duration: 0.3, \n        onComplete: () => {\n          viewDetail.classList.add('hidden');\n          viewOverview.classList.remove('hidden');\n          gsap.fromTo(viewOverview, { opacity: 0, y: -20 }, { opacity: 1, y: 0, duration: 0.5, ease: \"power2.out\" });\n        } \n      });\n    } else {\n      // Mock data for the selection\n      const staffData = {\n        'sandra': { name: 'Sandra Bullock', role: 'RN • Wound Care', color: '#10b981', avatar: 'https://i.pravatar.cc/150?u=sandra' },\n        'marcus': { name: 'Marcus Thorne', role: 'Physiotherapist', color: '#f59e0b', avatar: 'https://i.pravatar.cc/150?u=marcus' },\n        'lara': { name: 'Lara Croft', role: 'Infusion Nurse', color: '#10b981', avatar: 'https://i.pravatar.cc/150?u=lara' },\n        'peter': { name: 'Peter Parker', role: 'Dietitian', color: '#94a3b8', avatar: 'https://i.pravatar.cc/150?u=peter' }\n      };\n\n      const data = staffData[staffId];\n      \n      // Update Detail View Content\n      document.getElementById('detail-name').innerText = data.name;\n      document.getElementById('detail-role').innerText = data.role;\n      document.getElementById('detail-title').innerText = data.name;\n      document.getElementById('detail-avatar').src = data.avatar;\n      document.getElementById('detail-status').style.backgroundColor = data.color;\n\n      // Switch to Detail\n      gsap.to(viewOverview, { \n        opacity: 0, \n        y: 20, \n        duration: 0.3, \n        onComplete: () => {\n          viewOverview.classList.add('hidden');\n          viewDetail.classList.remove('hidden');\n          gsap.fromTo(viewDetail, { opacity: 0, y: -20 }, { opacity: 1, y: 0, duration: 0.5, ease: \"power2.out\" });\n          \n          // Animate Timeline Entries\n          gsap.from(\"#view-detail .relative\", {\n            opacity: 0,\n            x: -20,\n            stagger: 0.1,\n            duration: 0.6,\n            ease: \"power3.out\"\n          });\n        } \n      });\n    }\n  }\n\n  // FAB Toggle\n  const fab = document.getElementById('fab');\n  const quickActions = document.getElementById('quick-actions');\n  let fabOpen = false;\n\n  fab.addEventListener('click', () => {\n    fabOpen = !fabOpen;\n    if (fabOpen) {\n      quickActions.classList.remove('hidden');\n      gsap.to(\"#quick-actions button\", {\n        scale: 1,\n        stagger: 0.1,\n        duration: 0.4,\n        ease: \"back.out(1.7)\"\n      });\n    } else {\n      gsap.to(\"#quick-actions button\", {\n        scale: 0,\n        stagger: -0.05,\n        duration: 0.3,\n        onComplete: () => quickActions.classList.add('hidden')\n      });\n    }\n  });\n\n  // Initial Entrance\n  window.addEventListener('load', () => {\n    gsap.from(\".staff-item\", {\n      opacity: 0,\n      x: -30,\n      stagger: 0.05,\n      duration: 0.8,\n      ease: \"power3.out\"\n    });\n    \n    gsap.from(\"#view-overview\", {\n      opacity: 0,\n      y: 30,\n      duration: 1,\n      delay: 0.3,\n      ease: \"power4.out\"\n    });\n  });\n</script>\n",
