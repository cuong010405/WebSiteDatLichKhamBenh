      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap');\n  \n  .font-sans { font-family: 'Inter', sans-serif; }\n  .font-heading { font-family: 'Plus Jakarta Sans', sans-serif; }\n  \n  .border-hairline { border-color: #E4E4E7; }\n  .bg-surface-secondary { background-color: #F5F6F7; }\n  .bg-surface-tinted { background-color: #ECFBF2; }\n  .text-primary-strong { color: #16A34A; }\n  .tight-tracking { letter-spacing: -0.02em; }\n  \n  /* Custom Switch Style */\n  .switch-checkbox:checked + .switch-label {\n    background-color: #18BE66;\n  }\n  .switch-checkbox:checked + .switch-label:before {\n    transform: translateX(20px);\n  }\n</style>\n\n<div class=\"font-sans text-[#0A0A0A] bg-white min-h-screen flex\" data-kid=\"1\">\n  \n  <aside class=\"w-64 border-r border-hairline h-screen sticky top-0 bg-white p-8 flex flex-col\" data-kid=\"2\">\n    <div class=\"flex items-center gap-2 mb-10\" data-kid=\"3\">\n      <div class=\"w-8 h-8 bg-[#18BE66] rounded-lg flex items-center justify-center\" data-kid=\"4\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"white\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"w-5 h-5\" data-kid=\"5\">\n          <path d=\"M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5\" data-kid=\"6\"></path>\n        </svg>\n      </div>\n      <span class=\"text-xl font-semibold font-heading tight-tracking\" data-kid=\"7\">MintCare</span>\n    </div>\n    \n    <nav class=\"space-y-1\" data-kid=\"8\">\n      <div class=\"flex items-center gap-3 px-3 py-2 text-muted-foreground hover:bg-surface-secondary rounded-full font-medium text-sm transition-colors cursor-pointer\" data-kid=\"9\">\n        <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-