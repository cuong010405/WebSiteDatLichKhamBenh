data-kid=\"207\">Tổng ca trực</p>\n              <div class=\"flex items-baseline gap-2\" data-kid=\"208\">\n                <span class=\"text-2xl font-bold text-white\" data-kid=\"209\">42</span>\n                <span class=\"text-[10px] font-bold text-emerald-400\" data-kid=\"210\">+12%</span>\n              </div>\n            </div>\n            <div class=\"h-8 w-px bg-slate-800\" data-kid=\"211\"></div>\n            <div data-kid=\"212\">\n              <p class=\"text-[10px] font-bold text-slate-400 uppercase tracking-[0.2em] mb-1\" data-kid=\"213\">Chờ xác nhận</p>\n              <div class=\"flex items-center gap-3\" data-kid=\"214\">\n                <span class=\"text-2xl font-bold text-white\" data-kid=\"215\">08</span>\n                <span class=\"w-1.5 h-1.5 rounded-full bg-amber-400 shadow-[0_0_8px_rgba(251,191,36,0.5)]\" data-kid=\"216\"></span>\n              </div>\n            </div>\n            <div class=\"h-8 w-px bg-slate-800\" data-kid=\"217\"></div>\n            <div data-kid=\"218\">\n              <p class=\"text-[10px] font-bold text-slate-400 uppercase tracking-[0.2em] mb-1\" data-kid=\"219\">Hoàn thành</p>\n              <div class=\"flex items-center gap-3\" data-kid=\"220\">\n                <span class=\"text-2xl font-bold text-white\" data-kid=\"221\">18</span>\n                <div class=\"w-5 h-5 rounded-full bg-emerald-500/20 flex items-center justify-center\" data-kid=\"222\">\n                  <i class=\"ti ti-check text-emerald-500 text-xs\" data-kid=\"223\"></i>\n                </div>\n              </div>\n            </div>\n          </div>\n          \n          <div class=\"flex items-center gap-4 bg-slate-800/50 p-2 pr-4 rounded-xl border border-slate-700\" data-kid=\"224\">\n            <div class=\"flex -space-x-1.5\" data-kid=\"225\">\n              <img src=\"https://i.pravatar.cc/100?u=1\" class=\"w-7 h-7 rounded-lg border-2 border-slate-800 object-cover\" data-kid=\"226\">\n              <img src=\"https://i.pravatar.cc/100?u=2\" class=\"w-7 h-7 rounded-lg border-2 border-slate-800 object-cover\" data-kid=\"227\">\n              <img src=\"https://i.pravatar.cc/100?u=3\" class=\"w-7 h-7 rounded-lg border-2 border-slate-800 object-cover\" data-kid=\"228\">\n              <div class=\"w-7 h-7 rounded-lg border-2 border-slate-800 bg-slate-700 flex items-center justify-center text-[9px] font-bold text-white\" data-kid=\"229\">+9</div>\n            </div>\n            <div data-kid=\"230\">\n              <p class=\"text-[10px] font-bold text-white leading-none\" data-kid=\"231\">12 Chuyên gia</p>\n              <p class=\"text-[9px] text-slate-400 mt-0.5\" data-kid=\"232\">đang trực tuyến</p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </main>\n</div>\n\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" data-kid=\"233\">\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"234\"></script>\n\n<script data-kid=\"235\">\n  window.addEventListener('DOMContentLoaded', () => {\n    // Initial entrance for cards\n    gsap.from(\".session-card\", {\n      opacity: 0,\n      scale: 0.9,\n      y: 8,\n      duration: 0.6,\n      stagger: 0.08,\n      ease: \"power2.out\",\n      delay: 0.3\n    });\n\n    // Row entrance\n    gsap.from(\".staff-sticky, .hour-grid\", {\n      opacity: 0,\n      x: -10,\n      duration: 0.5,\n      stagger: 0.05,\n      ease: \"power1.out\"\n    });\n  });\n</script>\n",
