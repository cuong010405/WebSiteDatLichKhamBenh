 bg-surface-secondary text-[#18181B] rounded-full font-medium text-sm transition-colors cursor-pointer\" data-kid=\"27\">\n        <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-settings\" data-kid=\"28\"><path d=\"M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z\" data-kid=\"29\"></path><circle cx=\"12\" cy=\"12\" r=\"3\" data-kid=\"30\"></circle></svg>\n        Cài đặt\n      </div>\n    </nav>\n  </aside>\n\n  \n  <main class=\"flex-1 flex flex-col bg-white\" data-kid=\"31\">\n    \n    <header class=\"border-b border-hairline px-10 py-6 flex items-center justify-between sticky top-0 bg-white/80 backdrop-blur-md z-10\" data-kid=\"32\">\n      <h1 class=\"text-2xl font-semibold font-heading tight-tracking\" data-kid=\"33\">Cài đặt hệ thống</h1>\n      <div class=\"flex items-center gap-4\" data-kid=\"34\">\n        <button class=\"bg-[#18181B] text-white px-6 py-2.5 rounded-full text-sm font-medium hover:opacity-90 transition-opacity\" data-kid=\"35\">\n          Lưu thay đổi\n        </button>\n      </div>\n    </header>\n\n    <div class=\"p-10 max-w-6xl mx-auto w-full\" data-kid=\"36\">\n      <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-12\" data-kid=\"37\">\n        \n        \n        <div class=\"lg:col-span-3\" data-kid=\"38\">\n          <nav class=\"flex flex-col gap-1 sticky top-32\" data-kid=\"39\">\n            <a href=\"#profile\" class=\"flex items-center gap-3 px-4 py-3 bg-surface-tinted text-primary-strong rounded-xl font-semibold text-sm transition-all border border-transparent hover:border-[#18BE66]/20\" data-kid=\"40\">\n              <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-user\" data-kid=\"41\"><path d=\"M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2\" data-kid=\"42\"></path><circle cx=\"12\" cy=\"7\" r=\"4\" data-kid=\"43\"></circle></svg>\n              Hồ sơ cá nhân\n            </a>\n            <a href=\"#notifications\" class=\"flex items-center gap-3 px-4 py-3 text-muted-foreground hover:bg-surface-secondary rounded-xl font-medium text-sm transition-all\" data-kid=\"44\">\n              <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-bell\" data-kid=\"45\"><path d=\"M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9\" data-kid=\"46\"></path><path d=\"M10.3 21a1.94 1.94 0 0 0 3.4 0\" data-kid=\"47\"></path></svg>\n              Thông báo\n            </a>\n            <a href=\"#security\" class=\"flex items-center gap-3 px-4 py-3 text-muted-foreground hover:bg-surface-secondary rounded-xl font-medium text-sm transition-all\" data-kid=\"48\">\n              <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-shield-check\" data-kid=\"49\"><path d=\"M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z\" data-kid=\"50\"></path><path d=\"m9 12 2 2 4-4\" data-kid=\"51\"></path></svg>\n              Bảo mật\n            </a>\n            <a href=\"#team\" class=\"flex items-center gap-3 px-4 py-3 text-muted-foreground hover:bg-surface-secondary rounded-xl font-medium text-sm transition-all\" data-kid=\"52\">\n              <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-users-round\" data-kid=\"53\"><path d=\"M18 21a8 8 0 0 0-16 0\" data-kid=\"54\"></path><circle cx=\"10\" cy=\"8\" r=\"5\" data-kid=\"55\"></circle><path d=\"M22 20c0-3.37-2-6.5-4-8a5 5 0 0 0-.45-8.3\" data-kid=\"56\"></path></svg>\n              Quản lý nhóm\n            </a>\n          </nav>\n        </div>\n\n        \n        <div class=\"lg:col-span-9 space-y-12\" data-kid=\"57\">\n          \n          \n          <section id=\"profile\" class=\"space-y-8 animate-in fade-in slide-in-from-bottom-4 duration-500\" data-kid=\"58\">\n            <div data-kid=\"59\">\n              <h2 class=\"text-xl font-semibold tight-tracking mb-2\" data-kid=\"60\">Thông tin cá nhân</h2>\n              <p class=\"text-sm text-muted-foreground\" data-kid=\"61\">Cập nhật ảnh đại diện và thông tin cơ bản của bạn tại đây.</p>\n            </div>\n            \n            <div class=\"flex items-center gap-6\" data-kid=\"62\">\n              <div class=\"relative group\" data-kid=\"63\">\n                <img src=\"https://i.pravatar.cc/150?u=admin\" class=\"w-24 h-24 rounded-3xl border border-hairline object-cover\" loading=\"lazy\" decoding=\"async\" data-kid=\"64\">\n                <div class=\"absolute inset-0 bg-black/40 rounded-3xl opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center cursor-pointer\" data-kid=\"65\">\n                  <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"white\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-camera\" data-kid=\"66\"><path d=\"M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z\" data-kid=\"67\"></path><circle cx=\"12\" cy=\"13\" r=\"3\" data-kid=\"68\"></circle></svg>\n                </div>\n              </div>\n              <div class=\"space-y-2\" data-kid=\"69\">\n                <button class=\"text-sm font-semibold text-primary-strong hover:underline\" data-kid=\"70\">Thay đổi ảnh đại diện</button>\n                <p class=\"text-xs text-on-surface-tertiary\" data-kid=\"71\">JPG, GIF hoặc PNG. Tối đa 2MB.</p>\n              </div>\n            </div>\n\n            <div class=\"grid grid-cols-1 md:grid-cols-2 gap-6\" data-kid=\"72\">\n              <div class=\"space-y-2\" data-kid=\"73\">\n                <label class=\"text-sm font-medium\" data-kid=\"74\">Họ và tên</label>\n                <input type=\"text\" value=\"BS. Alex Miller\" class=\"w-full bg-surface-secondary border-transparent focus:border-[#18BE66] focus:bg-white outline-none rounded-xl px-4 py-3 text-sm transition-all border h-12\" data-kid=\"75\">\n              </div>\n              <div class=\"space-y-2\" data-kid=\"76\">\n                <label class=\"text-sm font-medium\" data-kid=\"77\">Địa chỉ Email</label>\n                <input type=\"email\" value=\"alex.miller@mintcare.com\" class=\"w-full bg-surface-secondary border-transparent focus:border-[#18BE66] focus:bg-white outline-none rounded-xl px-4 py-3 text-sm transition-all border h-12\" data-kid=\"78\">\n              </div>\n              <div class=\"space-y-2\" data-kid=\"79\">\n                <label class=\"text-sm font-medium\" data-kid=\"80\">Chức vụ</label>\n                <input type=\"text\" value=\"Quản trị viên\" readonly class=\"w-full bg-surface-secondary border-transparent opacity-60 rounded-xl px-4 py-3 text-sm h-12 cursor-not-allowed\" data-kid=\"81\">\n              </div>\n              <div class=\"space-y-2\" data-kid=\"82\">\n                <label class=\"text-sm font-medium\" data-kid=\"83\">Số điện thoại</label>\n                <input type=\"text\" value=\"+84 901 234 567\" class=\"w-full bg-surface-secondary border-transparent focus:border-[#18BE66] focus:bg-white outline-none rounded-xl px-4 py-3 text-sm transition-all border h-12\" data-kid=\"84\">\n              </div>\n            </div>\n          </section>\n\n          <div class=\"h-px bg-hairline w-full\" data-kid=\"85\"></div>\n\n          \n          <section id=\"notifications\" class=\"space-y-8\" data-kid=\"86\">\n            <div data-kid=\"87\">\n              <h2 class=\"text-xl font-semibold tight-tracking mb-2\" data-kid=\"88\">Cài đặt thông báo</h2>\n              <p class=\"text-sm text-muted-foreground\" data-kid=\"89\">Chọn cách bạn muốn nhận thông tin về các hoạt động của hệ thống.</p>\n            </div>\n\n            <div class=\"space-y-6\" data-kid=\"90\">\n              <div class=\"flex items-center justify-between p-4 rounded-2xl border border-hairline hover:bg-surface-secondary transition-colors group\" data-kid=\"91\">\n                <div class=\"flex gap-4\" data-kid=\"92\">\n                  <div class=\"w-10 h-10 bg-surface-tinted rounded-xl flex items-center justify-center text-primary-strong\" data-kid=\"93\">\n                    <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-mail\" data-kid=\"94\"><rect width=\"20\" height=\"16\" x=\"2\" y=\"4\" rx=\"2\" data-kid=\"95\"></rect><path d=\"m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7\" data-kid=\"96\"></path></svg>\n                  </div>\n                  <div data-kid=\"97\">\n                    <p class=\"text-sm font-semibold\" data-kid=\"98\">Thông báo qua Email</p>\n                    <p class=\"text-xs text-muted-foreground\" data-kid=\"99\">Nhận bản tin tóm tắt hàng ngày về các ca trực.</p>\n                  </div>\n                </div>\n                <div class=\"relative inline-block w-11 h-6 transition duration-200 ease-in-out\" data-kid=\"100\">\n                  <input type=\"checkbox\" id=\"email-notif\" checked class=\"switch-checkbox absolute opacity-0 w-0 h-0\" data-kid=\"101\">\n                  <label for=\"email-notif\" class=\"switch-label block overflow-hidden h-6 rounded-full bg-zinc-200 cursor-pointer before:content-[''] before:absolute before:left-0.5 before:top-0.5 before:bg-white before:w-5 before:h-5 before:rounded-full before:transition-transform before:duration-200\" data-kid=\"102\"></label>\n                </div>\n              </div>\n\n              <div class=\"flex items-center justify-between p-4 rounded-2xl border border-hairline hover:bg-surface-secondary transition-colors group\" data-kid=\"103\">\n                <div class=\"flex gap-4\" data-kid=\"104\">\n                  <div class=\"w-10 h-10 bg-surface-tinted rounded-xl flex items-center justify-center text-primary-strong\" data-kid=\"105\">\n                    <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-smartphone\" data-kid=\"106\"><rect width=\"14\" height=\"20\" x=\"5\" y=\"2\" rx=\"2\" ry=\"2\" data-kid=\"107\"></rect><path d=\"M12 18h.01\" data-kid=\"108\"></path></svg>\n                  </div>\n                  <div data-kid=\"109\">\n                    <p class=\"text-sm font-semibold\" data-kid=\"110\">Thông báo đẩy trên App</p>\n                    <p class=\"text-xs text-muted-foreground\" data-kid=\"111\">Thông báo tức thì khi có thay đổi lịch trực khẩn cấp.</p>\n                  </div>\n                </div>\n                <div class=\"relative inline-block w-11 h-6 transition duration-200 ease-in-out\" data-kid=\"112\">\n                  <input type=\"checkbox\" id=\"app-notif\" class=\"switch-checkbox absolute opacity-0 w-0 h-0\" data-kid=\"113\">\n                  <label for=\"app-notif\" class=\"switch-label block overflow-hidden h-6 rounded-full bg-zinc-200 cursor-pointer before:content-[''] before:absolute before:left-0.5 before:top-0.5 before:bg-white before:w-5 before:h-5 before:rounded-full before:transition-transform before:duration-200\" data-kid=\"114\"></label>\n                </div>\n              </div>\n            </div>\n          </section>\n\n          <div class=\"h-px bg-hairline w-full\" data-kid=\"115\"></div>\n\n          \n          <section id=\"security\" class=\"space-y-8 pb-20\" data-kid=\"116\">\n            <div data-kid=\"117\">\n              <h2 class=\"text-xl font-semibold tight-tracking mb-2\" data-kid=\"118\">Bảo mật tài khoản</h2>\n              <p class=\"text-sm text-muted-foreground\" data-kid=\"119\">Quản lý mật khẩu và các phương thức xác thực bảo mật.</p>\n            </div>\n\n            <div class=\"bg-surface-tinted/50 rounded-3xl p-8 border border-[#18BE66]/20\" data-kid=\"120\">\n              <div class=\"flex items-start justify-between\" data-kid=\"121\">\n                <div class=\"space-y-4\" data-kid=\"122\">\n                  <div class=\"flex items-center gap-3 text-primary-strong font-semibold\" data-kid=\"123\">\n                    <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-key-round\" data-kid=\"124\"><path d=\"M2 18v3c0 .6.4 1 1 1h4v-3h3v-3h2l1.4-1.4a6.5 6.5 0 1 0-4-4Z\" data-kid=\"125\"></path><circle cx=\"16.5\" cy=\"7.5\" r=\".5\" data-kid=\"126\"></circle></svg>\n                    Xác thực 2 yếu tố (2FA)\n                  </div>\n                  <p class=\"text-sm text-[#333] max-w-md leading-relaxed\" data-kid=\"127\">Thêm một lớp bảo mật bổ sung cho tài khoản của bạn. Sau khi nhập mật khẩu, bạn sẽ được yêu cầu mã xác minh từ ứng dụng Google Authenticator.</p>\n                  <button class=\"bg-[#18BE66] text-white px-6 py-2 rounded-full text-sm font-semibold hover:opacity-90 transition-opacity\" data-kid=\"128\">\n                    Kích hoạt ngay\n                  </button>\n                </div>\n                <div class=\"bg-white p-4 rounded-2xl border border-[#18BE66]/10 shadow-sm\" data-kid=\"129\">\n                  <div class=\"w-32 h-32 bg-zinc-100 rounded-lg flex items-center justify-center opacity-40\" data-kid=\"130\">\n                    <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"48\" height=\"48\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-qr-code\" data-kid=\"131\"><rect width=\"5\" height=\"5\" x=\"3\" y=\"3\" rx=\"1\" data-kid=\"132\"></rect><rect width=\"5\" height=\"5\" x=\"16\" y=\"3\" rx=\"1\" data-kid=\"133\"></rect><rect width=\"5\" height=\"5\" x=\"3\" y=\"16\" rx=\"1\" data-kid=\"134\"></rect><path d=\"M21 16h-3a2 2 0 0 0-2 2v3\" data-kid=\"135\"></path><path d=\"M21 21v.01\" data-kid=\"136\"></path><path d=\"M12 7v3a2 2 0 0 1-2 2H7\" data-kid=\"137\"></path><path d=\"M3 12h.01\" data-kid=\"138\"></path><path d=\"M12 3h.01\" data-kid=\"139\"></path><path d=\"M12 16v.01\" data-kid=\"140\"></path><path d=\"M16 12h1\" data-kid=\"141\"></path><path d=\"M21 12v.01\" data-kid=\"142\"></path><path d=\"M12 21v.01\" data-kid=\"143\"></path></svg>\n                  </div>\n                </div>\n              </div>\n            </div>\n\n            <div class=\"flex items-center justify-between border-t border-hair-line pt-8\" data-kid=\"144\">\n              <div data-kid=\"145\">\n                <p class=\"text-sm font-semibold\" data-kid=\"146\">Thay đổi mật khẩu</p>\n                <p class=\"text-xs text-muted-foreground\" data-kid=\"147\">Bạn nên sử dụng mật khẩu mạnh có ít nhất 12 ký tự.</p>\n              </div>\n              <button class=\"border border-hairline px-6 py-2 rounded-full text-sm font-semibold hover:bg-surface-secondary transition-colors\" data-kid=\"148\">\n                Cập nhật mật khẩu\n              </button>\n            </div>\n          </section>\n\n        </div>\n      </div>\n    </div>\n  </main>\n</div>",
