      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap');\n\n  :root {\n    --color-primary: #18BE66;\n    --color-primary-dark: #15A358;\n    --color-primary-light: #ECFBF2;\n    --color-border: #E2E8F0;\n    --color-bg: #F8FAFB;\n    --sidebar-width: 256px;\n    --staff-col-width: 160px;\n    --hour-col-width: 80px;\n  }\n\n  body {\n    font-family: 'Plus Jakarta Sans', sans-serif;\n    background-color: var(--color-bg);\n    color: #0F172A;\n    margin: 0;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  .font-mono {\n    font-family: 'JetBrains Mono', monospace;\n  }\n\n  .custom-scrollbar::-webkit-scrollbar {\n    width: 6px;\n    height: 6px;\n  }\n  .custom-scrollbar::-webkit-scrollbar-track {\n    background: transparent;\n  }\n  .custom-scrollbar::-webkit-scrollbar-thumb {\n    background: #CBD5E1;\n    border-radius: 10px;\n  }\n  .custom-scrollbar::-webkit-scrollbar-thumb:hover {\n    background: #94A3B8;\n  }\n\n  /* Grid Layout */\n  .timeline-container {\n    display: grid;\n    grid-template-columns: var(--staff-col-width) 1fr;\n    background: white;\n  }\n\n  .hour-grid {\n    display: grid;\n    grid-template-columns: repeat(12, var(--hour-col-width));\n    position: relative;\n  }\n\n  .hour-cell {\n    width: var(--hour-col-width);\n    border-right: 1px solid var(--color-border);\n    flex-shrink: 0;\n  }\n\n  .session-card {\n    position: absolute;\n    top: 6px;\n    bottom: 6px;\n    border-radius: 8px;\n    padding: 6px 8px;\n    display: flex;\n    flex-direction: column;\n    font-size: 10px;\n    border: 1px solid transparent;\n    cursor: pointer;\n    box-sizing: border-box;\n    z-index: 10;\n    line-height: 1.2;\n  }\n\n  .session-card.confirmed {\n    background-color: var(--color-primary-light);\n    border-color: rgba(24, 190, 102, 0.25);\n    color: var(--color-primary-dark);\n  }\n\n  .session-card.pending {\n    background-color: #F1F5F9;\n    border-color: #E2E8F0;\n    color: #64748B;\n  }\n\n  .session-card:hover {\n    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.08);\n    transform: translateY(-2px) scale(1.02);\n    z-index: 20;\n  }\n\n  .staff-sticky {\n    position: sticky;\n    left: 0;\n    z-index: 30;\n    background: white;\n    border-right: 1px solid var(--color-border);\n  }\n\n  .header-sticky {\n    position: sticky;\n    top: 0;\n    z-index: 40;\n    background: rgba(255, 255, 255, 0.9);\n    backdrop-filter: blur(8px);\n  }\n\n  .time-indicator {\n    position: absolute;\n    top: 40px; /* Below header cells */\n    bottom: 0;\n    width: 2px;\n    background-color: var(--color-primary);\n    z-index: 25;\n    pointer-events: none;\n  }\n\n  .time-indicator::before {\n    content: '';\n    position: absolute;\n    top: 0;\n    left: 50%;\n    transform: translateX(-50%);\n    width: 6px;\n    height: 6px;\n    background-color: var(--color-primary);\n    border-radius: 50%;\n    box-shadow: 0 0 0 3px rgba(24, 190, 102, 0.2);\n  }\n</style>\n\n<div class=\"flex min-h-screen bg-[var(--color-bg)]\" data-kid=\"1\">\n  \n  <aside class=\"w-[var(--sidebar-width)] border-r border-slate-200 bg-white flex flex-col fixed h-full z-50\" data-kid=\"2\">\n    <div class=\"p-6\" data-kid=\"3\">\n      <div class=\"flex items-center gap-2 mb-10\" data-kid=\"4\">\n        <div class=\"w-9 h-9 bg-[var(--color-primary)] rounded-xl flex items-center justify-center shadow-lg shadow-emerald-500/20\" data-kid=\"5\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"white\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"w-5 h-5\" data-kid=\"6\">\n            <path d=\"M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5\" data-kid=\"7\"></path>\n          </svg>\n        </div>\n        <span class=\"text-xl font-bold tracking-tight text-slate-900\" data-kid=\"8\">MintCare</span>\n      </div>\n      \n      <nav class=\"space-y-1.5\" data-kid=\"9\">\n        <a href=\"#\" class=\"flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-medium text-slate-500 hover:bg-slate-50 transition-colors\" data-kid=\"10\">\n          <i class=\"ti ti-layout-dashboard text-lg\" data-kid=\"11\"></i>\n          <span data-kid=\"12\">Tổng quan</span>\n        </a>\n        <a href=\"#\" class=\"flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-medium text-slate-500 hover:bg-slate-50 transition-colors\" data-kid=\"13\">\n          <i class=\"ti ti-users text-lg\" data-kid=\"14\"></i>\n          <span data-kid=\"15\">Nhân viên</span>\n        </a>\n        <a href=\"#\" class=\"flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-semibold bg-[var(--color-primary-light)] text-[var(--color-primary-dark)]\" data-kid=\"16\">\n          <i class=\"ti ti-calendar-event text-lg\" data-kid=\"17\"></i>\n          <span data-kid=\"18\">Lịch trực</span>\n        </a>\n        <a href=\"#\" class=\"flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-medium text-slate-500 hover:bg-slate-50 transition-colors\" data-kid=\"19\">\n          <i class=\"ti ti-user-heart text-lg\" data-kid=\"20\"></i>\n          <span data-kid=\"21\">Bệnh nhân</span>\n        </a>\n        <a href=\"#\" class=\"flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-medium text-slate-500 hover:bg-slate-50 transition-colors\" data-kid=\"22\">\n          <i class=\"ti ti-chart-bar text-lg\" data-kid=\"23\"></i>\n          <span data-kid=\"24\">Báo cáo</span>\n        </a>\n        <a href=\"#\" class=\"flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-medium text-slate-500 hover:bg-slate-50 transition-colors\" data-kid=\"25\">\n          <i class=\"ti ti-settings text-lg\" data-kid=\"26\"></i>\n          <span data-kid=\"27\">Cài đặt</span>\n        </a>\n      </nav>\n    </div>\n\n    <div class=\"mt-auto p-6\" data-kid=\"28\">\n      <div class=\"bg-slate-50 rounded-2xl p-4 border border-slate-100\" data-kid=\"29\">\n        <div class=\"flex items-center gap-3 mb-3\" data-kid=\"30\">\n          <div class=\"w-2 h-2 rounded-full bg-emerald-500 animate-pulse\" data-kid=\"31\"></div>\n          <span class=\"text-[11px] font-bold text-slate-500 uppercase tracking-wider\" data-kid=\"32\">System Status</span>\n        </div>\n        <p class=\"text-[12px] text-slate-600 font-medium\" data-kid=\"33\">Hoạt động bình thường</p>\n      </div>\n    </div>\n  </aside>\n\n  \n  <main class=\"ml-[var(--sidebar-width)] flex-1 flex flex-col min-w-0\" data-kid=\"34\">\n    \n    <header class=\"h-20 border-b border-slate-200 bg-white/80 backdrop-blur-md sticky top-0 z-40 px-10 flex items-center justify-between\" data-kid=\"35\">\n      <div class=\"flex items-center gap-4 flex-1 max-w-xl\" data-kid=\"36\">\n        <div class=\"relative flex-1\" data-kid=\"37\">\n          <i class=\"ti ti-search absolute left-3.5 top-1/2 -translate-y-1/2 text-slate-400\" data-kid=\"38\"></i>\n          <input type=\"text\" placeholder=\"Tìm kiếm chuyên gia, bệnh nhân...\" class=\"w-full bg-slate-100 border-none rounded-full py-2 pl-10 pr-4 text-sm focus:ring-2 focus:ring-[var(--color-primary)]/20 outline-none transition-all\" data-kid=\"39\">\n        </div>\n      </div>\n      <div class=\"flex items-center gap-4\" data-kid=\"40\">\n        <button class=\"p-2 text-slate-500 hover:bg-slate-50 rounded-full relative transition-colors\" data-kid=\"41\">\n          <i class=\"ti ti-bell text-xl\" data-kid=\"42\"></i>\n          <span class=\"absolute top-2 right-2 w-2 h-2 bg-red-500 border-2 border-white rounded-full\" data-kid=\"43\"></span>\n        </button>\n        <div class=\"h-8 w-[1px] bg-slate-200 mx-2\" data-kid=\"44\"></div>\n        <div class=\"flex items-center gap-3 cursor-pointer group\" data-kid=\"45\">\n          <div class=\"text-right hidden sm:block\" data-kid=\"46\">\n            <p class=\"text-sm font-bold text-slate-900 leading-none\" data-kid=\"47\">BS. Lê Minh</p>\n            <p class=\"text-[11px] text-slate-500 mt-1\" data-kid=\"48\">Admin Dashboard</p>\n          </div>\n          <img src=\"https://i.pravatar.cc/150?u=admin\" class=\"w-10 h-10 rounded-xl object-cover border-2 border-slate-100 group-hover:border-[var(--color-primary)]/30 transition-all\" data-kid=\"49\">\n        </div>\n      </div>\n    </header>\n\n    \n    <div class=\"p-8 pb-0\" data-kid=\"50\">\n      <div class=\"flex flex-col md:flex-row md:items-end justify-between gap-6 mb-8\" data-kid=\"51\">\n        <div class=\"flex items-start gap-4\" data-kid=\"52\">\n          <div data-kid=\"53\">\n            <div class=\"flex items-center gap-2 mb-2\" data-kid=\"54\">\n              <span class=\"px-2 py-0.5 bg-emerald-100 text-[var(--color-primary-dark)] text-[10px] font-bold rounded uppercase tracking-wider\" data-kid=\"55\">Lịch biểu</span>\n              <span class=\"text-slate-400 text-xs\" data-kid=\"56\">•</span>\n              <span class=\"text-slate-500 text-xs font-medium\" data-kid=\"57\">Hôm nay, 18 Tháng 6, 2026</span>\n            </div>\n            <h1 class=\"text-3xl font-bold text-slate-900 tracking-tight\" data-kid=\"58\">Lịch trực chuyên gia</h1>\n          </div>\n          <button class=\"mt-8 flex items-center gap-2 px-3.5 py-1.5 bg-white border border-slate-200 rounded-xl text-xs font-bold text-slate-700 hover:border-emerald-500/30 hover:bg-emerald-50/30 transition-all shadow-sm\" data-kid=\"59\">\n            <i class=\"ti ti-adjustments-horizontal text-sm\" data-kid=\"60\"></i>\n            Bộ lọc\n          </button>\n        </div>\n        <div class=\"flex items-center gap-3\" data-kid=\"61\">\n          <div class=\"flex bg-slate-100 p-1 rounded-xl border border-slate-200\" data-kid=\"62\">\n            <button class=\"px-4 py-1.5 text-xs font-bold rounded-lg bg-white shadow-sm text-slate-900\" data-kid=\"63\">Ngày</button>\n            <button class=\"px-4 py-1.5 text-xs font-semibold text-slate-500 hover:text-slate-900 transition-colors\" data-kid=\"64\">Tuần</button>\n            <button class=\"px-4 py-1.5 text-xs font-semibold text-slate-500 hover:text-slate-900 transition-colors\" data-kid=\"65\">Tháng</button>\n          </div>\n          <button class=\"bg-[var(--color-primary)] text-white px-5 py-2.5 rounded-xl text-sm font-bold flex items-center gap-2 hover:bg-[var(--color-primary-dark)] transition-all shadow-lg shadow-emerald-500/20 active:scale-95\" data-kid=\"66\">\n            <i class=\"ti ti-calendar-plus text-lg\" data-kid=\"67\"></i>\n            Phân công ca trực\n          </button>\n        </div>\n      </div>\n\n      \n      <div class=\"bg-white rounded-[24px] border border-slate-200 shadow-sm overflow-hidden mb-8 max-w-[1120px] relative\" data-kid=\"68\">\n        <div class=\"overflow-x-auto custom-scrollbar\" data-kid=\"69\">\n          <div class=\"timeline-container relative min-w-[1120px]\" data-kid=\"70\">\n            \n            <div class=\"time-indicator\" style=\"left: 320px;\" data-kid=\"71\"></div>\n\n            \n            <div class=\"staff-sticky bg-slate-50/50 p-3 border-b border-slate-200\" data-kid=\"72\">\n              <span class=\"text-[10px] font-bold uppercase tracking-wider text-slate-400\" data-kid=\"73\">Chuyên gia</span>\n            </div>\n            \n            \n            <div class=\"hour-grid bg-slate-50/50 border-b border-slate-200\" data-kid=\"74\">\n              \n              <div class=\"hour-cell py-3 flex flex-col items-center justify-center\" data-kid=\"75\">\n                <span class=\"text-[11px] font-bold text-slate-500\" data-kid=\"76\">08:00</span>\n              </div>\n              <div class=\"hour-cell py-3 flex flex-col items-center justify-center\" data-kid=\"77\">\n                <span class=\"text-[11px] font-bold text-slate-500\" data-kid=\"78\">09:00</span>\n              </div>\n              <div class=\"hour-cell py-3 flex flex-col items-center justify-center bg-emerald-50/50\" data-kid=\"79\">\n                <span class=\"text-[11px] font-bold text-[var(--color-primary-dark)]\" data-kid=\"80\">10:00</span>\n                <div class=\"w-1.5 h-1.5 rounded-full bg-[var(--color-primary)] mt-1 animate-pulse\" data-kid=\"81\"></div>\n              </div>\n              <div class=\"hour-cell py-3 flex flex-col items-center justify-center\" data-kid=\"82\">\n                <span class=\"text-[11px] font-bold text-slate-500\" data-kid=\"83\">11:00</span>\n              </div>\n              <div class=\"hour-cell py-3 flex flex-col items-center justify-center\" data-kid=\"84\">\n                <span class=\"text-[11px] font-bold text-slate-500\" data-kid=\"85\">12:00</span>\n              </div>\n              <div class=\"hour-cell py-3 flex flex-col items-center justify-center\" data-kid=\"86\">\n                <span class=\"text-[11px] font-bold text-slate-500\" data-kid=\"87\">13:00</span>\n              </div>\n              <div class=\"hour-cell py-3 flex flex-col items-center justify-center\" data-kid=\"88\">\n                <span class=\"text-[11px] font-bold text-slate-500\" data-kid=\"89\">14:00</span>\n              </div>\n              <div class=\"hour-cell py-3 flex flex-col items-center justify-center\" data-kid=\"90\">\n                <span class=\"text-[11px] font-bold text-slate-500\" data-kid=\"91\">15:00</span>\n              </div>\n              <div class=\"hour-cell py-3 flex flex-col items-center justify-center\" data-kid=\"92\">\n                <span class=\"text-[11px] font-bold text-slate-500\" data-kid=\"93\">16:00</span>\n              </div>\n              <div class=\"hour-cell py-3 flex flex-col items-center justify-center\" data-kid=\"94\">\n                <span class=\"text-[11px] font-bold text-slate-500\" data-kid=\"95\">17:00</span>\n              </div>\n              <div class=\"hour-cell py-3 flex flex-col items-center justify-center\" data-kid=\"96\">\n                <span class=\"text-[11px] font-bold text-slate-500\" data-kid=\"97\">18:00</span>\n              </div>\n              <div class=\"hour-cell py-3 flex flex-col items-center justify-center\" data-kid=\"98\">\n                <span class=\"text-[11px] font-bold text-slate-500\" data-kid=\"99\">19:00</span>\n              </div>\n            </div>\n\n            \n            <div class=\"staff-sticky p-2 flex items-center gap-2 border-b border-slate-100 hover:bg-slate-50 cursor-pointer group\" data-kid=\"100\">\n              <img src=\"https://i.pravatar.cc/100?u=sandra\" class=\"w-8 h-8 rounded-lg object-cover border border-slate-100 group-hover:border-[var(--color-primary)]/30 transition-all\" data-kid=\"101\">\n              <div class=\"min-w-0\" data-kid=\"102\">\n                <p class=\"text-[11px] font-bold text-slate-900 truncate group-hover:text-[var(--color-primary-dark)] transition-colors\" data-kid=\"103\">Sandra Bullock</p>\n                <p class=\"text-[9px] text-slate-400 font-medium truncate uppercase\" data-kid=\"104\">RN • Vết thương</p>\n              </div>\n            </div>\n            <div class=\"hour-grid border-b border-slate-100 h-20 group hover:bg-slate-50/30\" data-kid=\"105\">\n              <div class=\"hour-cell\" data-kid=\"106\"></div><div class=\"hour-cell\" data-kid=\"107\"></div><div class=\"hour-cell\" data-kid=\"108\"></div><div class=\"hour-cell\" data-kid=\"109\"></div>\n              <div class=\"hour-cell\" data-kid=\"110\"></div><div class=\"hour-cell\" data-kid=\"111\"></div><div class=\"hour-cell\" data-kid=\"112\"></div><div class=\"hour-cell\" data-kid=\"113\"></div>\n              <div class=\"hour-cell\" data-kid=\"114\"></div><div class=\"hour-cell\" data-kid=\"115\"></div><div class=\"hour-cell\" data-kid=\"116\"></div><div class=\"hour-cell\" data-kid=\"117\"></div>\n              \n              \n              <div class=\"session-card confirmed\" style=\"left: 1px; width: 78px;\" data-kid=\"118\">\n                <p class=\"font-bold mb-0.5\" data-kid=\"119\">Kiểm tra định kỳ</p>\n                <div class=\"mt-auto opacity-90 leading-tight\" data-kid=\"120\">\n                  <p class=\"font-semibold text-[9px]\" data-kid=\"121\">Evelyn G.</p>\n                  <p class=\"text-[8px] opacity-75\" data-kid=\"122\">08:00 - 09:00</p>\n                </div>\n              </div>\n              <div class=\"session-card confirmed\" style=\"left: 241px; width: 158px;\" data-kid=\"123\">\n                <p class=\"font-bold mb-0.5\" data-kid=\"124\">Thay băng vết thương</p>\n                <div class=\"mt-auto opacity-90 leading-tight\" data-kid=\"125\">\n                  <p class=\"font-semibold text-[9px]\" data-kid=\"126\">Arthur D.</p>\n                  <p class=\"text-[8px] opacity-75\" data-kid=\"127\">11:00 - 13:00</p>\n                </div>\n              </div>\n            </div>\n\n            \n            <div class=\"staff-sticky p-2 flex items-center gap-2 border-b border-slate-100 hover:bg-slate-50 cursor-pointer group\" data-kid=\"128\">\n              <img src=\"https://i.pravatar.cc/100?u=marcus\" class=\"w-8 h-8 rounded-lg object-cover border border-slate-100 group-hover:border-[var(--color-primary)]/30 transition-all\" data-kid=\"129\">\n              <div class=\"min-w-0\" data-kid=\"130\">\n                <p class=\"text-[11px] font-bold text-slate-900 truncate group-hover:text-[var(--color-primary-dark)] transition-colors\" data-kid=\"131\">Marcus Thorne</p>\n                <p class=\"text-[9px] text-slate-400 font-medium truncate uppercase\" data-kid=\"132\">PT • Phục hồi</p>\n              </div>\n            </div>\n            <div class=\"hour-grid border-b border-slate-100 h-20 group hover:bg-slate-50/30\" data-kid=\"133\">\n              <div class=\"hour-cell\" data-kid=\"134\"></div><div class=\"hour-cell\" data-kid=\"135\"></div><div class=\"hour-cell\" data-kid=\"136\"></div><div class=\"hour-cell\" data-kid=\"137\"></div>\n         