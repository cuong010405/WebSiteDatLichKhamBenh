      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@500&display=swap');\n\n  :root {\n    --color-primary: #18BE66;\n    --color-primary-strong: #16A34A;\n    --color-action: #18181B;\n    --color-surface: #FFFFFF;\n    --color-surface-secondary: #F5F6F7;\n    --color-surface-tinted: #ECFBF2;\n    --color-hairline: #E4E4E7;\n    --color-foreground: #0A0A0A;\n    --color-muted-foreground: #52525B;\n    --color-on-surface-tertiary: #A1A1AA;\n  }\n\n  body {\n    font-family: 'Plus Jakarta Sans', sans-serif;\n    color: var(--color-foreground);\n    background-color: var(--color-surface);\n  }\n\n  .tight-tracking { letter-spacing: -0.02em; }\n  .eyebrow { font-family: 'JetBrains Mono', monospace; font-size: 11px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.04em; color: var(--color-primary-strong); }\n</style>\n\n<div class=\"flex min-h-screen\" data-kid=\"1\">\n  \n  <aside class=\"w-64 border-r border-(--color-hairline) fixed h-full bg-white flex flex-col z-50\" data-kid=\"2\">\n    <div class=\"p-8 pb-4\" data-kid=\"3\">\n      <div class=\"flex items-center gap-2 mb-10\" data-kid=\"4\">\n        <div class=\"w-8 h-8 bg-(--color-primary) rounded-lg flex items-center justify-center\" data-kid=\"5\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"white\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"w-5 h-5\" data-kid=\"6\">\n            <path d=\"M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5\" data-kid=\"7\"></path>\n          </svg>\n        </div>\n        <span class=\"text-xl font-semibold tight-tracking\" data-kid=\"8\">MintCare</span>\n      </div>\n      <nav class=\"space-y-1\" data-kid=\"9\">\n        <div class=\"flex items-center gap-3 px-3 py-2 text-(--color-muted-foreground) hover:bg-(--color-surface-secondary) rounded-full font-medium text-sm transition-colors cursor-pointer\" data-kid=\"10\">\n          <i data-lucide=\"layout-grid\" class=\"w-4 h-4\" data-kid=\"11\"></i> Tổng quan\n        </div>\n        <div class=\"flex items-center gap-3 px-3 py-2 bg-(--color-surface-secondary) text-(--color-foreground) rounded-full font-medium text-sm transition-colors cursor-pointer\" data-kid=\"12\">\n          <i data-lucide=\"users\" class=\"w-4 h-4\" data-kid=\"13\"></i> Nhân viên\n        </div>\n        <div class=\"flex items-center gap-3 px-3 py-2 text-(--color-muted-foreground) hover:bg-(--color-surface-secondary) rounded-full font-medium text-sm transition-colors cursor-pointer\" data-kid=\"14\">\n          <i data-lucide=\"calendar\" class=\"w-4 h-4\" data-kid=\"15\"></i> Lịch trực\n        </div>\n        <div class=\"flex items-center gap-3 px-3 py-2 text-(--color-muted-foreground) hover:bg-(--color-surface-secondary) rounded-full font-medium text-sm transition-colors cursor-pointer\" data-kid=\"16\">\n          <i data-lucide=\"activity\" class=\"w-4 h-4\" data-kid=\"17\"></i> Bệnh nhân\n        </div>\n        <div class=\"flex items-center gap-3 px-3 py-2 text-(--color-muted-foreground) hover:bg-(--color-surface-secondary) rounded-full font-medium text-sm transition-colors cursor-pointer\" data-kid=\"18\">\n          <i data-lucide=\"file-text\" class=\"w-4 h-4\" data-kid=\"19\"></i> Báo cáo\n        </div>\n      </nav>\n    </div>\n    <div class=\"mt-auto p-8 pt-0\" data-kid=\"20\">\n      <div class=\"border-t border-(--color-hairline) pt-6\" data-kid=\"21\">\n        <div class=\"flex items-center gap-3 mb-6\" data-kid=\"22\">\n          <img src=\"https://i.pravatar.cc/150?u=admin\" class=\"w-9 h-9 border border-(--color-hairline) rounded-full\" alt=\"Admin\" decoding=\"async\" loading=\"lazy\" data-kid=\"23\">\n          <div data-kid=\"24\">\n            <p class=\"text-sm font-medium text-(--color-foreground)\" data-kid=\"25\">BS. Alex Miller</p>\n            <p class=\"text-[11px] text-(--color-on-surface-tertiary) uppercase font-mono\" data-kid=\"26\">Quản trị viên</p>\n          </div>\n        </div>\n      </div>\n    </div>\n  </aside>\n\n  <div class=\"flex-1 ml-64 flex flex-col min-h-screen bg-white\" data-kid=\"27\">\n    \n    <header class=\"sticky top-0 z-40 bg-white/90 backdrop-blur-md border-b border-(--color-hairline) px-8 py-4 flex items-center justify-between\" data-kid=\"28\">\n      <div class=\"relative w-96\" data-kid=\"29\">\n        <i data-lucide=\"search\" class=\"absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-(--color-on-surface-tertiary)\" data-kid=\"30\"></i>\n        <input type=\"text\" placeholder=\"Tìm kiếm nhân viên, bệnh nhân...\" class=\"w-full bg-(--color-surface-secondary) border-transparent focus:border-(--color-primary) focus:bg-white outline-none rounded-full py-2 pl-11 pr-4 text-sm transition-all h-10\" data-kid=\"31\">\n      </div>\n      <div class=\"flex items-center gap-6\" data-kid=\"32\">\n        <div class=\"flex items-center gap-2 bg-(--color-surface-secondary) rounded-full px-4 py-1.5 border border-(--color-hairline)\" data-kid=\"33\">\n          <div class=\"w-2 h-2 rounded-full bg-(--color-primary) animate-pulse\" data-kid=\"34\"></div>\n          <span class=\"text-xs font-medium text-(--color-muted-foreground)\" data-kid=\"35\">Hệ thống ổn định</span>\n        </div>\n        <i data-lucide=\"bell\" class=\"w-5 h-5 text-(--color-muted-foreground) cursor-pointer hover:text-(--color-foreground) transition-colors\" data-kid=\"36\"></i>\n        <div class=\"h-8 w-px bg-(--color-hairline)\" data-kid=\"37\"></div>\n        <button class=\"rounded-full bg-(--color-action) text-white hover:bg-(--color-action)/90 px-6 py-2 text-sm font-medium\" data-kid=\"38\">Đăng xuất</button>\n      </div>\n    </header>\n\n    <main class=\"flex-1 p-10 max-w-(--breakpoint-2xl) mx-auto w-full\" data-kid=\"39\">\n      <div class=\"flex justify-between items-end mb-10\" data-kid=\"40\">\n        <div data-kid=\"41\">\n          <span class=\"eyebrow mb-2 block\" data-kid=\"42\">Quản lý nhân sự</span>\n          <h1 class=\"text-4xl font-semibold tight-tracking text-(--color-foreground) leading-tight\" data-kid=\"43\">Danh sách Nhân viên</h1>\n          <p class=\"text-(--color-muted-foreground) mt-2\" data-kid=\"44\">Điều phối và quản lý đội ngũ y tá, bác sĩ chuyên khoa.</p>\n        </div>\n        <div class=\"flex gap-3\" data-kid=\"45\">\n          <button class=\"bg-(--color-surface-secondary) text-(--color-foreground) border border-(--color-hairline) rounded-full px-5 h-10 text-sm font-medium hover:bg-(--color-hairline) transition-colors flex items-center gap-2\" data-kid=\"46\">\n            <i data-lucide=\"download\" class=\"w-4 h-4\" data-kid=\"47\"></i> Xuất báo cáo\n          </button>\n        </div>\n      </div>\n\n      <div class=\"grid grid-cols-10 gap-10\" data-kid=\"48\">\n        \n        <div class=\"col-span-7 space-y-6\" data-kid=\"49\">\n          <div class=\"grid grid-cols-2 gap-6\" data-kid=\"50\">\n            \n            <div class=\"group border border-(--color-hairline) rounded-3xl p-6 bg-white hover:border-(--color-primary) transition-all cursor-pointer relative overflow-hidden\" data-kid=\"51\">\n              <div class=\"flex items-start justify-between relative z-10\" data-kid=\"52\">\n                <div class=\"flex items-center gap-4\" data-kid=\"53\">\n                  <div class=\"relative\" data-kid=\"54\">\n                    <img src=\"https://i.pravatar.cc/150?u=sandra\" class=\"w-16 h-16 rounded-2xl border border-(--color-hairline) object-cover\" alt=\"Sandra Bullock\" decoding=\"async\" loading=\"lazy\" data-kid=\"55\">\n                    <div class=\"absolute -bottom-1 -right-1 w-4 h-4 border-2 border-white rounded-full bg-(--color-primary)\" data-kid=\"56\"></div>\n                  </div>\n                  <div data-kid=\"57\">\n                    <h3 class=\"font-bold text-lg text-(--color-foreground) group-hover:text-(--color-primary-strong) transition-colors\" data-kid=\"58\">Sandra Bullock</h3>\n                    <div class=\"flex items-center gap-2 mt-1\" data-kid=\"59\">\n                      <span class=\"bg-(--color-surface-tinted) text-(--color-primary-strong) text-[10px] font-bold px-2 py-0.5 rounded-full uppercase tracking-wider\" data-kid=\"60\">Y tá • Vết thương</span>\n                    </div>\n                  </div>\n                </div>\n                <button class=\"text-(--color-on-surface-tertiary) hover:text-(--color-foreground) transition-colors\" data-kid=\"61\">\n                  <i data-lucide=\"more-horizontal\" class=\"w-5 h-5\" data-kid=\"62\"></i>\n                </button>\n              </div>\n              <div class=\"mt-8 flex items-center justify-between border-t border-(--color-hairline)/50 pt-5\" data-kid=\"63\">\n                <div class=\"flex items-center gap-2 text-sm text-(--color-muted-foreground)\" data-kid=\"64\">\n                  <i data-lucide=\"map-pin\" class=\"w-4 h-4\" data-kid=\"65\"></i> Quận Queens\n                </div>\n                <span class=\"text-xs font-semibold text-(--color-primary-strong)\" data-kid=\"66\">Sẵn sàng</span>\n              </div>\n            </div>\n\n            \n            <div class=\"group border border-(--color-hairline) rounded-3xl p-6 bg-white hover:border-(--color-primary) transition-all cursor-pointer relative overflow-hidden\" data-kid=\"67\">\n              <div class=\"flex items-start justify-between relative z-10\" data-kid=\"68\">\n                <div class=\"flex items-center gap-4\" data-kid=\"69\">\n                  <div class=\"relative\" data-kid=\"70\">\n                    <img src=\"https://i.pravatar.cc/150?u=marcus\" class=\"w-16 h-16 rounded-2xl border border-(--color-hairline) object-cover\" alt=\"Marcus Thorne\" decoding=\"async\" loading=\"lazy\" data-kid=\"71\">\n                    <div class=\"absolute -bottom-1 -right-1 w-4 h-4 border-2 border-white rounded-full bg-orange-500\" data-kid=\"72\"></div>\n                  </div>\n                  <div data-kid=\"73\">\n                    <h3 class=\"font-bold text-lg text-(--color-foreground) group-hover:text-(--color-primary-strong) transition-colors\" data-kid=\"74\">Marcus Thorne</h3>\n                    <div class=\"flex items-center gap-2 mt-1\" data-kid=\"75\">\n                      <span class=\"bg-orange-50 text-orange-600 text-[10px] font-bold px-2 py-0.5 rounded-full uppercase tracking-wider\" data-kid=\"76\">VLTL • Phục hồi</span>\n                    </div>\n                  </div>\n                </div>\n                <button class=\"text-(--color-on-surface-tertiary) hover:text-(--color-foreground) transition-colors\" data-kid=\"77\">\n                  <i data-lucide=\"more-horizontal\" class=\"w-5 h-5\" data-kid=\"78\"></i>\n                </button>\n              </div>\n              <div class=\"mt-8 flex items-center justify-between border-t border-(--color-hairline)/50 pt-5\" data-kid=\"79\">\n                <div class=\"flex items-center gap-2 text-sm text-(--color-muted-foreground)\" data-kid=\"80\">\n                  <i data-lucide=\"clock\" class=\"w-4 h-4\" data-kid=\"81\"></i> Kết thúc trong 12p\n                </div>\n                <span class=\"text-xs font-semibold text-orange-600\" data-kid=\"82\">Đang bận</span>\n              </div>\n            </div>\n\n            \n            <div class=\"group border border-(--color-hairline) rounded-3xl p-6 bg-white hover:border-(--color-primary) transition-all cursor-pointer relative overflow-hidden\" data-kid=\"83\">\n              <div class=\"flex items-start justify-between relative z-10\" data-kid=\"84\">\n                <div class=\"flex items-center gap-4\" data-kid=\"85\">\n                  <div class=\"relative\" data-kid=\"86\">\n                    <img src=\"https://i.pravatar.cc/150?u=lara\" class=\"w-16 h-16 rounded-2xl border border-(--color-hairline) object-cover\" alt=\"Lara Croft\" decoding=\"async\" loading=\"lazy\" data-kid=\"87\">\n                    <div class=\"absolute -bottom-1 -right-1 w-4 h-4 border-2 border-white rounded-full bg-(--color-primary)\" data-kid=\"88\"></div>\n                  </div>\n                  <div data-kid=\"89\">\n                    <h3 class=\"font-bold text-lg text-(--color-foreground) group-hover:text-(--color-primary-strong) transition-colors\" data-kid=\"90\">Lara Croft</h3>\n                    <div class=\"flex items-center gap-2 mt-1\" data-kid=\"91\">\n                      <span class=\"bg-(--color-surface-tinted) text-(--color-primary-strong) text-[10px] font-bold px-2 py-0.5 rounded-full uppercase tracking-wider\" data-kid=\"92\">Y tá • Truyền dịch</span>\n                    </div>\n                  </div>\n                </div>\n                <button class=\"text-(--color-on-surface-tertiary) hover:text-(--color-foreground) transition-colors\" data-kid=\"93\">\n                  <i data-lucide=\"more-horizontal\" class=\"w-5 h-5\" data-kid=\"94\"></i>\n                </button>\n              </div>\n              <div class=\"mt-8 flex items-center justify-between border-t border-(--color-hairline)/50 pt-5\" data-kid=\"95\">\n                <div class=\"flex items-center gap-2 text-sm text-(--color-muted-foreground)\" data-kid=\"96\">\n                  <i data-lucide=\"map-pin\" class=\"w-4 h-4\" data-kid=\"97\"></i> Brooklyn\n                </div>\n                <span class=\"text-xs font-semibold text-(--color-primary-strong)\" data-kid=\"98\">Sẵn sàng</span>\n              </div>\n            </div>\n\n            \n            <div class=\"group border border-(--color-hairline) rounded-3xl p-6 bg-white hover:border-(--color-primary) transition-all cursor-pointer relative overflow-hidden\" data-kid=\"99\">\n              <div class=\"flex items-start justify-between relative z-10\" data-kid=\"100\">\n                <div class=\"flex items-center gap-4\" data-kid=\"101\">\n                  <div class=\"relative\" data-kid=\"102\">\n                    <img src=\"https://i.pravatar.cc/150?u=peter\" class=\"w-16 h-16 rounded-2xl border border-(--color-hairline) object-cover\" alt=\"Peter Parker\" decoding=\"async\" loading=\"lazy\" data-kid=\"103\">\n                    <div class=\"absolute -bottom-1 -right-1 w-4 h-4 border-2 border-white rounded-full bg-(--color-primary)\" data-kid=\"104\"></div>\n                  </div>\n                  <div data-kid=\"105\">\n                    <h3 class=\"font-bold text-lg text-(--color-foreground) group-hover:text-(--color-primary-strong) transition-colors\" data-kid=\"106\">Peter Parker</h3>\n                    <div class=\"flex items-center gap-2 mt-1\" data-kid=\"107\">\n                      <span class=\"bg-(--color-surface-tinted) text-(--color-primary-strong) text-[10px] font-bold px-2 py-0.5 rounded-full uppercase tracking-wider\" data-kid=\"108\">Chuyên gia Dinh dưỡng</span>\n                    </div>\n                  </div>\n                </div>\n                <button class=\"text-(--color-on-surface-tertiary) hover:text-(--color-foreground) transition-colors\" data-kid=\"109\">\n                  <i data-lucide=\"more-horizontal\" class=\"w-5 h-5\" data-kid=\"110\"></i>\n                </button>\n              </div>\n              <div class=\"mt-8 flex items-center justify-between border-t border-(--color-hairline)/50 pt-5\" data-kid=\"111\">\n                <div class=\"flex items-center gap-2 text-sm text-(--color-muted-foreground)\" data-kid=\"112\">\n                  <i data-lucide=\"map-pin\" class=\"w-4 h-4\" data-kid=\"113\"></i> Manhattan\n                </div>\n                <span class=\"text-xs font-semibold text-(--color-primary-strong)\" data-kid=\"114\">Sẵn sàng</span>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"col-span-3\" data-kid=\"115\">\n          <div class=\"bg-(--color-surface-tinted) rounded-3xl p-8 sticky top-28 border border-(--color-primary)/10\" data-kid=\"116\">\n            <h2 class=\"text-xl font-bold tight-tracking mb-6 flex items-center gap-2 text-(--color-action)\" data-kid=\"117\">\n              <i data-lucide=\"user-plus\" class=\"w-5 h-5 text-(--color-primary)\" data-kid=\"118\"></i> Thêm nhân viên mới\n            </h2>\n            \n            <form class=\"space-y-5\" data-kid=\"119\">\n              <div class=\"space-y-2\" data-kid=\"120\">\n                <label class=\"text-sm font-semibold text-(--color-muted-foreground)\" data-kid=\"121\">Họ tên</label>\n                <input type=\"text\" placeholder=\"VD: Nguyễn Văn A\" class=\"w-full bg-white border border-(--color-hairline) focus:border-(--color-primary) outline-none rounded-xl px-4 py-3 text-sm transition-all h-12 shadow-sm\" data-kid=\"122\">\n              </div>\n              \n              <div class=\"space-y-2\" data-kid=\"123\">\n                <label class=\"text-sm font-semibold text-(--color-muted-foreground)\" data-kid=\"124\">Chức vụ</label>\n                <div class=\"relative\" data-kid=\"125\">\n                  <select class=\"w-full bg-white border border-(--color-hairline) focus:border-(--color-primary) outline-none rounded-xl px-4 py-3 text-sm transition-all h-12 shadow-sm appearance-none\" data-kid=\"126\">\n                    <option data-kid=\"127\">Chọn chức vụ</option>\n                    <option data-kid=\"128\">Bác sĩ Chuyên khoa</option>\n                    <option data-kid=\"129\">Y tá Điều dưỡng</option>\n                    <option data-kid=\"130\">Chuyên gia VLTL</option>\n                    <option data-kid=\"131\">Chuyên gia Dinh dưỡng</option>\n                  </select>\n                  <i data-lucide=\"chevron-down\" class=\"absolute right-4 top-1/2 -translate-y-1/2 w-4 h-4 text-(--color-on-surface-tertiary) pointer-events-none\" data-kid=\"132\"></i>\n                </div>\n              </div>\n\n              <div class=\"space-y-2\" data-kid=\"133\">\n                <label class=\"text-sm font-semibold text-(--color-muted-foreground)\" data-kid=\"134\">Phòng ban</label>\n                <div class=\"relative\" data-kid=\"135\">\n                  <select class=\"w-full bg-white border border-(--color-hairline) focus:border-(--color-primary) outline-none rounded-xl px-4 py-3 text-sm transition-all h-12 shadow-sm appearance-none\" data-kid=\"136\">\n                    <option data-kid=\"137\">Chọn phòng ban</option>\n                    <option data-kid=\"138\">Nội khoa</option>\n                    <option data-kid=\"139\">Ngoại khoa</option>\n                    <option data-kid=\"140\">Phục hồi chức năng</option>\n                    <option data-kid=\"141\">Cấp cứu tại gia</option>\n                  </select>\n                  <i data-lucide=\"chevron-down\" class=\"absolute right-4 top-1/2 -translate-y-1/2 w-4 h-4 text-(--color-on-surface-tertiary) pointer-events-none\" data-kid=\"142\"></i>\n                </div>\n              </div>\n\n              <div class=\"space-y-2\" data-kid=\"143\">\n                <label class=\"text-sm font-semibold text-(--color-muted-foreground)\" data-kid=\"144\">Số điện thoại</label>\n                <input type=\"tel\" placeholder=\"090 123 4567\" class=\"w-full bg-white border border-(--color-hairline) focus:border-(--color-primary) outline-none rounded-xl px-4 py-3 text-sm transition-all h-12 shadow-sm\" data-kid=\"145\">\n              </div>\n\n              <div class=\"pt-4\" data-kid=\"146\">\n                <button type=\"submit\" class=\"w-full bg-(--color-action) text-white rounded-full py-4 font-bold text-sm hover:opacity-90 transition-opacity shadow-lg shadow-(--color-action)/10\" data-kid=\"147\">\n                  Tạo hồ sơ nhân viên\n                </button>\n              </div>\n            </form>\n\n            <div class=\"mt-8 p-4 bg-white/50 border border-white rounded-2xl\" data-kid=\"148\">\n              <div class=\"flex items-center gap-3\" data-kid=\"149\">\n                <div class=\"w-10 h-10 bg-white rounded-xl flex items-center justify-center text-(--color-primary) shadow-sm\" data-kid=\"150\">\n                  <i data-lucide=\"info\" class=\"w-5 h-5\" data-kid=\"151\"></i>\n                </div>\n                <div data-kid=\"152\">\n                  <p class=\"text-[11px] font-bold text-(--color-primary-strong) uppercase\" data-kid=\"153\">Ghi chú</p>\n                  <p class=\"text-[11px] text-(--color-muted-foreground)\" data-kid=\"154\">Mật khẩu mặc định sẽ được gửi qua email nhân viên.</p>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </main>\n  </div>\n</div>\n\n<script src=\"https://unpkg.com/lucide@latest\" data-kid=\"155\"></script>\n<script data-kid=\"156\">\n  lucide.createIcons();\n</script>",
