      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap');\n\n  :root {\n    --color-primary: #18BE66;\n    --color-primary-strong: #16A34A;\n    --color-action: #18181B;\n    --color-surface: #FFFFFF;\n    --color-surface-secondary: #F5F6F7;\n    --color-surface-tinted: #ECFBF2;\n    --color-hairline: #E4E4E7;\n    --color-background: var(--color-surface);\n    --color-foreground: #0A0A0A;\n    --color-muted-foreground: #52525B;\n    --color-on-surface-tertiary: #A1A1AA;\n  }\n\n  .font-sans { font-family: 'Inter', sans-serif; }\n  .font-heading { font-family: 'Plus Jakarta Sans', sans-serif; }\n  .font-mono { font-family: 'JetBrains Mono', monospace; }\n\n  .tight-tracking { letter-spacing: -0.02em; }\n  .eyebrow { font-size: 11px; font-weight: 600; text-transform: uppercase; tracking: 0.05em; color: var(--color-primary-strong); font-family: 'JetBrains Mono', monospace; }\n\n  /* Custom scrollbar */\n  ::-webkit-scrollbar { width: 6px; }\n  ::-webkit-scrollbar-track { background: transparent; }\n  ::-webkit-scrollbar-thumb { background: var(--color-hairline); border-radius: 10px; }\n  ::-webkit-scrollbar-thumb:hover { background: var(--color-on-surface-tertiary); }\n</style>\n\n<div class=\"flex min-h-screen bg-white font-sans text-foreground\" data-kid=\"1\">\n  \n  <aside class=\"w-64 border-r border-(--color-hairline) fixed h-full bg-white flex flex-col z-50\" data-kid=\"2\">\n    <div class=\"p-8 pb-4\" data-kid=\"3\">\n      <div class=\"flex items-center gap-2 mb-10\" data-kid=\"4\">\n        <div class=\"w-8 h-8 bg-(--color-primary) rounded-lg flex items-center justify-center\" data-kid=\"5\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"white\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"w-5 h-5\" data-kid=\"6\">\n            <path d=\"M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5\" data-kid=\"7\"></path>\n          </svg>\n        </div>\n        <span class=\"text-xl font-bold tight-tracking font-heading\" data-kid=\"8\">MintCare</span>\n      </div>\n\n      <nav class=\"space-y-1\" data-kid=\"9\">\n        <a href=\"#\" class=\"flex items-center gap-3 px-3 py-2 rounded-full font-medium text-sm text-(--color-muted-foreground) hover:bg-(--color-surface-secondary) transition-colors\" data-kid=\"10\">\n          <i class=\"ti ti-layout-grid w-4 h-4\" data-kid=\"11\"></i>\n          Tổng quan\n        </a>\n        <a href=\"#\" class=\"flex items-center gap-3 px-3 py-2 rounded-full font-medium text-sm text-(--color-muted-foreground) hover:bg-(--color-surface-secondary) transition-colors\" data-kid=\"12\">\n          <i class=\"ti ti-users w-4 h-4\" data-kid=\"13\"></i>\n          Nhân viên\n        </a>\n        <a href=\"#\" class=\"flex items-center gap-3 px-3 py-2 rounded-full font-medium text-sm text-(--color-muted-foreground) hover:bg-(--color-surface-secondary) transition-colors\" data-kid=\"14\">\n          <i class=\"ti ti-calendar w-4 h-4\" data-kid=\"15\"></i>\n          Lịch trực\n        </a>\n        <a href=\"#\" class=\"flex items-center gap-3 px-3 py-2 rounded-full font-medium text-sm bg-(--color-surface-secondary) text-foreground transition-colors\" data-kid=\"16\">\n          <i class=\"ti ti-activity w-4 h-4 text-(--color-primary)\" data-kid=\"17\"></i>\n          Bệnh nhân\n        </a>\n        <a href=\"#\" class=\"flex items-center gap-3 px-3 py-2 rounded-full font-medium text-sm text-(--color-muted-foreground) hover:bg-(--color-surface-secondary) transition-colors\" data-kid=\"18\">\n          <i class=\"ti ti-file-text w-4 h-4\" data-kid=\"19\"></i>\n          Báo cáo\n        </a>\n      </nav>\n    </div>\n\n    <div class=\"mt-auto p-8 pt-0\" data-kid=\"20\">\n      <div class=\"border-t border-(--color-hairline) pt-6\" data-kid=\"21\">\n        <div class=\"flex items-center gap-3 mb-6\" data-kid=\"22\">\n          <div class=\"w-9 h-9 rounded-full border border-(--color-hairline) bg-(--color-surface-secondary) flex items-center justify-center overflow-hidden\" data-kid=\"23\">\n            <img src=\"https://i.pravatar.cc/150?u=admin\" alt=\"Admin\" class=\"w-full h-full object-cover\" loading=\"lazy\" decoding=\"async\" data-kid=\"24\">\n          </div>\n          <div data-kid=\"25\">\n            <p class=\"text-sm font-semibold text-foreground\" data-kid=\"26\">BS. Alex Miller</p>\n            <p class=\"text-[10px] text-(--color-on-surface-tertiary) uppercase font-mono tracking-wider\" data-kid=\"27\">Quản trị viên</p>\n          </div>\n        </div>\n        <a href=\"#\" class=\"flex items-center gap-3 px-3 py-2 text-(--color-muted-foreground) hover:bg-(--color-surface-secondary) rounded-full font-medium text-sm transition-colors\" data-kid=\"28\">\n          <i class=\"ti ti-settings w-4 h-4\" data-kid=\"29\"></i>\n          Cài đặt\n        </a>\n      </div>\n    </div>\n  </aside>\n\n  \n  <div class=\"flex-1 ml-64 flex flex-col min-h-screen\" data-kid=\"30\">\n    \n    <header class=\"sticky top-0 z-40 bg-white/90 backdrop-blur-md border-b border-(--color-hairline) px-10 py-4 flex items-center justify-between\" data-kid=\"31\">\n      <div class=\"relative w-96\" data-kid=\"32\">\n        <i class=\"ti ti-search absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-(--color-on-surface-tertiary)\" data-kid=\"33\"></i>\n        <input type=\"text\" placeholder=\"Tìm kiếm bệnh nhân, bệnh lý...\" class=\"w-full bg-(--color-surface-secondary) border-transparent focus:bg-white focus:ring-2 focus:ring-(--color-primary)/20 outline-none rounded-full py-2.5 pl-11 pr-4 text-sm transition-all h-11\" data-kid=\"34\">\n      </div>\n      <div class=\"flex items-center gap-6\" data-kid=\"35\">\n        <div class=\"flex items-center gap-2 bg-(--color-surface-secondary) rounded-full px-4 py-1.5 border border-(--color-hairline)\" data-kid=\"36\">\n          <div class=\"w-2 h-2 rounded-full bg-(--color-primary) animate-pulse\" data-kid=\"37\"></div>\n          <span class=\"text-xs font-medium text-(--color-muted-foreground)\" data-kid=\"38\">Hệ thống ổn định</span>\n        </div>\n        <div class=\"relative p-2 hover:bg-(--color-surface-secondary) rounded-full transition-colors cursor-pointer\" data-kid=\"39\">\n          <i class=\"ti ti-bell w-5 h-5 text-(--color-muted-foreground)\" data-kid=\"40\"></i>\n          <span class=\"absolute top-2 right-2 w-2 h-2 bg-(--color-primary) rounded-full border-2 border-white\" data-kid=\"41\"></span>\n        </div>\n        <div class=\"h-8 w-px bg-(--color-hairline)\" data-kid=\"42\"></div>\n        <button class=\"bg-(--color-action) text-white font-semibold text-sm px-6 py-2.5 rounded-full hover:opacity-90 transition-opacity\" data-kid=\"43\">\n          Đăng xuất\n        </button>\n      </div>\n    </header>\n\n    \n    <main class=\"flex-1 p-10 max-w-7xl mx-auto w-full\" data-kid=\"44\">\n      \n      <div class=\"flex justify-between items-end mb-10\" data-kid=\"45\">\n        <div data-kid=\"46\">\n          <span class=\"eyebrow mb-2 block\" data-kid=\"47\">Dữ liệu lâm sàng</span>\n          <h1 class=\"text-4xl font-bold tight-tracking text-foreground font-heading\" data-kid=\"48\">Danh sách bệnh nhân</h1>\n          <p class=\"text-(--color-muted-foreground) mt-2\" data-kid=\"49\">Quản lý và theo dõi hồ sơ y tế của toàn bộ bệnh nhân.</p>\n        </div>\n        <button class=\"bg-(--color-primary) text-white rounded-full px-6 py-3 font-semibold text-sm flex items-center gap-2 hover:bg-(--color-primary-strong) transition-all shadow-sm hover:shadow-md\" data-kid=\"50\">\n          <i class=\"ti ti-plus w-4 h-4\" data-kid=\"51\"></i>\n          Thêm bệnh nhân\n        </button>\n      </div>\n\n      \n      <div class=\"bg-white border border-(--color-hairline) rounded-3xl overflow-hidden shadow-xs\" data-kid=\"52\">\n        <div class=\"overflow-x-auto\" data-kid=\"53\">\n          <table class=\"w-full text-left border-collapse\" data-kid=\"54\">\n            <thead data-kid=\"55\">\n              <tr class=\"bg-(--color-surface-secondary)/50 border-b border-(--color-hairline)\" data-kid=\"56\">\n                <th class=\"px-8 py-5 text-[11px] font-bold text-(--color-on-surface-tertiary) uppercase tracking-widest\" data-kid=\"57\">Mã BN</th>\n                <th class=\"px-8 py-5 text-[11px] font-bold text-(--color-on-surface-tertiary) uppercase tracking-widest\" data-kid=\"58\">Họ và tên</th>\n                <th class=\"px-8 py-5 text-[11px] font-bold text-(--color-on-surface-tertiary) uppercase tracking-widest\" data-kid=\"59\">Lần khám cuối</th>\n                <th class=\"px-8 py-5 text-[11px] font-bold text-(--color-on-surface-tertiary) uppercase tracking-widest\" data-kid=\"60\">Trạng thái</th>\n                <th class=\"px-8 py-5 text-[11px] font-bold text-(--color-on-surface-tertiary) uppercase tracking-widest text-right\" data-kid=\"61\">Thao tác</th>\n              </tr>\n            </thead>\n            <tbody class=\"divide-y divide-(--color-hairline)\" data-kid=\"62\">\n              \n              <tr class=\"group hover:bg-(--color-surface-secondary)/30 transition-colors cursor-pointer bg-(--color-surface-tinted)/20\" data-kid=\"63\">\n                <td class=\"px-8 py-6 font-mono text-xs text-(--color-on-surface-tertiary)\" data-kid=\"64\">#BN-0842</td>\n                <td class=\"px-8 py-6\" data-kid=\"65\">\n                  <div class=\"flex items-center gap-3\" data-kid=\"66\">\n                    <div class=\"w-10 h-10 rounded-xl bg-(--color-surface-secondary) flex items-center justify-center font-bold text-(--color-primary) text-sm\" data-kid=\"67\">EG</div>\n                    <div data-kid=\"68\">\n                      <p class=\"font-semibold text-sm\" data-kid=\"69\">Evelyn Green</p>\n                      <p class=\"text-xs text-(--color-muted-foreground)\" data-kid=\"70\">Nữ • 64 tuổi</p>\n                    </div>\n                  </div>\n                </td>\n                <td class=\"px-8 py-6\" data-kid=\"71\">\n                  <p class=\"text-sm font-medium\" data-kid=\"72\">12/06/2024</p>\n                  <p class=\"text-[10px] text-(--color-on-surface-tertiary) font-mono\" data-kid=\"73\">09:15 AM</p>\n                </td>\n                <td class=\"px-8 py-6\" data-kid=\"74\">\n                  <span class=\"inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-bold bg-(--color-surface-tinted) text-(--color-primary-strong) uppercase tracking-wider\" data-kid=\"75\">\n                    <span class=\"w-1.5 h-1.5 rounded-full bg-(--color-primary)\" data-kid=\"76\"></span>\n                    Đang điều trị\n                  </span>\n                </td>\n                <td class=\"px-8 py-6 text-right\" data-kid=\"77\">\n                  <button class=\"p-2 hover:bg-(--color-surface-secondary) rounded-lg transition-colors text-(--color-on-surface-tertiary) hover:text-(--color-action)\" data-kid=\"78\">\n                    <i class=\"ti ti-dots-vertical w-5 h-5\" data-kid=\"79\"></i>\n                  </button>\n                </td>\n              </tr>\n              \n              <tr class=\"bg-(--color-surface-tinted)/10\" data-kid=\"80\">\n                <td colspan=\"5\" class=\"px-8 py-0\" data-kid=\"81\">\n                  <div class=\"py-8 border-t border-(--color-primary)/10 animate-in fade-in slide-in-from-top-2 duration-300\" data-kid=\"82\">\n                    <div class=\"grid grid-cols-1 md:grid-cols-3 gap-10\" data-kid=\"83\">\n                      <div class=\"space-y-4\" data-kid=\"84\">\n                        <div class=\"flex items-center gap-2\" data-kid=\"85\">\n                          <i class=\"ti ti-clipboard-text text-(--color-primary) w-4 h-4\" data-kid=\"86\"></i>\n                          <h4 class=\"text-xs font-bold uppercase tracking-wider text-(--color-on-surface-tertiary)\" data-kid=\"87\">Tóm tắt bệnh lý</h4>\n                        </div>\n                        <p class=\"text-sm text-(--color-muted-foreground) leading-relaxed bg-white p-4 rounded-2xl border border-(--color-hairline)\" data-kid=\"88\">\n                          Bệnh nhân có tiền sử cao huyết áp và tiểu đường type 2. Hiện đang trong lộ trình phục hồi sau phẫu thuật thay khớp gối trái. Cần theo dõi sát chỉ số đường huyết và thực hiện bài tập VLTL 3 lần/tuần.\n                        </p>\n                      </div>\n                      <div class=\"space-y-4\" data-kid=\"89\">\n                        <div class=\"flex items-center gap-2\" data-kid=\"90\">\n                          <i class=\"ti ti-stethoscope text-(--color-primary) w-4 h-4\" data-kid=\"91\"></i>\n                          <h4 class=\"text-xs font-bold uppercase tracking-wider text-(--color-on-surface-tertiary)\" data-kid=\"92\">Đội ngũ phụ trách</h4>\n                        </div>\n                        <div class=\"space-y-3\" data-kid=\"93\">\n                          <div class=\"flex items-center gap-3 bg-white p-3 rounded-xl border border-(--color-hairline)\" data-kid=\"94\">\n                            <img src=\"https://i.pravatar.cc/150?u=sandra\" class=\"w-8 h-8 rounded-lg object-cover\" loading=\"lazy\" decoding=\"async\" data-kid=\"95\">\n                            <div data-kid=\"96\">\n                              <p class=\"text-xs font-semibold\" data-kid=\"97\">Sandra Bullock</p>\n                              <p class=\"text-[10px] text-(--color-muted-foreground)\" data-kid=\"98\">Y tá chính • Chăm sóc vết thương</p>\n                            </div>\n                          </div>\n                          <div class=\"flex items-center gap-3 bg-white p-3 rounded-xl border border-(--color-hairline)\" data-kid=\"99\">\n                            <img src=\"https://i.pravatar.cc/150?u=marcus\" class=\"w-8 h-8 rounded-lg object-cover\" loading=\"lazy\" decoding=\"async\" data-kid=\"100\">\n                            <div data-kid=\"101\">\n                              <p class=\"text-xs font-semibold\" data-kid=\"102\">Marcus Thorne</p>\n                              <p class=\"text-[10px] text-(--color-muted-foreground)\" data-kid=\"103\">Chuyên gia VLTL</p>\n                            </div>\n                          </div>\n                        </div>\n                      </div>\n                      <div class=\"space-y-4\" data-kid=\"104\">\n                        <div class=\"flex items-center justify-between\" data-kid=\"105\">\n                          <div class=\"flex items-center gap-2\" data-kid=\"106\">\n                            <i class=\"ti ti-history text-(--color-primary) w-4 h-4\" data-kid=\"107\"></i>\n                            <h4 class=\"text-xs font-bold uppercase tracking-wider text-(--color-on-surface-tertiary)\" data-kid=\"108\">Lịch sử thăm khám</h4>\n                          </div>\n                          <button class=\"text-(--color-primary-strong) text-[10px] font-bold hover:underline\" data-kid=\"109\">Xem tất cả</button>\n                        </div>\n                        <div class=\"space-y-3\" data-kid=\"110\">\n                          <div class=\"flex items-center justify-between text-xs py-2 border-b border-(--color-hairline)\" data-kid=\"111\">\n                            <span class=\"text-(--color-muted-foreground)\" data-kid=\"112\">Thay băng & Kiểm tra</span>\n                            <span class=\"font-mono text-(--color-on-surface-tertiary)\" data-kid=\"113\">12/06</span>\n                          </div>\n                          <div class=\"flex items-center justify-between text-xs py-2 border-b border-(--color-hairline)\" data-kid=\"114\">\n                            <span class=\"text-(--color-muted-foreground)\" data-kid=\"115\">Vật lý trị liệu</span>\n                            <span class=\"font-mono text-(--color-on-surface-tertiary)\" data-kid=\"116\">10/06</span>\n                          </div>\n                          <div class=\"flex items-center justify-between text-xs py-2\" data-kid=\"117\">\n                            <span class=\"text-(--color-muted-foreground)\" data-kid=\"118\">Kiểm tra tổng quát</span>\n                            <span class=\"font-mono text-(--color-on-surface-tertiary)\" data-kid=\"119\">05/06</span>\n                          </div>\n                        </div>\n                      </div>\n                    </div>\n                  </div>\n                </td>\n              </tr>\n\n              \n              <tr class=\"group hover:bg-(--color-surface-secondary)/30 transition-colors cursor-pointer\" data-kid=\"120\">\n                <td class=\"px-8 py-6 font-mono text-xs text-(--color-on-surface-tertiary)\" data-kid=\"121\">#BN-0721</td>\n                <td class=\"px-8 py-6\" data-kid=\"122\">\n                  <div class=\"flex items-center gap-3\" data-kid=\"123\">\n                    <div class=\"w-10 h-10 rounded-xl bg-(--color-surface-secondary) flex items-center justify-center font-bold text-(--color-primary) text-sm\" data-kid=\"124\">OW</div>\n                    <div data-kid=\"125\">\n                      <p class=\"font-semibold text-sm\" data-kid=\"126\">Oscar White</p>\n                      <p class=\"text-xs text-(--color-muted-foreground)\" data-kid=\"127\">Nam • 72 tuổi</p>\n                    </div>\n                  </div>\n                </td>\n                <td class=\"px-8 py-6\" data-kid=\"128\">\n                  <p class=\"text-sm font-medium\" data-kid=\"129\">11/06/2024</p>\n                  <p class=\"text-[10px] text-(--color-on-surface-tertiary) font-mono\" data-kid=\"130\">02:30 PM</p>\n                </td>\n                <td class=\"px-8 py-6\" data-kid=\"131\">\n                  <span class=\"inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-bold bg-(--color-surface-secondary) text-(--color-muted-foreground) uppercase tracking-wider border border-(--color-hairline)\" data-kid=\"132\">\n                    Chờ tái khám\n                  </span>\n                </td>\n                <td class=\"px-8 py-6 text-right\" data-kid=\"133\">\n                  <button class=\"p-2 hover:bg-(--color-surface-secondary) rounded-lg transition-colors text-(--color-on-surface-tertiary) hover:text-(--color-action)\" data-kid=\"134\">\n                    <i class=\"ti ti-dots-vertical w-5 h-5\" data-kid=\"135\"></i>\n                  </button>\n                </td>\n              </tr>\n\n              \n              <tr class=\"group hover:bg-(--color-surface-secondary)/30 transition-colors cursor-pointer\" data-kid=\"136\">\n                <td class=\"px-8 py-6 font-mono text-xs text-(--color-on-surface-tertiary)\" data-kid=\"137\">#BN-1052</td>\n                <td class=\"px-8 py-6\" data-kid=\"138\">\n                  <div class=\"flex items-center gap-3\" data-kid=\"139\">\n                    <div class=\"w-10 h-10 rounded-xl bg-(--color-surface-secondary) flex items-center justify-center font-bold text-(--color-primary) text-sm\" data-kid=\"140\">RT</div>\n                    <div data-kid=\"141\">\n                      <p class=\"font-semibold text-sm\" data-kid=\"142\">Rose Thorne</p>\n                      <p class=\"text-xs text-(--color-muted-foreground)\" data-kid=\"143\">Nữ • 45 tuổi</p>\n                    </div>\n                  </div>\n                </td>\n                <td class=\"px-8 py-6\" data-kid=\"144\">\n                  <p class=\"text-sm font-medium\" data-kid=\"145\">09/06/2024</p>\n                  <p class=\"text-[10px] text-(--color-on-surface-tertiary) font-mono\" data-kid=\"146\">10:00 AM</p>\n                </td>\n                <td class=\"px-8 py-6\" data-kid=\"147\">\n                  <span class=\"inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-bold bg-(--color-surface-tinted) text-(--color-primary-strong) uppercase tracking-wider\" data-kid=\"148\">\n                    <span class=\"w-1.5 h-1.5 rounded-full bg-(--color-primary)\" data-kid=\"149\"></span>\n                    Đang điều trị\n                  </span>\n                </td>\n                <td class=\"px-8 py-6 text-right\" data-kid=\"150\">\n                  <button class=\"p-2 hover:bg-(--color-surface-secondary) rounded-lg transition-colors text-(--color-on-surface-tertiary) hover:text-(--color-action)\" data-kid=\"151\">\n                    <i class=\"ti ti-dots-vertical w-5 h-5\" data-kid=\"152\"></i>\n                  </button>\n                </td>\n              </tr>\n            </tbody>\n          </table>\n        </div>\n        \n        \n        <div class=\"px-8 py-5 border-t border-(--color-hairline) flex items-center justify-between bg-(--color-surface-secondary)/20\" data-kid=\"153\">\n          <p class=\"text-xs text-(--color-muted-foreground)\" data-kid=\"154\">Hiển thị <span class=\"font-bold text-foreground\" data-kid=\"155\">1-10</span> trong số <span class=\"font-bold text-foreground\" data-kid=\"156\">840</span> bệnh nhân</p>\n          <div class=\"flex gap-2\" data-kid=\"157\">\n            <button class=\"p-2 border border-(--color-hairline) rounded-xl hover:bg-white transition-colors disabled:opacity-50\" disabled data-kid=\"158\">\n              <i class=\"ti ti-chevron-left w-4 h-4\" data-kid=\"159\"></i>\n            </button>\n            <button class=\"p-2 border border-(--color-hairline) rounded-xl hover:bg-white transition-colors\" data-kid=\"160\">\n              <i class=\"ti ti-chevron-right w-4 h-4\" data-kid=\"161\"></i>\n            </button>\n          </div>\n        </div>\n      </div>\n    </main>\n  </div>\n</div>\n\n\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" data-kid=\"162\">",
