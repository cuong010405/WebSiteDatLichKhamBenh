      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css');\n\n  :root {\n    --color-primary: #18BE66;\n    --color-primary-soft: #ECFBF2;\n    --color-primary-strong: #16A34A;\n    --color-action: #18181B;\n    --color-surface: #FFFFFF;\n    --color-surface-secondary: #F5F6F7;\n    --color-hairline: #E4E4E7;\n    --color-text: #0A0A0A;\n    --color-text-muted: #52525B;\n  }\n\n  body {\n    font-family: 'Plus Jakarta Sans', sans-serif;\n    background-color: var(--color-surface);\n    color: var(--color-text);\n    margin: 0;\n    overflow-x: clip;\n  }\n\n  .font-mono {\n    font-family: 'JetBrains Mono', monospace;\n  }\n\n  /* Sidebar Styles */\n  .sidebar-link {\n    display: flex;\n    align-items: center;\n    gap: 12px;\n    padding: 10px 16px;\n    border-radius: 9999px;\n    font-size: 14px;\n    font-weight: 500;\n    color: var(--color-text-muted);\n    transition: all 0.2s ease;\n  }\n\n  .sidebar-link:hover {\n    background-color: var(--color-surface-secondary);\n    color: var(--color-text);\n  }\n\n  .sidebar-link.active {\n    background-color: var(--color-surface-secondary);\n    color: var(--color-text);\n    font-weight: 600;\n  }\n\n  /* Staff Card Styles */\n  .staff-card {\n    background: white;\n    border: 1px solid var(--color-hairline);\n    border-radius: 32px;\n    display: flex;\n    flex-direction: column;\n    height: 780px;\n    position: relative;\n    box-shadow: 0 8px 32px -8px rgba(0,0,0,0.04);\n    transition: box-shadow 0.3s ease;\n  }\n\n  .staff-card:hover {\n    box-shadow: 0 12px 48px -12px rgba(0,0,0,0.08);\n  }\n\n  .timeline-scroll {\n    flex: 1;\n    position: relative;\n    overflow-y: auto;\n    padding-bottom: 40px;\n    scrollbar-width: thin;\n    scrollbar-color: var(--color-hairline) transparent;\n    background-image: linear-gradient(var(--color-surface-secondary) 1px, transparent 1px);\n    background-size: 100% 74px;\n  }\n\n  .time-row {\n    height: 74px; /* Base height for 1 hour */\n    border-top: 1px solid var(--color-hairline)/30;\n    padding-left: 20px;\n    display: flex;\n    align-items: flex-start;\n    padding-top: 10px;\n    position: relative;\n  }\n\n  .time-label {\n    font-size: 11px;\n    font-weight: 700;\n    color: #94A3B8;\n    font-family: 'JetBrains Mono', monospace;\n    width: 45px;\n    user-select: none;\n    z-index: 5;\n  }\n\n  .shift-card {\n    position: absolute;\n    left: 68px;\n    right: 12px;\n    border-radius: 16px;\n    padding: 12px;\n    font-size: 12px;\n    display: flex;\n    flex-direction: column;\n    justify-content: space-between;\n    /* Removed transform from transition to avoid GSAP conflict */\n    transition: box-shadow 0.3s ease;\n    cursor: pointer;\n    z-index: 10;\n    overflow: hidden;\n  }\n\n  .shift-card:hover {\n    box-shadow: 0 12px 28px -8px rgba(0,0,0,0.15);\n    z-index: 20;\n  }\n\n  .shift-confirmed {\n    border-left: 5px solid var(--color-primary);\n    background: var(--color-primary-soft);\n    color: var(--color-primary-strong);\n  }\n\n  .shift-pending {\n    border-left: 5px solid #94A3B8;\n    background: #F8FAFC;\n    color: #64748B;\n  }\n  \n  .shift-pending:hover {\n    box-shadow: 0 12px 28px -8px rgba(100, 116, 139, 0.15);\n  }\n\n  .shift-urgent {\n    border-left: 5px solid #EF4444;\n    background: #FFF5F5;\n    color: #C53030;\n  }\n  \n  .shift-urgent:hover {\n    box-shadow: 0 12px 28px -8px rgba(197, 48, 48, 0.15);\n  }\n\n  .eyebrow {\n    font-size: 11px;\n    font-weight: 600;\n    text-transform: uppercase;\n    letter-spacing: 0.1em;\n    color: var(--color-primary-strong);\n    font-family: 'JetBrains Mono', monospace;\n  }\n\n  /* Custom Scrollbar */\n  .timeline-scroll::-webkit-scrollbar {\n    width: 4px;\n  }\n  .timeline-scroll::-webkit-scrollbar-thumb {\n    background: var(--color-hairline);\n    border-radius: 4px;\n  }\n\n  .status-dot {\n    width: 8px;\n    height: 8px;\n    border-radius: 50%;\n  }\n\n  .animate-float {\n    animation: float 3s ease-in-out infinite;\n  }\n\n  @keyframes float {\n    0%, 100% { transform: translateY(0); }\n    50% { transform: translateY(-5px); }\n  }\n</style>\n\n<div class=\"flex min-h-screen\" data-kid=\"1\">\n  \n  <aside class=\"w-64 border-r border-hairline sticky top-0 h-screen bg-white flex flex-col z-50\" data-kid=\"2\">\n    <div class=\"p-8 pb-4\" data-kid=\"3\">\n      <div class=\"flex items-center gap-2 mb-10\" data-kid=\"4\">\n        <div class=\"w-10 h-10 bg-[var(--color-primary)] rounded-xl flex items-center justify-center shadow-lg shadow-green-200\" data-kid=\"5\">\n          <i class=\"ti ti-leaf text-white text-2xl\" data-kid=\"6\"></i>\n        </div>\n        <span class=\"text-xl font-bold tracking-tight\" data-kid=\"7\">MintCare</span>\n      </div>\n      <nav class=\"space-y-1.5\" data-kid=\"8\">\n        <a href=\"#\" class=\"sidebar-link\" data-kid=\"9\">\n          <i class=\"ti ti-layout-dashboard text-xl\" data-kid=\"10\"></i>\n          Overview\n        </a>\n        <a href=\"#\" class=\"sidebar-link\" data-kid=\"11\">\n          <i class=\"ti ti-users text-xl\" data-kid=\"12\"></i>\n          Staff Directory\n        </a>\n        <a href=\"#\" class=\"sidebar-link active\" data-kid=\"13\">\n          <i class=\"ti ti-calendar-event text-xl\" data-kid=\"14\"></i>\n          Schedule\n        </a>\n        <a href=\"#\" class=\"sidebar-link\" data-kid=\"15\">\n          <i class=\"ti ti-heart-rate-monitor text-xl\" data-kid=\"16\"></i>\n          Patients\n        </a>\n        <a href=\"#\" class=\"sidebar-link\" data-kid=\"17\">\n          <i class=\"ti ti-report-analytics text-xl\" data-kid=\"18\"></i>\n          Analytics\n        </a>\n        <a href=\"#\" class=\"sidebar-link\" data-kid=\"19\">\n          <i class=\"ti