      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@500;600&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  body {\n    font-family: 'Plus Jakarta Sans', sans-serif;\n    background-color: #F5F6F7;\n    margin: 0;\n  }\n\n  .font-mono {\n    font-family: 'JetBrains Mono', monospace;\n  }\n\n  .tight-tracking {\n    letter-spacing: -0.02em;\n  }\n\n  .eyebrow {\n    font-size: 11px;\n    font-weight: 600;\n    text-transform: uppercase;\n    letter-spacing: 0.04em;\n    color: #16A34A;\n    font-family: 'JetBrains Mono', monospace;\n  }\n\n  .card-gradient {\n    background: linear-gradient(135deg, #FFFFFF 0%, #F9FAFB 100%);\n  }\n\n  /* Custom Chart Styling */\n  .chart-container {\n    position: relative;\n    width: 100%;\n    height: 100%;\n  }\n</style>\n\n<div class=\"flex min-h-screen\" data-kid=\"1\">\n  \n  <aside class=\"w-64 border-r border-[#E4E4E7] fixed h-full bg-white flex flex-col z-50\" data-kid=\"2\">\n    <div class=\"p-8 pb-4\" data-kid=\"3\">\n      <div class=\"flex items-center gap-2 mb-10\" data-kid=\"4\">\n        <div class=\"w-8 h-8 bg-[#18BE66] rounded-lg flex items-center justify-center\" data-kid=\"5\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"white\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"w-5 h-5\" data-kid=\"6\">\n            <path d=\"M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5\" data-kid=\"7\"></path>\n          </svg>\n        </div>\n        <span class=\"text-xl font-semibold tight-tracking text-[#0A0A0A]\" data-kid=\"8\">MintCare</span>\n      </div>\n\n      <nav class=\"space-y-1\" data-kid=\"9\">\n        <a href=\"#\" class=\"flex items-center gap-3 px-3 py-2 rounded-full font-medium text-sm text-[#52525B] hover:bg-[#F5F6F7] transition-colors\" data-kid=\"10\">\n          <i class=\"ti ti-layout-grid w-4 h-4\" data-kid=\"11\"></i>\n          Tổng quan\n        </a>\n        <a href=\"#\" class=\"flex items-center gap-3 px-3 py-2 rounded-full font-medium text-sm text-[#52525B] hover:bg-[#F5F6F7] transition-colors\" data-kid=\"12\">\n          <i class=\"ti ti-users w-4 h-4\" data-kid=\"13\"></i>\n          Nhân viên\n        </a>\n        <a href=\"#\" class=\"flex items-center gap-3 px-3 py-2 rounded-full font-medium text-sm text-[#52525B] hover:bg-[#F5F6F7] transition-colors\" data-kid=\"14\">\n          <i class=\"ti ti-calendar w-4 h-4\" data-kid=\"15\"></i>\n          Lịch trực\n        </a>\n        <a href=\"#\" class=\"flex items-center gap-3 px-3 py-2 rounded-full font-medium text-sm text-[#52525B] hover:bg-[#F5F6F7] transition-colors\" data-kid=\"16\">\n          <i class=\"ti ti-activity w-4 h-4\" data-kid=\"17\"></i>\n          Bệnh nhân\n        </a>\n        <a href=\"#\" class=\"flex items-center gap-3 px-3 py-2 rounded-full font-medium text-sm bg-[#F5F6F7] text-[#0A0A0A] transition-colors\" data-kid=\"18\">\n          <i class=\"ti ti-file-text w-4 h-4\" data-kid=\"19\"></i>\n          Báo cáo\n        </a>\n      </nav>\n    </div>\n\n    <div class=\"mt-auto p-8 pt-0\" data-kid=\"20\">\n      <div class=\"border-t border-[#E4E4E7] pt-6\" data-kid=\"21\">\n        <div class=\"flex items-center gap-3 mb-6\" data-kid=\"22\">\n          <div class=\"w-9 h-9 border border-[#E4E4E7] rounded-full overflow-hidden\" data-kid=\"23\">\n            <img src=\"https://i.pravatar.cc/150?u=admin\" alt=\"Bác sĩ Alex Miller\" class=\"w-full h-full object-cover\" data-kid=\"24\">\n          </div>\n          <div data-kid=\"25\">\n            <p class=\"text-sm font-medium text-[#0A0A0A]\" data-kid=\"26\">BS. Alex Miller</p>\n            <p class=\"text-[11px] text-[#52525B] uppercase font-mono\" data-kid=\"27\">Quản trị viên</p>\n          </div>\n        </div>\n        <a href=\"#\" class=\"flex items-center gap-3 px-3 py-2 text-[#52525B] hover:bg-[#F5F6F7] rounded-full font-medium text-sm transition-colors\" data-kid=\"28\">\n          <i class=\"ti ti-settings w-4 h-4\" data-kid=\"29\"></i>\n          Cài đặt\n        </a>\n      </div>\n    </div>\n  </aside>\n\n  \n  <div class=\"flex-1 ml-64 flex flex-col min-h-screen bg-white\" data-kid=\"30\">\n    \n    <header class=\"sticky top-0 z-40 bg-white/90 backdrop-blur-md border-b border-[#E4E4E7] px-8 py-4 flex items-center justify-between\" data-kid=\"31\">\n      <div class=\"relative w-96\" data-kid=\"32\">\n        <i class=\"ti ti-search absolute left-4 top-1/2 -translate-y-1/2 text-[#52525B]\" data-kid=\"33\"></i>\n        <input type=\"text\" placeholder=\"Tìm kiếm báo cáo, dữ liệu...\" class=\"w-full bg-[#F5F6F7] border-transparent focus:border-[#18BE66] focus:bg-white outline-none rounded-full py-2 pl-11 pr-4 text-sm transition-all h-10 border\" data-kid=\"34\">\n      </div>\n      <div class=\"flex items-center gap-6\" data-kid=\"35\">\n        <div class=\"flex items-center gap-2 bg-[#F5F6F7] rounded-full px-4 py-1.5 border border-[#E4E4E7]\" data-kid=\"36\">\n          <div class=\"w-2 h-2 rounded-full bg-[#18BE66] animate-pulse\" data-kid=\"37\"></div>\n          <span class=\"text-xs font-medium text-[#52525B]\" data-kid=\"38\">Dữ liệu trực tuyến</span>\n        </div>\n        <div class=\"relative\" data-kid=\"39\">\n          <i class=\"ti ti-bell w-5 h-5 text-[#52525B] cursor-pointer hover:text-[#0A0A0A] transition-colors\" data-kid=\"40\"></i>\n          <span class=\"absolute -top-1 -right-1 w-2 h-2 bg-[#18BE66] rounded-full border-2 border-white\" data-kid=\"41\"></span>\n        </div>\n        <div class=\"h-8 w-px bg-[#E4E4E7]\" data-kid=\"42\"></div>\n        <button class=\"rounded-full bg-[#18181B] text-white hover:bg-[#18181B]/90 px-6 py-2 text-sm font-medium h-10 transition-colors\" data-kid=\"43\">\n          Xuất dữ liệu\n        </button>\n      </div>\n    </header>\n\n    \n    <main class=\"flex-1 p-10 max-w-7xl mx-auto w-full space-y-10\" data-kid=\"44\">\n      \n      <div class=\"flex justify-between items-end\" data-kid=\"45\">\n        <div data-kid=\"46\">\n          <span class=\"eyebrow mb-2 block\" data-kid=\"47\">Phân tích & Thống kê</span>\n          <h1 class=\"text-[40px] font-semibold tight-tracking text-[#0A0A0A] leading-tight\" data-kid=\"48\">Báo cáo Hoạt động</h1>\n          <p class=\"text-[#52525B] mt-2\" data-kid=\"49\">Dữ liệu tổng hợp từ 01/06/2024 đến hiện tại.</p>\n        </div>\n        <div class=\"flex items-center gap-3\" data-kid=\"50\">\n          <div class=\"bg-[#F5F6F7] p-1 rounded-xl flex gap-1 border border-[#E4E4E7]\" data-kid=\"51\">\n            <button class=\"px-4 py-1.5 text-xs font-semibold bg-white rounded-lg shadow-sm text-[#0A0A0A]\" data-kid=\"52\">Tuần</button>\n            <button class=\"px-4 py-1.5 text-xs font-semibold text-[#52525B] hover:text-[#0A0A0A] transition-colors\" data-kid=\"53\">Tháng</button>\n            <button class=\"px-4 py-1.5 text-xs font-semibold text-[#52525B] hover:text-[#0A0A0A] transition-colors\" data-kid=\"54\">Năm</button>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"grid grid-cols-12 grid-rows-2 gap-6 h-[720px]\" data-kid=\"55\">\n        \n        <div class=\"col-span-8 row-span-2 bg-white border border-[#E4E4E7] rounded-3xl p-8 flex flex-col shadow-xs hover:border-[#18BE66]/30 transition-all\" data-kid=\"56\">\n          <div class=\"flex items-center justify-between mb-8\" data-kid=\"57\">\n            <div data-kid=\"58\">\n              <span class=\"eyebrow text-[10px] mb-1 block\" data-kid=\"59\">Tăng trưởng</span>\n              <h2 class=\"text-xl font-semibold tight-tracking\" data-kid=\"60\">Xu hướng bệnh nhân nội trú</h2>\n            </div>\n            <div class=\"text-right\" data-kid=\"61\">\n              <span class=\"text-2xl font-semibold text-[#18BE66]\" data-kid=\"62\">+12.5%</span>\n              <p class=\"text-[10px] font-mono text-[#52525B] uppercase\" data-kid=\"63\">so với tháng trước</p>\n            </div>\n          </div>\n          <div class=\"flex-1 min-h-0\" data-kid=\"64\">\n            <canvas id=\"patientInflowChart\" data-kid=\"65\"></canvas>\n          </div>\n        </div>\n\n        \n        <div class=\"col-span-4 row-span-1 bg-white border border-[#E4E4E7] rounded-3xl p-8 flex flex-col shadow-xs hover:border-[#18BE66]/30 transition-all\" data-kid=\"66\">\n          <div class=\"flex items-center justify-between mb-4\" data-kid=\"67\">\n            <div data-kid=\"68\">\n              <span class=\"eyebrow text-[10px] mb-1 block\" data-kid=\"69\">Vận hành</span>\n              <h2 class=\"text-xl font-semibold tight-tracking\" data-kid=\"70\">Công suất giường</h2>\n            </div>\n            <i class=\"ti ti-chart-pie text-[#18BE66] text-2xl\" data-kid=\"71\"></i>\n          </div>\n          <div class=\"flex-1 flex items-center justify-center relative\" data-kid=\"72\">\n            <div style=\"width: 180px; height: 180px;\" data-kid=\"73\">\n              <canvas id=\"occupancyGauge\" data-kid=\"74\"></canvas>\n            </div>\n            <div class=\"absolute inset-0 flex flex-col items-center justify-center pt-8\" data-kid=\"75\">\n              <span class=\"text-3xl font-bold tight-tracking\" data-kid=\"76\">82%</span>\n              <span class=\"text-[10px] text-[#52525B] font-mono uppercase\" data-kid=\"77\">Đang sử dụng</span>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"col-span-4 row-span-1 bg-[#18181B] rounded-3xl p-8 flex flex-col shadow-lg\" data-kid=\"78\">\n          <div class=\"flex items-center justify-between mb-6\" data-kid=\"79\">\n            <div data-kid=\"80\">\n              <span class=\"eyebrow text-[10px] mb-1 block !text-[#18BE66]\" data-kid=\"81\">Năng suất</span>\n              <h2 class=\"text-xl font-semibold tight-tracking text-white\" data-kid=\"82\">Giờ làm việc</h2>\n            </div>\n            <i class=\"ti ti-clock text-[#18BE66] text-xl\" data-kid=\"83\"></i>\n          </div>\n          <div class=\"flex-1 min-h-0\" data-kid=\"84\">\n            <canvas id=\"staffHoursChart\" data-kid=\"85\"></canvas>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"grid grid-cols-3 gap-6\" data-kid=\"86\">\n        \n        <div class=\"bg-white border border-[#E4E4E7] rounded-3xl p-8 shadow-xs\" data-kid=\"87\">\n          <div class=\"flex items-center gap-2 mb-6\" data-kid=\"88\">\n            <div class=\"w-8 h-8 bg-[#ECFBF2] rounded-lg flex items-center justify-center text-[#18BE66]\" data-kid=\"89\">\n              <i class=\"ti ti-alert-circle\" data-kid=\"90\"></i>\n            </div>\n            <h3 class=\"font-semibold text-lg\" data-kid=\"91\">Ca trực quan trọng</h3>\n          </div>\n          <div class=\"space-y-4\" data-kid=\"92\">\n            <div class=\"p-4 bg-[#F5F6F7] rounded-2xl flex justify-between items-center group cursor-pointer hover:bg-[#ECFBF2] transition-colors\" data-kid=\"93\">\n              <div data-kid=\"94\">\n                <p class=\"text-sm font-semibold\" data-kid=\"95\">Phẫu thuật Hậu phẫu</p>\n                <p class=\"text-xs text-[#52525B]\" data-kid=\"96\">Quận 1 • Bệnh nhân: Mr. Tran</p>\n              </div>\n              <span class=\"text-[10px] font-mono bg-white px-2 py-1 rounded-md border border-[#E4E4E7]\" data-kid=\"97\">18:00</span>\n            </div>\n            <div class=\"p-4 bg-[#F5F6F7] rounded-2xl flex justify-between items-center group cursor-pointer hover:bg-[#ECFBF2] transition-colors\" data-kid=\"98\">\n              <div data-kid=\"99\">\n                <p class=\"text-sm font-semibold\" data-kid=\"100\">Truyền dịch IV</p>\n                <p class=\"text-xs text-[#52525B]\" data-kid=\"101\">Quận 3 • Bệnh nhân: Ms. Lan</p>\n              </div>\n              <span class=\"text-[10px] font-mono bg-white px-2 py-1 rounded-md border border-[#E4E4E7]\" data-kid=\"102\">19:30</span>\n            </div>\n          </div>\n          <button class=\"w-full mt-6 py-2.5 text-xs font-semibold text-[#18BE66] hover:bg-[#ECFBF2] rounded-xl transition-colors\" data-kid=\"103\">Xem toàn bộ lịch trình</button>\n        </div>\n\n        \n        <div class=\"bg-[#ECFBF2] rounded-3xl p-8 border border-[#18BE66]/20 relative overflow-hidden flex flex-col justify-between\" data-kid=\"104\">\n          <div class=\"relative z-10\" data-kid=\"105\">\n            <span class=\"eyebrow text-[10px] mb-1 block\" data-kid=\"106\">Chi phí</span>\n            <h3 class=\"text-xl font-semibold tight-tracking mb-2\" data-kid=\"107\">Tiết kiệm vận hành</h3>\n            <p class=\"text-sm text-[#16A34A]/80\" data-kid=\"108\">Tối ưu hóa điều phối nhân sự giúp giảm 15% chi phí ngoài giờ.</p>\n          </div>\n          <div class=\"text-4xl font-bold text-[#16A34A] tight-tracking relative z-10\" data-kid=\"109\">$12,450</div>\n          <i class=\"ti ti-pig-money absolute -bottom-4 -right-4 text-8xl text-[#18BE66]/10 rotate-12\" data-kid=\"110\"></i>\n        </div>\n\n        \n        <div class=\"bg-white border border-[#E4E4E7] rounded-3xl p-8 shadow-xs flex flex-col justify-between\" data-kid=\"111\">\n          <div data-kid=\"112\">\n            <span class=\"eyebrow text-[10px] mb-1 block\" data-kid=\"113\">Hài lòng</span>\n            <h3 class=\"text-xl font-semibold tight-tracking mb-2\" data-kid=\"114\">Chỉ số NPS</h3>\n            <div class=\"flex items-center gap-1 text-[#FFB800] my-4\" data-kid=\"115\">\n              <i class=\"ti ti-star-filled\" data-kid=\"116\"></i>\n              <i class=\"ti ti-star-filled\" data-kid=\"117\"></i>\n              <i class=\"ti ti-star-filled\" data-kid=\"118\"></i>\n              <i class=\"ti ti-star-filled\" data-kid=\"119\"></i>\n              <i class=\"ti ti-star-half-filled\" data-kid=\"120\"></i>\n              <span class=\"ml-2 text-2xl font-bold text-[#0A0A0A]\" data-kid=\"121\">4.8</span>\n            </div>\n          </div>\n          <p class=\"text-xs text-[#52525B]\" data-kid=\"122\">Dựa trên 240 phản hồi trong tuần này.</p>\n        </div>\n      </div>\n    </main>\n\n    \n    <footer class=\"mt-auto px-8 py-8 border-t border-[#E4E4E7] flex justify-between items-center\" data-kid=\"123\">\n      <div class=\"flex items-center gap-3\" data-kid=\"124\">\n        <div class=\"w-6 h-6 bg-[#18BE66] rounded flex items-center justify-center\" data-kid=\"125\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"white\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"w-3.5 h-3.5\" data-kid=\"126\">\n            <path d=\"M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5\" data-kid=\"127\"></path>\n          </svg>\n        </div>\n        <span class=\"text-sm font-semibold tight-tracking text-[#52525B]\" data-kid=\"128\">MintCare &copy; 2024</span>\n      </div>\n      <div class=\"flex gap-8\" data-kid=\"129\">\n        <a href=\"#\" class=\"text-xs font-medium text-[#52525B] hover:text-[#0A0A0A] transition-colors uppercase font-mono tracking-widest\" data-kid=\"130\">Trung tâm Hỗ trợ</a>\n        <a href=\"#\" class=\"text-xs font-medium text-[#52525B] hover:text-[#0A0A0A] transition-colors uppercase font-mono tracking-widest\" data-kid=\"131\">Trạng thái Hệ thống</a>\n        <a href=\"#\" class=\"text-xs font-medium text-[#52525B] hover:text-[#0A0A0A] transition-colors uppercase font-mono tracking-widest\" data-kid=\"132\">Quyền riêng tư</a>\n      </div>\n    </footer>\n  </div>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/chart.js\" data-kid=\"133\"></script>\n<script data-kid=\"134\">\n  // Shared Configuration\n  const primaryColor = '#18BE66';\n  const primaryLight = 'rgba(24, 190, 102, 0.1)';\n  const gridColor = '#F1F5F9';\n  const labelColor = '#94A3B8';\n\n  // Area Chart: Patient Inflow\n  const ctxInflow = document.getElementById('patientInflowChart').getContext('2d');\n  new Chart(ctxInflow, {\n    type: 'line',\n    data: {\n      labels: ['T2', 'T3', 'T4', 'T5', 'T6', 'T7', 'CN'],\n      datasets: [{\n        label: 'Số lượng bệnh nhân',\n        data: [65, 78, 72, 90, 85, 95, 102],\n        borderColor: primaryColor,\n        backgroundColor: (context) => {\n          const chart = context.chart;\n          const {ctx, chartArea} = chart;\n          if (!chartArea) return null;\n          const gradient = ctx.createLinearGradient(0, chartArea.top, 0, chartArea.bottom);\n          gradient.addColorStop(0, 'rgba(24, 190, 102, 0.2)');\n          gradient.addColorStop(1, 'rgba(24, 190, 102, 0)');\n          return gradient;\n        },\n        fill: true,\n        tension: 0.4,\n        borderWidth: 3,\n        pointRadius: 0,\n        pointHoverRadius: 6,\n        pointHoverBackgroundColor: primaryColor,\n        pointHoverBorderColor: '#fff',\n        pointHoverBorderWidth: 3\n      }]\n    },\n    options: {\n      responsive: true,\n      maintainAspectRatio: false,\n      plugins: {\n        legend: { display: false },\n        tooltip: {\n          backgroundColor: '#18181B',\n          padding: 12,\n          titleFont: { family: 'Plus Jakarta Sans', size: 12 },\n          bodyFont: { family: 'Plus Jakarta Sans', size: 14, weight: '600' },\n          displayColors: false\n        }\n      },\n      scales: {\n        x: {\n          grid: { display: false },\n          ticks: { color: labelColor, font: { family: 'Plus Jakarta Sans', size: 11 } }\n        },\n        y: {\n          grid: { color: gridColor, drawBorder: false },\n          ticks: { color: labelColor, font: { family: 'Plus Jakarta Sans', size: 11 }, stepSize: 20 }\n        }\n      }\n    }\n  });\n\n  // Gauge Chart: Bed Occupancy\n  const ctxOccupancy = document.getElementById('occupancyGauge').getContext('2d');\n  new Chart(ctxOccupancy, {\n    type: 'doughnut',\n    data: {\n      labels: ['Đã dùng', 'Còn trống'],\n      datasets: [{\n        data: [82, 18],\n        backgroundColor: [primaryColor, '#F1F5F9'],\n        borderWidth: 0,\n        circumference: 240,\n        rotation: 240,\n        cutout: '85%',\n        borderRadius: 20\n      }]\n    },\n    options: {\n      responsive: true,\n      maintainAspectRatio: false,\n      plugins: {\n        legend: { display: false },\n        tooltip: { enabled: false }\n      }\n    }\n  });\n\n  // Bar Chart: Staff Hours\n  const ctxHours = document.getElementById('staffHoursChart').getContext('2d');\n  new Chart(ctxHours, {\n    type: 'bar',\n    data: {\n      labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri'],\n      datasets: [{\n        label: 'Giờ làm',\n        data: [420, 380, 450, 410, 390],\n        backgroundColor: primaryColor,\n        borderRadius: 6,\n        barThickness: 12\n      }]\n    },\n    options: {\n      responsive: true,\n      maintainAspectRatio: false,\n      plugins: {\n        legend: { display: false }\n      },\n      scales: {\n        x: {\n          grid: { display: false },\n          ticks: { color: 'rgba(255,255,255,0.4)', font: { family: 'JetBrains Mono', size: 10 } }\n        },\n        y: {\n          display: false\n        }\n      }\n    }\n  });\n</script>",
