      "html": "\n<div class=\"min-h-screen bg-white font-sans text-[#0A0A0A]\" data-kid=\"0\">\n    <style data-kid=\"1\">\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Geist+Mono:wght@400;500&display=swap');\n        \n        :root {\n            --color-surface: #FFFFFF;\n            --color-primary: #18BE66;\n            --color-primary-strong: #16A34A;\n            --color-action: #18181B;\n            --color-on-surface: #0A0A0A;\n            --color-on-surface-secondary: #52525B;\n            --color-on-surface-tertiary: #A1A1AA;\n            --color-surface-secondary: #F5F6F7;\n            --color-surface-tinted: #ECFBF2;\n            --color-hairline: #E4E4E7;\n        }\n\n        .font-mono-eyebrow {\n            font-family: 'Geist Mono', ui-monospace, monospace;\n        }\n\n        .tracking-tight-custom {\n            letter-spacing: -0.02em;\n        }\n\n        /* Lenis base scroll behavior */\n        html.lenis {\n            height: auto;\n        }\n        .lenis-smooth {\n            scroll-behavior: auto !important;\n        }\n        .lenis-smooth [data-lenis-prevent] {\n            overscroll-behavior: contain;\n        }\n        .lenis-stopped {\n            overflow: hidden;\n        }\n    </style>\n    <link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" data-kid=\"2\">\n\n    \n    <nav class=\"sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-[var(--color-hairline)] px-8 h-16 flex items-center justify-between\" data-kid=\"3\">\n        <div class=\"flex items-center gap-8\" data-kid=\"4\">\n            <div class=\"flex items-center gap-2\" data-kid=\"5\">\n                <div class=\"w-8 h-8 bg-[var(--color-primary)] rounded-lg flex items-center justify-center\" data-kid=\"6\">\n                    <i class=\"lucide-leaf w-5 h-5 text-white\" data-kid=\"7\"></i>\n                </div>\n                <span class=\"text-lg font-semibold tracking-tight-custom\" data-kid=\"8\">Mintlify <span class=\"text-[var(--color-on-surface-tertiary)] font-normal\" data-kid=\"9\">Health</span></span>\n            </div>\n            <div class=\"hidden md:flex items-center gap-6\" data-kid=\"10\">\n                <a href=\"#\" class=\"text-sm font-medium text-[var(--color-on-surface-secondary)] hover:text-[var(--color-on-surface)] transition-colors\" data-kid=\"11\">Patients</a>\n                <a href=\"#\" class=\"text-sm font-medium text-[var(--color-on-surface)] transition-colors border-b-2 border-[var(--color-primary)] pt-1\" data-kid=\"12\">Dispatch</a>\n                <a href=\"#\" class=\"text-sm font-medium text-[var(--color-on-surface-secondary)] hover:text-[var(--color-on-surface)] transition-colors\" data-kid=\"13\">Schedules</a>\n                <a href=\"#\" class=\"text-sm font-medium text-[var(--color-on-surface-secondary)] hover:text-[var(--color-on-surface)] transition-colors\" data-kid=\"14\">Resources</a>\n            </div>\n        </div>\n        <div class=\"flex items-center gap-4\" data-kid=\"15\">\n            <div class=\"bg-[var(--color-surface-secondary)] px-3 py-1.5 rounded-full flex items-center gap-2 border border-[var(--color-hairline)]\" data-kid=\"16\">\n                <span class=\"w-2 h-2 rounded-full bg-[var(--color-primary)]\" data-kid=\"17\"></span>\n                <span class=\"text-xs font-medium text-[var(--color-on-surface-secondary)]\" data-kid=\"18\">All systems normal</span>\n            </div>\n            <button class=\"w-8 h-8 rounded-full bg-[var(--color-surface-secondary)] flex items-center justify-center text-[var(--color-on-surface-secondary)]\" data-kid=\"19\">\n                <i class=\"lucide-bell w-4 h-4\" data-kid=\"20\"></i>\n            </button>\n            <div class=\"w-8 h-8 rounded-full bg-[var(--color-action)] flex items-center justify-center text-white text-xs font-medium\" data-kid=\"21\">JD</div>\n        </div>\n    </nav>\n\n    \n    <header class=\"max-w-7xl mx-auto px-8 py-16\" data-kid=\"22\">\n        <div class=\"mb-10\" data-kid=\"23\">\n            <span class=\"font-mono-eyebrow text-[13px] font-medium tracking-[0.04em] text-[var(--color-primary-strong)] uppercase\" data-kid=\"24\">Command Center</span>\n            <h1 class=\"text-[48px] font-semibold tracking-tight-custom mt-2 mb-4 leading-tight\" data-kid=\"25\">Care Scheduling & Dispatch</h1>\n            <p class=\"text-[18px] text-[var(--color-on-surface-secondary)] max-w-2xl\" data-kid=\"26\">Real-time oversight of home care delivery, staffing logistics, and service progression.</p>\n        </div>\n\n        \n        <div class=\"bg-[var(--color-surface-secondary)] rounded-2xl p-8 border border-[var(--color-hairline)]\" data-kid=\"27\">\n            <div class=\"flex items-center justify-between mb-8\" data-kid=\"28\">\n                <div class=\"text-[14px] font-medium text-[var(--color-on-surface)]\" data-kid=\"29\">Global Care Cycle Status</div>\n                <div class=\"flex items-center gap-2\" data-kid=\"30\">\n                    <span class=\"text-[12px] text-[var(--color-on-surface-tertiary)]\" data-kid=\"31\">Updated 2m ago</span>\n                    <button class=\"text-[var(--color-primary-strong)] hover:underline text-xs font-medium\" data-kid=\"32\">Refresh Data</button>\n                </div>\n            </div>\n            <div class=\"relative flex items-center justify-between px-4\" data-kid=\"33\">\n                <div class=\"absolute top-1/2 left-4 right-4 h-0.5 bg-[var(--color-hairline)] -translate-y-1/2\" data-kid=\"34\"></div>\n                \n                <div class=\"relative z-10 flex flex-col items-center gap-3\" data-kid=\"35\">\n                    <div class=\"w-10 h-10 rounded-full bg-[var(--color-primary)] flex items-center justify-center text-white shadow-sm\" data-kid=\"36\">\n                        <i class=\"lucide-clipboard-list w-5 h-5\" data-kid=\"37\"></i>\n                    </div>\n                    <div class=\"text-center\" data-kid=\"38\">\n                        <div class=\"text-xs font-bold text-[var(--color-on-surface)]\" data-kid=\"39\">Discovery</div>\n                        <div class=\"text-[10px] text-[var(--color-on-surface-tertiary)] uppercase font-mono-eyebrow\" data-kid=\"40\">Complete</div>\n                    </div>\n                </div>\n\n                <div class=\"relative z-10 flex flex-col items-center gap-3\" data-kid=\"41\">\n                    <div class=\"w-10 h-10 rounded-full bg-[var(--color-primary)] flex items-center justify-center text-white shadow-sm\" data-kid=\"42\">\n                        <i class=\"lucide-file-text w-5 h-5\" data-kid=\"43\"></i>\n                    </div>\n                    <div class=\"text-center\" data-kid=\"44\">\n                        <div class=\"text-xs font-bold text-[var(--color-on-surface)]\" data-kid=\"45\">Assessment</div>\n                        <div class=\"text-[10px] text-[var(--color-on-surface-tertiary)] uppercase font-mono-eyebrow\" data-kid=\"46\">Complete</div>\n                    </div>\n                </div>\n\n                <div class=\"relative z-10 flex flex-col items-center gap-3\" data-kid=\"47\">\n                    <div class=\"w-12 h-12 rounded-full bg-white border-2 border-[var(--color-primary)] flex items-center justify-center text-[var(--color-primary)] shadow-md ring-4 ring-[var(--color-surface-secondary)]\" data-kid=\"48\">\n                        <div class=\"w-3 h-3 rounded-full bg-[var(--color-primary)] animate-pulse\" data-kid=\"49\"></div>\n                    </div>\n                    <div class=\"text-center\" data-kid=\"50\">\n                        <div class=\"text-sm font-bold text-[var(--color-primary)]\" data-kid=\"51\">Dispatch</div>\n                        <div class=\"text-[10px] text-[var(--color-primary-strong)] uppercase font-mono-eyebrow\" data-kid=\"52\">In Progress</div>\n                    </div>\n                </div>\n\n                <div class=\"relative z-10 flex flex-col items-center gap-3 opacity-40\" data-kid=\"53\">\n                    <div class=\"w-10 h-10 rounded-full bg-white border border-[var(--color-hairline)] flex items-center justify-center text-[var(--color-on-surface-tertiary)]\" data-kid=\"54\">\n                        <i class=\"lucide-heart-pulse w-5 h-5\" data-kid=\"55\"></i>\n                    </div>\n                    <div class=\"text-center\" data-kid=\"56\">\n                        <div class=\"text-xs font-bold text-[var(--color-on-surface-tertiary)]\" data-kid=\"57\">Active Care</div>\n                        <div class=\"text-[10px] uppercase font-mono-eyebrow\" data-kid=\"58\">Queue</div>\n                    </div>\n                </div>\n\n                <div class=\"relative z-10 flex flex-col items-center gap-3 opacity-40\" data-kid=\"59\">\n                    <div class=\"w-10 h-10 rounded-full bg-white border border-[var(--color-hairline)] flex items-center justify-center text-[var(--color-on-surface-tertiary)]\" data-kid=\"60\">\n                        <i class=\"lucide-star w-5 h-5\" data-kid=\"61\"></i>\n                    </div>\n                    <div class=\"text-center\" data-kid=\"62\">\n                        <div class=\"text-xs font-bold text-[var(--color-on-surface-tertiary)]\" data-kid=\"63\">Review</div>\n                        <div class=\"text-[10px] uppercase font-mono-eyebrow\" data-kid=\"64\">Planned</div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </header>\n\n    \n    <main class=\"max-w-7xl mx-auto px-8 pb-24 grid grid-cols-12 gap-8\" data-kid=\"65\">\n        \n        \n        <div class=\"col-span-12 lg:col-span-8 flex flex-col gap-8\" data-kid=\"66\">\n            \n            \n            <section class=\"bg-white border border-[var(--color-hairline)] rounded-2xl overflow-hidden group\" data-kid=\"67\">\n                <div class=\"p-6 border-b border-[var(--color-hairline)] flex items-center justify-between\" data-kid=\"68\">\n                    <div data-kid=\"69\">\n                        <span class=\"font-mono-eyebrow text-[12px] font-medium text-[var(--color-primary-strong)] uppercase\" data-kid=\"70\">Live Visualization</span>\n                        <h3 class=\"text-lg font-semibold tracking-tight-custom\" data-kid=\"71\">Service Area Map</h3>\n                    </div>\n                    <div class=\"flex items-center gap-2\" data-kid=\"72\">\n                        <div class=\"bg-[var(--color-surface-tinted)] px-3 py-1 rounded-full text-[12px] font-medium text-[var(--color-primary-strong)]\" data-kid=\"73\">\n                            8 Active Routes\n                        </div>\n                        <button class=\"p-2 rounded-lg border border-[var(--color-hairline)] hover:bg-[var(--color-surface-secondary)]\" data-kid=\"74\">\n                            <i class=\"lucide-maximize-2 w-4 h-4 text-[var(--color-on-surface-secondary)]\" data-kid=\"75\"></i>\n                        </button>\n                    </div>\n                </div>\n                \n                <div class=\"h-[400px] bg-[var(--color-surface-secondary)] relative overflow-hidden flex items-center justify-center\" data-kid=\"76\">\n                    \n                    <div class=\"absolute inset-0 opacity-10\" style=\"background-image: radial-gradient(var(--color-primary) 1.5px, transparent 1.5px); background-size: 32px 32px;\" data-kid=\"77\"></div>\n                    <svg class=\"absolute inset-0 w-full h-full opacity-5 pointer-events-none\" viewBox=\"0 0 800 400\" data-kid=\"78\">\n                        <path d=\"M50 50 Q 150 100 200 50 T 400 50 T 600 150 T 750 100\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" data-kid=\"79\"></path>\n                        <path d=\"M100 350 Q 300 250 500 350 T 700 250\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" data-kid=\"80\"></path>\n                    </svg>\n\n                    \n                    <div class=\"absolute top-6 left-6 flex flex-col gap-3\" data-kid=\"81\">\n                        <div class=\"bg-white/90 backdrop-blur-md p-3 rounded-xl border border-[var(--color-hairline)] shadow-sm max-w-[200px]\" data-kid=\"82\">\n                            <div class=\"text-[10px] font-mono-eyebrow text-[var(--color-on-surface-tertiary)] uppercase mb-1\" data-kid=\"83\">Active Region</div>\n                            <div class=\"text-sm font-semibold truncate\" data-kid=\"84\">Greater Metropolitan</div>\n                        </div>\n                    </div>\n\n                    \n                    \n                    <svg class=\"absolute inset-0 w-full h-full pointer-events-none\" style=\"filter: drop-shadow(0 0 8px rgba(24,190,102,0.1));\" data-kid=\"85\">\n                        <path d=\"M240 100 Q 350 150 440 240\" fill=\"none\" stroke=\"var(--color-primary)\" stroke-width=\"1.5\" stroke-dasharray=\"4 4\" opacity=\"0.4\" data-kid=\"86\"></path>\n                        <path d=\"M440 240 L 600 160\" fill=\"none\" stroke=\"var(--color-primary)\" stroke-width=\"1.5\" stroke-dasharray=\"4 4\" opacity=\"0.4\" data-kid=\"87\"></path>\n                    </svg>\n\n                    \n                    <div class=\"absolute top-[25%] left-[30%] group cursor-pointer z-10\" data-kid=\"88\">\n                        <div class=\"bg-[var(--color-action)] text-white text-[10px] px-2 py-1 rounded-md absolute -top-10 left-1/2 -translate-x-1/2 opacity-0 md:group-hover:opacity-100 transition-opacity whitespace-nowrap shadow-lg\" data-kid=\"89\">\n                            Sarah Jenkins • Physical Therapy\n                        </div>\n                        <div class=\"w-8 h-8 rounded-full bg-white border-2 border-[var(--color-primary)] flex items-center justify-center shadow-lg\" data-kid=\"90\">\n                            <i class=\"lucide-map-pin w-4 h-4 text-[var(--color-primary)] map-pin-icon\" data-kid=\"91\"></i>\n                        </div>\n                    </div>\n\n                    \n                    <div class=\"absolute top-[60%] left-[55%] group cursor-pointer z-20\" data-kid=\"92\">\n                        <div class=\"bg-[var(--color-action)] text-white text-[10px] px-2 py-1 rounded-md absolute -top-12 left-1/2 -translate-x-1/2 opacity-0 md:group-hover:opacity-100 transition-opacity whitespace-nowrap shadow-lg\" data-kid=\"93\">\n                            James Wilson • In Transit (5m away)\n                        </div>\n                        <div class=\"relative\" data-kid=\"94\">\n                            <div class=\"absolute inset-0 bg-[var(--color-primary)]/20 rounded-full animate-ping\" data-kid=\"95\"></div>\n                            <div class=\"w-12 h-12 rounded-full bg-[var(--color-primary)] border-4 border-white flex items-center justify-center shadow-xl overflow-hidden\" data-kid=\"96\">\n                                <img src=\"https://i.pravatar.cc/48?u=james\" alt=\"staff\" class=\"w-full h-full object-cover\" data-kid=\"97\">\n                            </div>\n                        </div>\n                    </div>\n\n                    \n                    <div class=\"absolute top-[40%] left-[75%] group cursor-pointer z-10 opacity-70\" data-kid=\"98\">\n                        <div class=\"w-8 h-8 rounded-full bg-white border-2 border-[var(--color-on-surface-tertiary)] flex items-center justify-center shadow-sm\" data-kid=\"99\">\n                            <i class=\"lucide-home w-4 h-4 text-[var(--color-on-surface-tertiary)]\" data-kid=\"100\"></i>\n                        </div>\n                    </div>\n\n                    \n                    <div class=\"absolute bottom-6 right-6 flex flex-col gap-2\" data-kid=\"101\">\n                        <button class=\"w-10 h-10 rounded-full bg-white border border-[var(--color-hairline)] flex items-center justify-center text-[var(--color-on-surface-secondary)] hover:bg-[var(--color-surface-secondary)] transition-colors shadow-sm\" data-kid=\"102\">\n                            <i class=\"lucide-plus w-5 h-5\" data-kid=\"103\"></i>\n                        </button>\n                        <button class=\"w-10 h-10 rounded-full bg-white border border-[var(--color-hairline)] flex items-center justify-center text-[var(--color-on-surface-secondary)] hover:bg-[var(--color-surface-secondary)] transition-colors shadow-sm\" data-kid=\"104\">\n                            <i class=\"lucide-minus w-5 h-5\" data-kid=\"105\"></i>\n                        </button>\n                    </div>\n                </div>\n            </section>\n\n            \n            <section class=\"grid grid-cols-1 md:grid-cols-3 gap-6\" data-kid=\"106\">\n                \n                <div class=\"flex flex-col gap-4\" data-kid=\"107\">\n                    <div class=\"flex items-center justify-between px-2\" data-kid=\"108\">\n                        <div class=\"flex items-center gap-2\" data-kid=\"109\">\n                            <span class=\"font-mono-eyebrow text-[13px] font-medium tracking-[0.04em] text-[var(--color-on-surface-secondary)] uppercase\" data-kid=\"110\">Unassigned</span>\n                            <span class=\"bg-[var(--color-surface-secondary)] text-[var(--color-on-surface-secondary)] text-[11px] font-bold px-2 py-0.5 rounded-full border border-[var(--color-hairline)]\" data-kid=\"111\">4</span>\n                        </div>\n                    </div>\n                    \n                    <div class=\"flex flex-col gap-3\" data-kid=\"112\">\n                        \n                        <div class=\"kanban-card bg-white border border-[var(--color-hairline)] rounded-xl p-4 hover:border-[var(--color-primary)] cursor-pointer group hover:shadow-sm\" data-kid=\"113\">\n                            <div class=\"flex justify-between items-start mb-2\" data-kid=\"114\">\n                                <div class=\"flex gap-2\" data-kid=\"115\">\n                                    <span class=\"text-[10px] font-mono-eyebrow text-[var(--color-primary-strong)] bg-[var(--color-surface-tinted)] px-2 py-0.5 rounded-md uppercase\" data-kid=\"116\">Hourly</span>\n                                    <span class=\"text-[9px] font-mono-eyebrow text-white bg-[var(--color-primary)] px-1.5 py-0.5 rounded-full uppercase font-bold tracking-wider\" data-kid=\"117\">NEW</span>\n                                </div>\n                                <span class=\"text-[10px] text-[var(--color-on-surface-tertiary)]\" data-kid=\"118\">14:20</span>\n                            </div>\n                            <h4 class=\"text-sm font-semibold text-[var(--color-on-surface)] mb-1\" data-kid=\"119\">Sarah Jenkins</h4>\n                            <p class=\"text-[12px] text-[var(--color-on-surface-secondary)] line-clamp-2 mb-3\" data-kid=\"120\">Post-op physical therapy session. Requires specialist handling.</p>\n                            <div class=\"flex items-center justify-between pt-3 border-t border-[var(--color-hairline)]\" data-kid=\"121\">\n                                <div class=\"flex -space-x-1.5\" data-kid=\"122\">\n                                    <img src=\"https://i.pravatar.cc/24?u=1\" class=\"w-5 h-5 rounded-full border border-white\" alt=\"avatar\" data-kid=\"123\">\n                                    <img src=\"https://i.pravatar.cc/24?u=2\" class=\"w-5 h-5 rounded-full border border-white\" alt=\"avatar\" data-kid=\"124\">\n                                </div>\n                                <button class=\"text-[11px] font-medium px-3 py-1 bg-[var(--color-action)] text-white rounded-full\" data-kid=\"125\">Assign</button>\n                            </div>\n                        </div>\n\n                        <div class=\"kanban-card bg-white border border-[var(--color-hairline)] rounded-xl p-4 hover:border-[var(--color-primary)] cursor-pointer group hover:shadow-sm\" data-kid=\"126\">\n                            <div class=\"flex justify-between items-start mb-2\" data-kid=\"127\">\n                                <span class=\"text-[10px] font-mono-eyebrow text-[var(--color-on-surface-secondary)] bg-[var(--color-surface-secondary)] px-2 py-0.5 rounded-md uppercase\" data-kid=\"128\">Package A</span>\n                                <span class=\"text-[10px] text-[var(--color-on-surface-tertiary)]\" data-kid=\"129\">15:00</span>\n                            </div>\n                            <h4 class=\"text-sm font-semibold text-[var(--color-on-surface)] mb-1\" data-kid=\"130\">Arthur Morgan</h4>\n                            <p class=\"text-[12px] text-[var(--color-on-surface-secondary)] line-clamp-2 mb-3\" data-kid=\"131\">Weekly medication audit and vital check.</p>\n                            <div class=\"flex items-center justify-between pt-3 border-t border-[var(--color-hairline)]\" data-kid=\"132\">\n                                <div class=\"flex items-center gap-1 text-[var(--color-on-surface-tertiary)]\" data-kid=\"133\">\n                                    <i class=\"lucide-clock w-3 h-3\" data-kid=\"134\"></i>\n                                    <span class=\"text-[10px]\" data-kid=\"135\">Due in 40m</span>\n                                </div>\n                                <button class=\"text-[11px] font-medium px-3 py-1 border border-[var(--color-hairline)] rounded-full hover:bg-[var(--color-surface-secondary)]\" data-kid=\"136\">Assign</button>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"flex flex-col gap-4\" data-kid=\"137\">\n                    <div class=\"flex items-center justify-between px-2\" data-kid=\"138\">\n                        <div class=\"flex items-center gap-2\" data-kid=\"139\">\n                            <span class=\"font-mono-eyebrow text-[13px] font-medium tracking-[0.04em] text-[var(--color-on-surface-secondary)] uppercase\" data-kid=\"140\">In Transit</span>\n                            <span class=\"bg-[var(--color-surface-secondary)] text-[var(--color-on-surface-secondary)] text-[11px] font-bold px-2 py-0.5 rounded-full border border-[var(--color-hairline)]\" data-kid=\"141\">2</span>\n                        </div>\n                    </div>\n                    \n                    <div class=\"flex flex-col gap-3\" data-kid=\"142\">\n                        <div class=\"bg-white border-l-4 border-l-[var(--color-primary)] border border-y-[var(--color-hairline)] border-r-[var(--color-hairline)] rounded-xl p-4 shadow-sm\" data-kid=\"143\">\n                            <div class=\"flex justify-between items-start mb-2\" data-kid=\"144\">\n                                <div class=\"flex items-center gap-1.5 text-[var(--color-primary-strong)]\" data-kid=\"145\">\n                                    <span class=\"w-1.5 h-1.5 rounded-full bg-[var(--color-primary)] animate-pulse\" data-kid=\"146\"></span>\n                                    <span class=\"text-[10px] font-bold uppercase tracking-wider\" data-kid=\"147\">Live</span>\n                                </div>\n                                <span class=\"text-[10px] text-[var(--color-on-surface-tertiary)] font-medium\" data-kid=\"148\">8 min away</span>\n                            </div>\n                            <h4 class=\"text-sm font-semibold text-[var(--color-on-surface)] mb-1\" data-kid=\"149\">James Wilson</h4>\n                            <div class=\"flex items-center gap-2 mb-3 text-[11px] text-[var(--color-on-surface-secondary)]\" data-kid=\"150\">\n                                <i class=\"lucide-user w-3 h-3\" data-kid=\"151\"></i>\n                                <span data-kid=\"152\">Patient: John Doe</span>\n                            </div>\n                            <div class=\"w-full bg-[var(--color-surface-secondary)] h-1 rounded-full overflow-hidden\" data-kid=\"153\">\n                                <div class=\"bg-[var(--color-primary)] h-full w-[70%]\" id=\"transit-progress\" data-kid=\"154\"></div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"flex flex-col gap-4\" data-kid=\"155\">\n                    <div class=\"flex items-center justify-between px-2\" data-kid=\"156\">\n                        <div class=\"flex items-center gap-2\" data-kid=\"157\">\n                            <span class=\"font-mono-eyebrow text-[13px] font-medium tracking-[0.04em] text-[var(--color-on-surface-secondary)] uppercase\" data-kid=\"158\">On Site</span>\n                            <span class=\"bg-[var(--color-surface-secondary)] text-[var(--color-on-surface-secondary)] text-[11px] font-bold px-2 py-0.5 rounded-full border border-[var(--color-hairline)]\" data-kid=\"159\">3</span>\n                        </div>\n                    </div>\n                    <div class=\"flex flex-col gap-3\" data-kid=\"160\">\n                        <div class=\"kanban-card bg-white border border-[var(--color-hairline)] rounded-xl p-4 shadow-sm border-t-2 border-t-[var(--color-primary)]\" data-kid=\"161\">\n                            <div class=\"flex justify-between items-start mb-2\" data-kid=\"162\">\n                                <span class=\"text-[10px] font-mono-eyebrow text-[var(--color-on-surface-tertiary)] uppercase\" data-kid=\"163\">Started 22m ago</span>\n                                <div class=\"flex items-center gap-1 text-[var(--color-primary-strong)]\" data-kid=\"164\">\n                                    <i class=\"lucide-check-circle-2 w-3 h-3\" data-kid=\"165\"></i>\n                                    <span class=\"text-[10px] font-bold uppercase\" data-kid=\"166\">Active</span>\n                                </div>\n                            </div>\n                            <h4 class=\"text-sm font-semibold text-[var(--color-on-surface)] mb-1\" data-kid=\"167\">Mary Stephenson</h4>\n                            <div class=\"flex items-center gap-2 text-[11px] text-[var(--color-on-surface-secondary)]\" data-kid=\"168\">\n                                <i class=\"lucide-user w-3 h-3\" data-kid=\"169\"></i>\n                                <span data-kid=\"170\">Provider: Alice Cooper</span>\n                            </div>\n                        </div>\n\n                        <div class=\"bg-[var(--color-surface-secondary)]/50 border border-dashed border-[var(--color-hairline)] rounded-xl p-4 flex flex-col items-center justify-center text-center\" data-kid=\"171\">\n                            <div class=\"w-8 h-8 rounded-full bg-white border border-[var(--color-hairline)] flex items-center justify-center mb-2\" data-kid=\"172\">\n                                <i class=\"lucide-activity w-4 h-4 text-[var(--color-on-surface-tertiary)]\" data-kid=\"173\"></i>\n                            </div>\n                            <span class=\"text-[11px] text-[var(--color-on-surface-tertiary)]\" data-kid=\"174\">+2 more visits active</span>\n                        </div>\n                    </div>\n                </div>\n            </section>\n        </div>\n\n        \n        <aside class=\"col-span-12 lg:col-span-4 flex flex-col gap-8\" data-kid=\"175\">\n            \n            \n            <section class=\"bg-white border border-[var(--color-hairline)] rounded-2xl p-6\" data-kid=\"176\">\n                <div class=\"flex items-center justify-between mb-6\" data-kid=\"177\">\n                    <div data-kid=\"178\">\n                        <h3 class=\"text-lg font-semibold tracking-tight-custom\" data-kid=\"179\">Staff Availability</h3>\n                        <p class=\"text-[13px] text-[var(--color-on-surface-secondary)] mt-1\" data-kid=\"180\">12 active providers online</p>\n                    </div>\n                    <span class=\"font-mono-eyebrow text-[11px] font-bold text-[var(--color-primary-strong)] bg-[var(--color-surface-tinted)] px-2 py-1 rounded\" data-kid=\"181\">LIVE</span>\n                </div>\n\n                <div class=\"space-y-3\" data-kid=\"182\">\n                    <div class=\"flex items-center justify-between p-3 rounded-xl border border-[var(--color-surface-secondary)] hover:border-[var(--color-hairline)] hover:bg-[var(--color-surface-secondary)]/30 transition-all cursor-pointer group\" data-kid=\"183\">\n                        <div class=\"flex items-center gap-3\" data-kid=\"184\">\n                            <div class=\"relative\" data-kid=\"185\">\n                                <img src=\"https://i.pravatar.cc/40?u=alice\" class=\"w-10 h-10 rounded-full bg-[var(--color-surface-secondary)]\" alt=\"staff\" data-kid=\"186\">\n                                <span class=\"absolute bottom-0 right-0 w-3 h-3 bg-[var(--color-primary)] border-2 border-white rounded-full\" data-kid=\"187\"></span>\n                            </div>\n                            <div data-kid=\"188\">\n                                <div class=\"text-sm font-semibold group-hover:text-[var(--color-primary-strong)]\" data-kid=\"189\">Alice Cooper</div>\n                                <div class=\"text-[11px] text-[var(--color-on-surface-tertiary)]\" data-kid=\"190\">Nurse Practitioner • 0.2mi away</div>\n                            </div>\n                        </div>\n                        <i class=\"lucide-chevron-right w-4 h-4 text-[var(--color-on-surface-tertiary)] group-hover:translate-x-1 transition-transform\" data-kid=\"191\"></i>\n                    </div>\n\n                    <div class=\"flex items-center justify-between p-3 rounded-xl border border-[var(--color-surface-secondary)] hover:border-[var(--color-hairline)] hover:bg-[var(--color-surface-secondary)]/30 transition-all cursor-pointer group\" data-kid=\"192\">\n                        <div class=\"flex items-center gap-3\" data-kid=\"193\">\n                            <div class=\"relative\" data-kid=\"194\">\n                                <img src=\"https://i.pravatar.cc/40?u=bob\" class=\"w-10 h-10 rounded-full bg-[var(--color-surface-secondary)] grayscale\" alt=\"staff\" data-kid=\"195\">\n                                <span class=\"absolute bottom-0 right-0 w-3 h-3 bg-[var(--color-on-surface-tertiary)] border-2 border-white rounded-full\" data-kid=\"196\"></span>\n                            </div>\n                            <div data-kid=\"197\">\n                                <div class=\"text-sm font-semibold\" data-kid=\"198\">Robert Fox</div>\n                                <div class=\"text-[11px] text-[var(--color-on-surface-tertiary)]\" data-kid=\"199\">Physiotherapist • On Break</div>\n                            </div>\n                        </div>\n                        <i class=\"lucide-chevron-right w-4 h-4 text-[var(--color-on-surface-tertiary)] group-hover:translate-x-1 transition-transform\" data-kid=\"200\"></i>\n                    </div>\n\n                    <div class=\"flex items-center justify-between p-3 rounded-xl border border-[var(--color-surface-secondary)] hover:border-[var(--color-hairline)] hover:bg-[var(--color-surface-secondary)]/30 transition-all cursor-pointer group\" data-kid=\"201\">\n                        <div class=\"flex items-center gap-3\" data-kid=\"202\">\n                            <div class=\"relative\" data-kid=\"203\">\n                                <img src=\"https://i.pravatar.cc/40?u=jane\" class=\"w-10 h-10 rounded-full bg-[var(--color-surface-secondary)]\" alt=\"staff\" data-kid=\"204\">\n                                <span class=\"absolute bottom-0 right-0 w-3 h-3 bg-[var(--color-primary)] border-2 border-white rounded-full\" data-kid=\"205\"></span>\n                            </div>\n                            <div data-kid=\"206\">\n                                <div class=\"text-sm font-semibold group-hover:text-[var(--color-primary-strong)]\" data-kid=\"207\">Jane Smith</div>\n                                <div class=\"text-[11px] text-[var(--color-on-surface-tertiary)]\" data-kid=\"208\">Occupational Therapist • 1.4mi away</div>\n                            </div>\n                        </div>\n                        <i class=\"lucide-chevron-right w-4 h-4 text-[var(--color-on-surface-tertiary)] group-hover:translate-x-1 transition-transform\" data-kid=\"209\"></i>\n                    </div>\n\n                    <button class=\"w-full py-3 mt-4 text-[14px] font-medium text-[var(--color-on-surface)] bg-white border border-[var(--color-hairline)] rounded-full hover:bg-[var(--color-surface-secondary)] transition-colors\" data-kid=\"210\">\n                        View Full Staffing List\n                    </button>\n                </div>\n            </section>\n\n            \n            <section class=\"grid grid-cols-1 gap-4\" data-kid=\"211\">\n                <div class=\"bg-[var(--color-action)] rounded-2xl p-6 text-white relative overflow-hidden\" data-kid=\"212\">\n                    <div class=\"relative z-10\" data-kid=\"213\">\n                        <span class=\"font-mono-eyebrow text-[11px] font-medium text-[var(--color-on-surface-tertiary)] uppercase tracking-wider\" data-kid=\"214\">Avg. Dispatch Time</span>\n                        <div class=\"text-3xl font-semibold mt-1 tracking-tight-custom\" data-kid=\"215\">14.2<span class=\"text-lg font-normal text-[var(--color-on-surface-tertiary)] ml-1\" data-kid=\"216\">mins</span></div>\n                        <div class=\"flex items-center gap-2 text-[var(--color-primary)] text-xs mt-3\" data-kid=\"217\">\n                            <i class=\"lucide-trending-down w-4 h-4\" data-kid=\"218\"></i>\n                            <span data-kid=\"219\">8.4% faster than last week</span>\n                        </div>\n                    </div>\n                    \n                    <div class=\"absolute -right-4 -bottom-4 opacity-10\" data-kid=\"220\">\n                        <i class=\"lucide-timer w-24 h-24\" data-kid=\"221\"></i>\n                    </div>\n                </div>\n\n                <div class=\"bg-white border border-[var(--color-hairline)] rounded-2xl p-6 grow\" data-kid=\"222\">\n                    <span class=\"font-mono-eyebrow text-[11px] font-medium text-[var(--color-on-surface-tertiary)] uppercase tracking-wider\" data-kid=\"223\">Upcoming Tasks</span>\n                    <div class=\"mt-4 space-y-4\" data-kid=\"224\">\n                        <div class=\"flex items-start gap-3\" data-kid=\"225\">\n                            <div class=\"w-2 h-2 rounded-full bg-[var(--color-primary)] mt-1.5\" data-kid=\"226\"></div>\n                            <div data-kid=\"227\">\n                                <div class=\"text-xs font-semibold text-[var(--color-on-surface)]\" data-kid=\"228\">Patient Assessment (D-492)</div>\n                                <div class=\"text-[10px] text-[var(--color-on-surface-tertiary)] mt-0.5\" data-kid=\"229\">Today at 16:30 • Sarah J.</div>\n                            </div>\n                        </div>\n                        <div class=\"flex items-start gap-3\" data-kid=\"230\">\n                            <div class=\"w-2 h-2 rounded-full bg-[var(--color-on-surface-tertiary)] mt-1.5\" data-kid=\"231\"></div>\n                            <div data-kid=\"232\">\n                                <div class=\"text-xs font-semibold text-[var(--color-on-surface)]\" data-kid=\"233\">Care Plan Review (M-201)</div>\n                                <div class=\"text-[10px] text-[var(--color-on-surface-tertiary)] mt-0.5\" data-kid=\"234\">Tomorrow at 09:00 • Team Alpha</div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </section>\n\n        </aside>\n    </main>\n\n    \n    <footer class=\"bg-white border-t border-[var(--color-hairline)] px-8 py-12\" data-kid=\"235\">\n        <div class=\"max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-start gap-12\" data-kid=\"236\">\n            <div class=\"max-w-xs\" data-kid=\"237\">\n                <div class=\"flex items-center gap-2 mb-4\" data-kid=\"238\">\n                    <div class=\"w-6 h-6 bg-[var(--color-primary)] rounded flex items-center justify-center\" data-kid=\"239\">\n                        <i class=\"lucide-leaf w-3 h-3 text-white\" data-kid=\"240\"></i>\n                    </div>\n                    <span class=\"font-semibold tracking-tight-custom\" data-kid=\"241\">Mintlify Health</span>\n                </div>\n                <p class=\"text-sm text-[var(--color-on-surface-secondary)] leading-relaxed\" data-kid=\"242\">The intelligent platform for modern healthcare logistics and patient care delivery.</p>\n            </div>\n            \n            <div class=\"grid grid-cols-2 md:grid-cols-3 gap-12\" data-kid=\"243\">\n                <div data-kid=\"244\">\n                    <h5 class=\"font-mono-eyebrow text-[11px] font-bold text-[var(--color-on-surface-tertiary)] uppercase mb-4 tracking-[0.05em]\" data-kid=\"245\">Platform</h5>\n                    <ul class=\"space-y-2 text-sm text-[var(--color-on-surface-secondary)]\" data-kid=\"246\">\n                        <li data-kid=\"247\"><a href=\"#\" class=\"hover:text-[var(--color-primary-strong)]\" data-kid=\"248\">Patients</a></li>\n                        <li data-kid=\"249\"><a href=\"#\" class=\"hover:text-[var(--color-primary-strong)]\" data-kid=\"250\">Providers</a></li>\n                        <li data-kid=\"251\"><a href=\"#\" class=\"hover:text-[var(--color-primary-strong)]\" data-kid=\"252\">Dispatch</a></li>\n                    </ul>\n                </div>\n                <div data-kid=\"253\">\n                    <h5 class=\"font-mono-eyebrow text-[11px] font-bold text-[var(--color-on-surface-tertiary)] uppercase mb-4 tracking-[0.05em]\" data-kid=\"254\">Resources</h5>\n                    <ul class=\"space-y-2 text-sm text-[var(--color-on-surface-secondary)]\" data-kid=\"255\">\n                        <li data-kid=\"256\"><a href=\"#\" class=\"hover:text-[var(--color-primary-strong)]\" data-kid=\"257\">Documentation</a></li>\n                        <li data-kid=\"258\"><a href=\"#\" class=\"hover:text-[var(--color-primary-strong)]\" data-kid=\"259\">API Reference</a></li>\n                        <li data-kid=\"260\"><a href=\"#\" class=\"hover:text-[var(--color-primary-strong)]\" data-kid=\"261\">Help Center</a></li>\n                    </ul>\n                </div>\n                <div class=\"col-span-2 md:col-span-1\" data-kid=\"262\">\n                    <h5 class=\"font-mono-eyebrow text-[11px] font-bold text-[var(--color-on-surface-tertiary)] uppercase mb-4 tracking-[0.05em]\" data-kid=\"263\">System Status</h5>\n                    <div class=\"bg-[var(--color-surface-secondary)] p-4 rounded-xl border border-[var(--color-hairline)]\" data-kid=\"264\">\n                        <div class=\"flex items-center gap-2 mb-1\" data-kid=\"265\">\n                            <span class=\"w-2 h-2 rounded-full bg-[var(--color-primary)]\" data-kid=\"266\"></span>\n                            <span class=\"text-xs font-semibold\" data-kid=\"267\">Operational</span>\n                        </div>\n                        <p class=\"text-[10px] text-[var(--color-on-surface-tertiary)]\" data-kid=\"268\">Uptime: 99.98% (Last 30d)</p>\n                    </div>\n                </div>\n            </div>\n        </div>\n        <div class=\"max-w-7xl mx-auto border-t border-[var(--color-hairline)] mt-12 pt-8 flex flex-col md:flex-row justify-between items-center gap-4\" data-kid=\"269\">\n            <p class=\"text-[11px] text-[var(--color-on-surface-tertiary)]\" data-kid=\"270\">© 2026 Mintlify Healthcare. All rights reserved.</p>\n            <div class=\"flex items-center gap-6\" data-kid=\"271\">\n                <a href=\"#\" class=\"text-[11px] text-[var(--color-on-surface-tertiary)] hover:text-[var(--color-primary-strong)]\" data-kid=\"272\">Terms</a>\n                <a href=\"#\" class=\"text-[11px] text-[var(--color-on-surface-tertiary)] hover:text-[var(--color-primary-strong)]\" data-kid=\"273\">Privacy</a>\n                <a href=\"#\" class=\"text-[11px] text-[var(--color-on-surface-tertiary)] hover:text-[var(--color-primary-strong)]\" data-kid=\"274\">Security</a>\n            </div>\n        </div>\n    </footer>\n\n    \n    <script src=\"https://unpkg.com/lucide@latest\" data-kid=\"275\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"276\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"277\"></script>\n    <script type=\"module\" data-kid=\"278\">\n        import Lenis from \"https://esm.sh/lenis@1\"\n        \n        // Initialize Lucide Icons first\n        lucide.createIcons();\n\n        // Initialize Lenis\n        const lenis = new Lenis()\n        function raf(time) {\n            lenis.raf(time)\n            requestAnimationFrame(raf)\n        }\n        requestAnimationFrame(raf)\n\n        // Initialize GSAP Animations\n        gsap.registerPlugin(ScrollTrigger);\n\n        // Kanban Card Entrance\n        gsap.from(\".kanban-card\", {\n            y: 20,\n            opacity: 0,\n            duration: 0.6,\n            stagger: 0.08,\n            ease: \"power2.out\",\n            scrollTrigger: {\n                trigger: \".kanban-card\",\n                start: \"top 95%\"\n            }\n        });\n\n        // Map Pins Subtle Animation\n        gsap.to(\".map-pin-icon\", {\n            y: -4,\n            repeat: -1,\n            yoyo: true,\n            duration: 2,\n            ease: \"sine.inOut\"\n        });\n\n        // Progress Bar Mock Logic\n        gsap.from(\"#transit-progress\", {\n            width: \"0%\",\n            duration: 4,\n            ease: \"power1.inOut\",\n            repeat: -1\n        });\n    </script>\n</div>\n",
