      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Geist+Mono:wght@500&display=swap');\n\n  body {\n    font-family: 'Inter', sans-serif;\n    color: #0A0A0A;\n    background-color: #FFFFFF;\n    margin: 0;\n  }\n\n  .font-mono {\n    font-family: 'Geist Mono', monospace;\n  }\n\n  .tight-tracking {\n    letter-spacing: -0.02em;\n  }\n\n  .eyebrow {\n    font-family: 'Geist Mono', monospace;\n    font-size: 13px;\n    font-weight: 500;\n    text-transform: uppercase;\n    letter-spacing: 0.04em;\n    color: #16A34A;\n  }\n\n  /* Custom Scrollbar for a cleaner look */\n  ::-webkit-scrollbar {\n    width: 6px;\n  }\n  ::-webkit-scrollbar-track {\n    background: transparent;\n  }\n  ::-webkit-scrollbar-thumb {\n    background: #E4E4E7;\n    border-radius: 10px;\n  }\n  ::-webkit-scrollbar-thumb:hover {\n    background: #A1A1AA;\n  }\n</style>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"1\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"2\"></script>\n<script src=\"https://unpkg.com/lucide@latest\" data-kid=\"3\"></script>\n\n<div class=\"flex min-h-screen\" data-kid=\"4\">\n  \n  <aside class=\"w-64 border-r border-[#E4E4E7] fixed h-full bg-white flex flex-col z-50\" data-kid=\"5\">\n    <div class=\"p-8 pb-4\" data-kid=\"6\">\n      <div class=\"flex items-center gap-2 mb-10\" data-kid=\"7\">\n        <div class=\"w-8 h-8 bg-[#18BE66] rounded-lg flex items-center justify-center\" data-kid=\"8\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"white\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"w-5 h-5\" data-kid=\"9\">\n            <path d=\"M12 2L3 7v10l9 5 9-5V7l-9-5z\" data-kid=\"10\"></path>\n            <path d=\"M12 22V12\" data-kid=\"11\"></path>\n            <path d=\"M3 7l9 5 9-5\" data-kid=\"12\"></path>\n          </svg>\n        </div>\n        <span class=\"text-xl font-semibold tight-tracking\" data-kid=\"13\">MintCare</span>\n      </div>\n\n      <nav class=\"space-y-1\" data-kid=\"14\">\n        <a href=\"#\" class=\"flex items-center gap-3 px-3 py-2 bg-[#F5F6F7] text-[#0A0A0A] rounded-full font-medium text-sm\" data-kid=\"15\">\n          <i data-lucide=\"layout-grid\" class=\"w-4 h-4\" data-kid=\"16\"></i>\n          Overview\n        </a>\n        <a href=\"#\" class=\"flex items-center gap-3 px-3 py-2 text-[#52525B] hover:bg-[#F5F6F7] rounded-full font-medium text-sm transition-colors\" data-kid=\"17\">\n          <i data-lucide=\"users\" class=\"w-4 h-4\" data-kid=\"18\"></i>\n          Staff\n        </a>\n        <a href=\"#\" class=\"flex items-center gap-3 px-3 py-2 text-[#52525B] hover:bg-[#F5F6F7] rounded-full font-medium text-sm transition-colors\" data-kid=\"19\">\n          <i data-lucide=\"calendar\" class=\"w-4 h-4\" data-kid=\"20\"></i>\n          Schedule\n        </a>\n        <a href=\"#\" class=\"flex items-center gap-3 px-3 py-2 text-[#52525B] hover:bg-[#F5F6F7] rounded-full font-medium text-sm transition-colors\" data-kid=\"21\">\n          <i data-lucide=\"activity\" class=\"w-4 h-4\" data-kid=\"22\"></i>\n          Patients\n        </a>\n        <a href=\"#\" class=\"flex items-center gap-3 px-3 py-2 text-[#52525B] hover:bg-[#F5F6F7] rounded-full font-medium text-sm transition-colors\" data-kid=\"23\">\n          <i data-lucide=\"file-text\" class=\"w-4 h-4\" data-kid=\"24\"></i>\n          Reports\n        </a>\n      </nav>\n    </div>\n\n    <div class=\"mt-auto p-8 pt-0\" data-kid=\"25\">\n      <div class=\"border-t border-[#E4E4E7] pt-6\" data-kid=\"26\">\n        <div class=\"flex items-center gap-3 mb-6\" data-kid=\"27\">\n          <img src=\"https://i.pravatar.cc/150?u=admin\" alt=\"User\" class=\"w-9 h-9 rounded-full border border-[#E4E4E7]\" data-kid=\"28\">\n          <div data-kid=\"29\">\n            <p class=\"text-sm font-medium text-[#0A0A0A]\" data-kid=\"30\">Dr. Alex Miller</p>\n            <p class=\"text-[11px] text-[#A1A1AA] uppercase font-mono\" data-kid=\"31\">Administrator</p>\n          </div>\n        </div>\n        <a href=\"#\" class=\"flex items-center gap-3 px-3 py-2 text-[#52525B] hover:bg-[#F5F6F7] rounded-full font-medium text-sm transition-colors\" data-kid=\"32\">\n          <i data-lucide=\"settings\" class=\"w-4 h-4\" data-kid=\"33\"></i>\n          Settings\n        </a>\n      </div>\n    </div>\n  </aside>\n\n  \n  <main class=\"ml-64 flex-1 bg-white min-h-screen\" data-kid=\"34\">\n    \n    <header class=\"sticky top-0 z-40 bg-white/90 backdrop-blur-md border-b border-[#E4E4E7] px-8 py-4 flex items-center justify-between\" data-kid=\"35\">\n      <div class=\"relative w-96\" data-kid=\"36\">\n        <i data-lucide=\"search\" class=\"absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-[#A1A1AA]\" data-kid=\"37\"></i>\n        <input type=\"text\" placeholder=\"Search staff, patients, or sessions...\" class=\"w-full bg-[#F5F6F7] border border-transparent focus:border-[#18BE66] focus:bg-white outline-hidden rounded-full py-2 pl-11 pr-4 text-sm transition-all\" data-kid=\"38\">\n      </div>\n      <div class=\"flex items-center gap-6\" data-kid=\"39\">\n        <div class=\"flex items-center gap-2 bg-[#F5F6F7] rounded-full px-4 py-1.5\" data-kid=\"40\">\n          <div class=\"w-2 h-2 rounded-full bg-[#18BE66]\" data-kid=\"41\"></div>\n          <span class=\"text-xs font-medium text-[#52525B]\" data-kid=\"42\">All systems normal</span>\n        </div>\n        <div class=\"relative\" data-kid=\"43\">\n          <i data-lucide=\"bell\" class=\"w-5 h-5 text-[#52525B] cursor-pointer hover:text-[#0A0A0A] transition-colors\" data-kid=\"44\"></i>\n          <span class=\"absolute -top-1 -right-1 w-2 h-2 bg-[#18BE66] rounded-full border-2 border-white\" data-kid=\"45\"></span>\n        </div>\n      </div>\n    </header>\n\n    <div class=\"p-10 max-w-7xl mx-auto\" data-kid=\"46\">\n      \n      <section class=\"mb-20\" id=\"hero-section\" data-kid=\"47\">\n        <div class=\"flex justify-between items-end mb-10\" data-kid=\"48\">\n          <div data-kid=\"49\">\n            <span class=\"eyebrow mb-2 block\" data-kid=\"50\">Healthcare Command Center</span>\n            <h1 class=\"text-[42px] font-semibold tight-tracking text-[#0A0A0A] leading-tight\" data-kid=\"51\">Good morning, Alex.</h1>\n            <p class=\"text-[#52525B] mt-2\" data-kid=\"52\">Here's an overview of today's in-home care operations.</p>\n          </div>\n          <div class=\"flex items-center gap-3\" data-kid=\"53\">\n            <button class=\"bg-white border border-[#E4E4E7] text-[#0A0A0A] rounded-full px-5 py-2.5 font-medium text-sm hover:bg-[#F5F6F7] transition-colors\" data-kid=\"54\">\n              Get a demo\n            </button>\n            <button class=\"bg-[#18181B] text-white rounded-full px-5 py-2.5 font-medium text-sm flex items-center gap-2 hover:opacity-90 transition-opacity\" data-kid=\"55\">\n              <i data-lucide=\"plus\" class=\"w-4 h-4\" data-kid=\"56\"></i>\n              Assign Session\n            </button>\n          </div>\n        </div>\n\n        \n        <div class=\"grid grid-cols-1 md:grid-cols-4 gap-6\" data-kid=\"57\">\n          <div class=\"stat-card bg-white border border-[#E4E4E7] rounded-2xl p-6 hover:border-[#18BE66]/30\" data-kid=\"58\">\n            <span class=\"eyebrow text-[11px] mb-3 block\" data-kid=\"59\">Total Care Visits</span>\n            <div class=\"flex items-baseline gap-2\" data-kid=\"60\">\n              <span class=\"text-3xl font-semibold\" data-kid=\"61\">142</span>\n              <span class=\"text-[#16A34A] text-xs font-semibold\" data-kid=\"62\">+8%</span>\n            </div>\n            <p class=\"text-xs text-[#A1A1AA] mt-1\" data-kid=\"63\">vs. yesterday</p>\n          </div>\n          <div class=\"stat-card bg-white border border-[#E4E4E7] rounded-2xl p-6 hover:border-[#18BE66]/30\" data-kid=\"