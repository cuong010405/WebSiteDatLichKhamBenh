      },
      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Geist+Mono:wght@500&display=swap');\n\n  :root {\n    --color-on-surface: #0A0A0A;\n    --color-surface: #FFFFFF;\n    --color-primary-strong: #16A34A;\n    --color-on-primary: #FFFFFF;\n    --color-hairline: #E4E4E7;\n    --color-on-surface-tertiary: #A1A1AA;\n    --color-on-action: #FFFFFF;\n    --color-on-surface-secondary: #52525B;\n    --color-success: #18BE66;\n    --color-action: #18181B;\n    --color-surface-secondary: #F5F6F7;\n    --color-primary: #18BE66;\n    --color-surface-tinted: #ECFBF2;\n  }\n\n  body {\n    font-family: 'Inter', sans-serif;\n    color: var(--color-on-surface);\n    background-color: var(--color-surface);\n    overflow-x: clip;\n  }\n\n  .font-mono {\n    font-family: 'Geist Mono', monospace;\n  }\n\n  .eyebrow-mono {\n    font-family: 'Geist Mono', monospace;\n    font-size: 13px;\n    font-weight: 500;\n    text-transform: uppercase;\n    letter-spacing: 0.04em;\n    color: var(--color-primary-strong);\n  }\n\n  .label-text {\n    font-size: 15px;\n    font-weight: 500;\n    color: var(--color-on-surface-secondary);\n  }\n\n  .headline-lg {\n    font-size: 42px;\n    font-weight: 600;\n    letter-spacing: -0.02em;\n    line-height: 1.1;\n  }\n\n  .headline-md {\n    font-size: 24px;\n    font-weight: 500;\n    letter-spacing: -0.01em;\n  }\n\n  .body-md {\n    font-size: 15px;\n    font-weight: 400;\n    line-height: 1.6;\n    color: var(--color-on-surface-secondary);\n  }\n\n  .card-hairline {\n    border: 1px solid var(--color-hairline);\n    border-radius: 16px;\n    background-color: var(--color-surface);\n  }\n\n  /* Custom Chart Overrides */\n  .chart-container canvas {\n    width: 100% !important;\n    height: 100% !important;\n  }\n\n  /* Navigation Pills */\n  .nav-pill-active {\n    background-color: var(--color-surface-tinted);\n    color: var(--color-primary-strong);\n    border: 1px solid transparent;\n  }\n  .nav-pill {\n    color: var(--color-on-surface-secondary);\n    border: 1px solid transparent;\n  }\n  .nav-pill:hover {\n    border-color: var(--color-hairline);\n  }\n\n  /* Custom Scrollbar */\n  ::-webkit-scrollbar {\n    width: 6px;\n  }\n  ::-webkit-scrollbar-track {\n    background: transparent;\n  }\n  ::-webkit-scrollbar-thumb {\n    background: var(--color-hairline);\n    border-radius: 10px;\n  }\n\n  /* Animations */\n  .reveal { opacity: 0; transform: translateY(20px); }\n</style>\n<link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" data-kid=\"1\">\n\n<div class=\"flex min-h-screen bg-white\" data-kid=\"2\">\n  \n  <aside class=\"w-64 border-r border-[var(--color-hairline)] flex flex-col fixed h-full bg-white z-50\" data-kid=\"3\">\n    <div class=\"p-8 pb-4\" data-kid=\"4\">\n      <div class=\"flex items-center gap-2.5 mb-10\" data-kid=\"5\">\n        <div class=\"w-7 h-7 bg-[#18BE66] rounded flex items-center justify-center\" data-kid=\"6\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" class=\"w-4 h-4 text-white\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"7\"><path d=\"M12 2L12 22M5 12L19 12M12 22L9 19M12 22L15 19\" data-kid=\"8\"></path></svg>\n        </div>\n        <span class=\"font-semibold text-lg tracking-tight\" data-kid=\"9\">Health Platform</span>\n      </div>\n\n      <nav class=\"space-y-1\" data-kid=\"10\">\n        <a href=\"#\" class=\"flex items-center gap-3 px-3 py-2 rounded-full nav-pill-active text-sm font-medium\" data-kid=\"11\">\n          <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"12\"><rect width=\"7\" height=\"9\" x=\"3\" y=\"3\" rx=\"1\" data-kid=\"13\"></rect><rect width=\"7\" height=\"5\" x=\"14\" y=\"3\" rx=\"1\" data-kid=\"14\"></rect><rect width=\"7\" height=\"9\" x=\"14\" y=\"12\" rx=\"1\" data-kid=\"15\"></rect><rect width=\"7\" height=\"5\" x=\"3\" y=\"16\" rx=\"1\" data-kid=\"16\"></rect></svg>\n          Dashboard\n        </a>\n        <a href=\"#\" class=\"flex items-center gap-3 px-3 py-2 rounded-full nav-pill text-sm font-medium\" data-kid=\"17\">\n          <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"18\"><path d=\"M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2\" data-kid=\"19\"></path><circle cx=\"9\" cy=\"7\" r=\"4\" data-kid=\"20\"></circle><path d=\"M22 21v-2a4 4 0 0 0-3-3.87\" data-kid=\"21\"></path><path d=\"M16 3.13a4 4 0 0 1 0 7.75\" data-kid=\"22\"></path></svg>\n          Patients\n        </a>\n        <a href=\"#\" class=\"flex items-center gap-3 px-3 py-2 rounded-full nav-pill text-sm font-medium\" data-kid=\"23\">\n          <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"24\"><path d=\"M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z\" data-kid=\"25\"></path></svg>\n          Consultations\n        </a>\n      </nav>\n    </div>\n\n    <div class=\"mt-auto p-8 pt-4\" data-kid=\"26\">\n      <div class=\"p-4 rounded-2xl bg-[var(--color-surface-secondary)] border border-[var(--color-hairline)]\" data-kid=\"27\">\n        <p class=\"text-xs font-mono font-medium text-[var(--color-primary-strong)] mb-1 uppercase tracking-wider\" data-kid=\"28\">Storage</p>\n        <p class=\"text-xs text-[var(--color-on-surface-secondary)] mb-3\" data-kid=\"29\">82% of records synced</p>\n        <div class=\"w-full h-1.5 bg-[var(--color-hairline)] rounded-full overflow-hidden\" data-kid=\"30\">\n          <div class=\"w-[82%] h-full bg-[var(--color-primary)]\" data-kid=\"31\"></div>\n        </div>\n      </div>\n    </div>\n  </aside>\n\n  \n  <main class=\"ml-64 flex-1\" data-kid=\"32\">\n    \n    <header class=\"h-16 border-b border-[var(--color-hairline)] flex items-center justify-between px-8 bg-white/80 backdrop-blur-md sticky top-0 z-40\" data-kid=\"33\">\n      <div class=\"flex items-center gap-4\" data-kid=\"34\">\n        <div class=\"flex items-center gap-2 text-sm font-medium text-[var(--color-on-surface-tertiary)]\" data-kid=\"35\">\n          <span data-kid=\"36\">Patient Logs</span>\n          <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"37\"><path d=\"m9 18 6-6-6-6\" data-kid=\"38\"></path></svg>\n          <span class=\"text-[var(--color-on-surface)]\" data-kid=\"39\">Sarah Jenkins</span>\n        </div>\n      </div>\n\n      <div class=\"flex items-center gap-4\" data-kid=\"40\">\n        <div class=\"px-4 py-1.5 bg-[var(--color-surface-secondary)] rounded-full border border-[var(--color-hairline)] flex items-center gap-3\" data-kid=\"41\">\n          <div class=\"w-1.5 h-1.5 rounded-full bg-[var(--color-primary)]\" data-kid=\"42\"></div>\n          <span class=\"text-xs font-medium\" data-kid=\"43\">All systems normal</span>\n        </div>\n        <div class=\"w-8 h-8 rounded-full bg-zinc-200 overflow-hidden\" data-kid=\"44\">\n          <img src=\"https://i.pravatar.cc/100?u=nurse1\" alt=\"Profile\" decoding=\"async\" loading=\"lazy\" data-kid=\"45\">\n        </div>\n      </div>\n    </header>\n\n    <div class=\"p-12 max-w-[1200px] mx-auto space-y-[80px] pb-32\" data-kid=\"46\">\n      \n      <section class=\"reveal pt-4\" data-kid=\"47\">\n        <div class=\"flex items-end justify-between\" data-kid=\"48\">\n          <div data-kid=\"49\">\n            <p class=\"eyebrow-mono mb-3\" data-kid=\"50\">Critical Monitoring</p>\n            <h1 class=\"headline-lg\" data-kid=\"51\">Health Logs & Vitals</h1>\n            <p class=\"text-[var(--color-on-surface-secondary)] text-lg mt-4 max-w-2xl\" data-kid=\"52\">\n              Real-time synchronization of medical telemetry and clinical observations for Patient ID: <span class=\"font-mono text-[var(--color-primary-strong)]\" data-kid=\"53\">SJ-2024-001</span>.\n            </p>\n          </div>\n          <div class=\"flex gap-3\" data-kid=\"54\">\n            <button class=\"px-6 py-2.5 rounded-full border border-[var(--color-hairline)] text-sm font-medium hover:bg-[var(--color-surface-secondary)] transition-colors\" data-kid=\"55\">Export PDF</button>\n            <button class=\"px-6 py-2.5 rounded-full bg-[var(--color-action)] text-white text-sm font-medium hover:opacity-90 transition-opacity\" data-kid=\"56\">Schedule Review</button>\n          </div>\n        </div>\n      </section>\n\n      \n      <section id=\"chart-kpi\" class=\"reveal\" data-kid=\"57\">\n        <div class=\"grid grid-cols-1 md:grid-cols-12 gap-6\" data-kid=\"58\">\n          \n          <div class=\"md:col-span-8 card-hairline p-8 flex flex-col md:flex-row justify-between gap-8 group hover:border-[var(--color-primary)] transition-colors\" data-kid=\"59\">\n            <div class=\"flex-1\" data-kid=\"60\">\n              <div class=\"flex items-center justify-between mb-8\" data-kid=\"61\">\n                <div class=\"w-14 h-14 rounded-2xl bg-[var(--color-surface-tinted)] flex items-center justify-center text-[var(--color-primary)]\" data-kid=\"62\">\n                  <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"28\" height=\"28\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"63\"><path d=\"M22 12h-4l-3 9L9 3l-3 9H2\" data-kid=\"64\"></path></svg>\n                </div>\n                <div class=\"flex items-center gap-2 bg-[var(--color-surface-tinted)] px-3 py-1 rounded-full\" data-kid=\"65\">\n                  <span class=\"w-2 h-2 rounded-full bg-[var(--color-primary)] animate-pulse\" data-kid=\"66\"></span>\n                  <span class=\"eyebrow-mono !text-[11px]\" data-kid=\"67\">Active Monitoring</span>\n                </div>\n              </div>\n              <div data-kid=\"68\">\n                <p class=\"eyebrow-mono mb-2\" data-kid=\"69\">Cardiac Telemetry</p>\n                <div class=\"flex items-baseline gap-3\" data-kid=\"70\">\n                  <span class=\"text-6xl font-semibold tracking-tighter\" data-kid=\"71\">72</span>\n                  <span class=\"text-[var(--color-on-surface-tertiary)] text-2xl font-medium tracking-tight\" data-kid=\"72\">BPM</span>\n                </div>\n                <p class=\"mt-6 eyebrow-mono !text-[11px] !text-[var(--color-on-surface-tertiary)] tracking-widest\" data-kid=\"73\">Normal Sinus Rhythm</p>\n              </div>\n            </div>\n            <div class=\"w-full md:w-1/3 h-48 md:h-full bg-[var(--color-surface-secondary)] rounded-2xl flex items-center justify-center p-4\" data-kid=\"74\">\n               \n               <svg class=\"w-full h-full opacity-50\" viewBox=\"0 0 200 100\" data-kid=\"75\">\n                  <path d=\"M0,50 L20,50 L30,20 L40,80 L50,50 L70,50 L80,10 L90,90 L100,50 L120,50 L130,30 L140,70 L150,50 L200,50\" fill=\"none\" stroke=\"var(--color-primary)\" stroke-width=\"2\" data-kid=\"76\"></path>\n               </svg>\n            </div>\n          </div>\n\n          \n          <div class=\"md:col-span-4 card-hairline p-8 flex flex-col justify-between group hover:border-[var(--color-primary)] transition-colors\" data-kid=\"77\">\n            <div class=\"w-12 h-12 rounded-xl bg-[var(--color-surface-tinted)] flex items-center justify-center text-[var(--color-primary)] mb-6\" data-kid=\"78\">\n              <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"79\"><path d=\"M11 2a2 2 0 0 0-2 2v5H4a2 2 0 0 0-2 2v2c0 1.1.9 2 2 2h5v5c0 1.1.9 2 2 2h2a2 2 0 0 0 2-2v-5h5a2 2 0 0 0 2-2v-2a2 2 0 0 0-2-2h-5V4a2 2 0 0 0-2-2h-2z\" data-kid=\"80\"></path></svg>\n            </div>\n            <div data-kid=\"81\">\n              <p class=\"eyebrow-mono mb-1\" data-kid=\"82\">Blood Pressure</p>\n              <div class=\"flex items-baseline gap-1.5\" data-kid=\"83\">\n                <span class=\"text-4xl font-semibold tracking-tighter\" data-kid=\"84\">120/80</span>\n                <span class=\"text-[var(--color-on-surface-tertiary)] text-lg font-medium\" data-kid=\"85\">mmHg</span>\n              </div>\n              <p class=\"mt-4 eyebrow-mono !text-[11px] !text-[var(--color-on-surface-tertiary)]\" data-kid=\"86\">Recorded 15m ago</p>\n            </div>\n          </div>\n\n          \n          <div class=\"md:col-span-6 card-hairline p-8 flex items-center justify-between group hover:border-[var(--color-primary)] transition-colors\" data-kid=\"87\">\n            <div class=\"flex items-center gap-6\" data-kid=\"88\">\n              <div class=\"w-12 h-12 rounded-xl bg-[var(--color-surface-tinted)] flex items-center justify-center text-[var(--color-primary)]\" data-kid=\"89\">\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"90\"><path d=\"M4 14.899A7 7 0 1 1 15.71 8h1.79a4.5 4.5 0 0 1 2.5 8.242\" data-kid=\"91\"></path><path d=\"M12 12v9\" data-kid=\"92\"></path><path d=\"m8 17 4 4 4-4\" data-kid=\"93\"></path></svg>\n              </div>\n              <div data-kid=\"94\">\n                <p class=\"eyebrow-mono mb-1\" data-kid=\"95\">Oxygen Saturation</p>\n                <div class=\"flex items-baseline gap-1.5\" data-kid=\"96\">\n                  <span class=\"text-3xl font-bold tracking-tighter\" data-kid=\"97\">98</span>\n                  <span class=\"text-[var(--color-on-surface-tertiary)] text-lg font-medium\" data-kid=\"98\">%</span>\n                </div>\n              </div>\n            </div>\n            <div class=\"flex items-center gap-2\" data-kid=\"99\">\n              <span class=\"w-2 h-2 rounded-full bg-[var(--color-primary)]\" data-kid=\"100\"></span>\n              <span class=\"eyebrow-mono !text-[11px]\" data-kid=\"101\">Optimal</span>\n            </div>\n          </div>\n\n          <div class=\"md:col-span-6 card-hairline p-8 flex items-center justify-between group hover:border-[var(--color-primary)] transition-colors\" data-kid=\"102\">\n            <div class=\"flex items-center gap-6\" data-kid=\"103\">\n              <div class=\"w-12 h-12 rounded-xl bg-[var(--color-surface-tinted)] flex items-center justify-center text-[var(--color-primary)]\" data-kid=\"104\">\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"105\"><path d=\"M14 4v10.54a4 4 0 1 1-4 0V4a2 2 0 0 1 4 0Z\" data-kid=\"106\"></path></svg>\n              </div>\n              <div data-kid=\"107\">\n                <p class=\"eyebrow-mono mb-1\" data-kid=\"108\">Body Temperature</p>\n                <div class=\"flex items-baseline gap-1.5\" data-kid=\"109\">\n                  <span class=\"text-3xl font-bold tracking-tighter\" data-kid=\"110\">36.8</span>\n                  <span class=\"text-[var(--color-on-surface-tertiary)] text-lg font-medium\" data-kid=\"111\">°C</span>\n                </div>\n              </div>\n            </div>\n            <div class=\"flex items-center gap-2\" data-kid=\"112\">\n              <span class=\"w-2 h-2 rounded-full bg-[var(--color-primary)]\" data-kid=\"113\"></span>\n              <span class=\"eyebrow-mono !text-[11px]\" data-kid=\"114\">Stable</span>\n            </div>\n          </div>\n        </div>\n      </section>\n\n      \n      <section id=\"live-chart\" class=\"reveal\" data-kid=\"115\">\n        <div class=\"grid grid-cols-1 lg:grid-cols-2 gap-8\" data-kid=\"116\">\n          \n          <div class=\"card-hairline p-8\" data-kid=\"117\">\n            <div class=\"flex items-center justify-between mb-8\" data-kid=\"118\">\n              <div data-kid=\"119\">\n                <h3 class=\"headline-md mb-1\" data-kid=\"120\">Pulse Telemetry</h3>\n                <p class=\"text-[var(--color-on-surface-secondary)] text-sm\" data-kid=\"121\">24-hour continuous monitoring</p>\n              </div>\n            <div class=\"text-right\" data-kid=\"122\">\n                <span class=\"text-2xl font-bold text-[var(--color-primary-strong)]\" data-kid=\"123\">72 bpm</span>\n                <p class=\"eyebrow-mono !text-[11px] !text-[var(--color-on-surface-tertiary)]\" data-kid=\"124\">Real-time Pulse</p>\n              </div>\n            </div>\n            <div class=\"h-[320px] relative chart-container\" data-kid=\"125\">\n              <canvas id=\"heartRateChart\" data-kid=\"126\"></canvas>\n            </div>\n          </div>\n\n          \n          <div class=\"card-hairline p-8\" data-kid=\"127\">\n            <div class=\"flex items-center justify-between mb-8\" data-kid=\"128\">\n              <div data-kid=\"129\">\n                <h3 class=\"headline-md mb-1\" data-kid=\"130\">Pressure Trends</h3>\n                <p class=\"text-[var(--color-on-surface-secondary)] text-sm\" data-kid=\"131\">Systolic vs Diastolic analysis</p>\n              </div>\n              <div class=\"flex gap-6\" data-kid=\"132\">\n                <div class=\"text-right\" data-kid=\"133\">\n                  <span class=\"text-xl font-bold\" data-kid=\"134\">118</span>\n                  <p class=\"eyebrow-mono !text-[11px] !text-[var(--color-on-surface-tertiary)]\" data-kid=\"135\">SYS AVG</p>\n                </div>\n                <div class=\"text-right\" data-kid=\"136\">\n                  <span class=\"text-xl font-bold\" data-kid=\"137\">78</span>\n                  <p class=\"eyebrow-mono !text-[11px] !text-[var(--color-on-surface-tertiary)]\" data-kid=\"138\">DIA AVG</p>\n                </div>\n              </div>\n            </div>\n            <div class=\"h-[320px] relative chart-container\" data-kid=\"139\">\n              <canvas id=\"bpChart\" data-kid=\"140\"></canvas>\n            </div>\n          </div>\n        </div>\n      </section>\n\n      \n      <section id=\"classic-table\" class=\"reveal\" data-kid=\"141\">\n        <div class=\"flex items-center justify-between mb-8\" data-kid=\"142\">\n          <div data-kid=\"143\">\n            <h2 class=\"headline-md\" data-kid=\"144\">Clinical Care Log</h2>\n            <p class=\"text-[var(--color-on-surface-secondary)] text-sm mt-1\" data-kid=\"145\">Full chronological history of all nursing activities</p>\n          </div>\n          <button class=\"bg-[var(--color-action)] text-white px-6 py-2.5 rounded-full font-medium text-sm flex items-center gap-2 transition-all hover:scale-[1.02] active:scale-[0.98]\" data-kid=\"146\">\n            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"147\"><path d=\"M5 12h14\" data-kid=\"148\"></path><path d=\"M12 5v14\" data-kid=\"149\"></path></svg>\n            Add Log Entry\n          </button>\n        </div>\n\n        <div class=\"card-hairline overflow-hidden\" data-kid=\"150\">\n          <table class=\"w-full text-left border-collapse\" data-kid=\"151\">\n            <thead data-kid=\"152\">\n              <tr class=\"bg-[var(--color-surface-secondary)] border-b border-[var(--color-hairline)]\" data-kid=\"153\">\n                <th class=\"px-8 py-4.5 text-[12px] font-mono font-medium text-[var(--color-on-surface-tertiary)] uppercase tracking-wider\" data-kid=\"154\">Timestamp</th>\n                <th class=\"px-8 py-4.5 text-[12px] font-mono font-medium text-[var(--color-on-surface-tertiary)] uppercase tracking-wider\" data-kid=\"155\">Event Type</th>\n                <th class=\"px-8 py-4.5 text-[12px] font-mono font-medium text-[var(--color-on-surface-tertiary)] uppercase tracking-wider\" data-kid=\"156\">Measurement</th>\n                <th class=\"px-8 py-4.5 text-[12px] font-mono font-medium text-[var(--color-on-surface-tertiary)] uppercase tracking-wider\" data-kid=\"157\">Clinician Note</th>\n                <th class=\"px-8 py-4.5 text-[12px] font-mono font-medium text-[var(--color-on-surface-tertiary)] uppercase tracking-wider text-right\" data-kid=\"158\">Status</th>\n              </tr>\n            </thead>\n            <tbody class=\"divide-y divide-[var(--color-hairline)]\" data-kid=\"159\">\n              \n              <tr class=\"hover:bg-[var(--color-surface-secondary)]/50 transition-colors cursor-pointer group\" data-kid=\"160\">\n                <td class=\"px-8 py-6\" data-kid=\"161\">\n                  <span class=\"text-sm font-semibold\" data-kid=\"162\">08:45 AM</span>\n                  <p class=\"eyebrow-mono !text-[11px] !text-[var(--color-on-surface-tertiary)] mt-0.5\" data-kid=\"163\">24 OCT 2024</p>\n                </td>\n                <td class=\"px-8 py-6\" data-kid=\"164\">\n                  <div class=\"flex items-center gap-3\" data-kid=\"165\">\n                    <div class=\"w-2 h-2 rounded-full bg-[var(--color-primary)]\" data-kid=\"166\"></div>\n                    <span class=\"text-sm font-medium\" data-kid=\"167\">Routine Vital Check</span>\n                  </div>\n                </td>\n                <td class=\"px-8 py-6 text-sm text-[var(--color-on-surface-secondary)] font-mono\" data-kid=\"168\">BP: 120/80</td>\n                <td class=\"px-8 py-6\" data-kid=\"169\">\n                  <p class=\"body-md max-w-sm line-clamp-2\" data-kid=\"170\">Patient stable. Reported mild headache but improved after hydration.</p>\n                </td>\n                <td class=\"px-8 py-6 text-right\" data-kid=\"171\">\n                  <span class=\"inline-flex items-center px-3 py-1 rounded-full bg-[var(--color-surface-tinted)] text-[var(--color-primary-strong)] eyebrow-mono !text-[11px] font-bold\" data-kid=\"172\">Verified</span>\n                </td>\n              </tr>\n              \n              <tr class=\"hover:bg-[var(--color-surface-secondary)]/50 transition-colors cursor-pointer group\" data-kid=\"173\">\n                <td class=\"px-8 py-6\" data-kid=\"174\">\n                  <span class=\"text-sm font-semibold\" data-kid=\"175\">06:12 AM</span>\n                  <p class=\"eyebrow-mono !text-[11px] !text-[var(--color-on-surface-tertiary)] mt-0.5\" data-kid=\"176\">24 OCT 2024</p>\n                </td>\n                <td class=\"px-8 py-6\" data-kid=\"177\">\n                  <div class=\"flex items-center gap-3\" data-kid=\"178\">\n                    <div class=\"w-2 h-2 rounded-full bg-[var(--color-action)]\" data-kid=\"179\"></div>\n                    <span class=\"text-sm font-medium\" data-kid=\"180\">Medication Admin</span>\n                  </div>\n                </td>\n                <td class=\"px-8 py-6 text-sm text-[var(--color-on-surface-secondary)] font-mono\" data-kid=\"181\">50mg IV</td>\n                <td class=\"px-8 py-6\" data-kid=\"182\">\n                  <p class=\"body-md max-w-sm line-clamp-2\" data-kid=\"183\">Antibiotic course (3/7). No allergic response observed.</p>\n                </td>\n                <td class=\"px-8 py-6 text-right\" data-kid=\"184\">\n                  <span class=\"inline-flex items-center px-3 py-1 rounded-full bg-[var(--color-surface-tinted)] text-[var(--color-primary-strong)] eyebrow-mono !text-[11px] font-bold\" data-kid=\"185\">Verified</span>\n                </td>\n              </tr>\n              \n              <tr class=\"hover:bg-[var(--color-surface-secondary)]/50 transition-colors cursor-pointer group\" data-kid=\"186\">\n                <td class=\"px-8 py-6\" data-kid=\"187\">\n                  <span class=\"text-sm font-semibold\" data-kid=\"188\">02:30 AM</span>\n                  <p class=\"eyebrow-mono !text-[11px] !text-[var(--color-on-surface-tertiary)] mt-0.5\" data-kid=\"189\">24 OCT 2024</p>\n                </td>\n                <td class=\"px-8 py-6\" data-kid=\"190\">\n                  <div class=\"flex items-center gap-3\" data-kid=\"191\">\n                    <div class=\"w-2 h-2 rounded-full bg-[var(--color-primary)]\" data-kid=\"192\"></div>\n                    <span class=\"text-sm font-medium\" data-kid=\"193\">Night Rounds</span>\n                  </div>\n                </td>\n                <td class=\"px-8 py-6 text-sm text-[var(--color-on-surface-secondary)] font-mono\" data-kid=\"194\">HR: 64 BPM</td>\n                <td class=\"px-8 py-6\" data-kid=\"195\">\n                  <p class=\"body-md max-w-sm line-clamp-2\" data-kid=\"196\">Resting peacefully. Vitals within range for deep sleep.</p>\n                </td>\n                <td class=\"px-8 py-6 text-right\" data-kid=\"197\">\n                  <span class=\"inline-flex items-center px-3 py-1 rounded-full bg-[var(--color-surface-tinted)] text-[var(--color-primary-strong)] eyebrow-mono !text-[11px] font-bold\" data-kid=\"198\">Verified</span>\n                </td>\n              </tr>\n              \n              <tr class=\"hover:bg-[var(--color-surface-secondary)]/50 transition-colors cursor-pointer group\" data-kid=\"199\">\n                <td class=\"px-8 py-6\" data-kid=\"200\">\n                  <span class=\"text-sm font-semibold\" data-kid=\"201\">11:15 PM</span>\n                  <p class=\"eyebrow-mono !text-[11px] !text-[var(--color-on-surface-tertiary)] mt-0.5\" data-kid=\"202\">23 OCT 2024</p>\n                </td>\n                <td class=\"px-8 py-6\" data-kid=\"203\">\n                  <div class=\"flex items-center gap-3\" data-kid=\"204\">\n                    <div class=\"w-2 h-2 rounded-full bg-[var(--color-on-surface-tertiary)]\" data-kid=\"205\"></div>\n                    <span class=\"text-sm font-medium\" data-kid=\"206\">Dietary Intake</span>\n                  </div>\n                </td>\n                <td class=\"px-8 py-6 text-sm text-[var(--color-on-surface-secondary)] font-mono\" data-kid=\"207\">Full meal</td>\n                <td class=\"px-8 py-6\" data-kid=\"208\">\n                  <p class=\"body-md max-w-sm line-clamp-2\" data-kid=\"209\">Completed dinner. Fluid intake 500ml.</p>\n                </td>\n                <td class=\"px-8 py-6 text-right\" data-kid=\"210\">\n                  <span class=\"inline-flex items-center px-3 py-1 rounded-full bg-[var(--color-surface-secondary)] text-[var(--color-on-surface-tertiary)] eyebrow-mono !text-[11px] font-bold\" data-kid=\"211\">Draft</span>\n                </td>\n              </tr>\n            </tbody>\n          </table>\n        </div>\n      </section>\n    </div>\n  </main>\n</div>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/chart.js\" data-kid=\"212\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"213\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"214\"></script>\n<script type=\"module\" data-kid=\"215\">\n  import Lenis from \"https://esm.sh/lenis@1\"\n  import Snap from \"https://esm.sh/lenis@1/snap\"\n  \n  // Smooth Scroll synchronized with GSAP\n  const lenis = new Lenis()\n  lenis.on('scroll', ScrollTrigger.update)\n  \n  gsap.ticker.add((time) => {\n    lenis.raf(time * 1000)\n  })\n  gsap.ticker.lagSmoothing(0)\n\n  // Register GSAP Plugins\n  gsap.registerPlugin(ScrollTrigger);\n\n  // Entrance Animations\n  const reveals = document.querySelectorAll('.reveal');\n  reveals.forEach((el, index) => {\n    gsap.to(el, {\n      opacity: 1,\n      y: 0,\n      duration: 0.8,\n      delay: index * 0.1,\n      ease: \"power3.out\",\n      scrollTrigger: {\n        trigger: el,\n        start: \"top 90%\",\n      }\n    });\n  });\n\n  // Chart Data Preparation\n  const labels = Array.from({length: 24}, (_, i) => `${i}:00`);\n  \n  // Heart Rate Chart\n  const hrCtx = document.getElementById('heartRateChart').getContext('2d');\n  new Chart(hrCtx, {\n    type: 'line',\n    data: {\n      labels: labels,\n      datasets: [{\n        label: 'Heart Rate',\n        data: labels.map(() => 65 + Math.random() * 20),\n        borderColor: '#18BE66',\n        backgroundColor: (context) => {\n          const chart = context.chart;\n          const {ctx, chartArea} = chart;\n          if (!chartArea) return null;\n          const gradient = ctx.createLinearGradient(0, chartArea.top, 0, chartArea.bottom);\n          gradient.addColorStop(0, 'rgba(24, 190, 102, 0.1)');\n          gradient.addColorStop(1, 'rgba(24, 190, 102, 0)');\n          return gradient;\n        },\n        fill: true,\n        tension: 0.4,\n        borderWidth: 2,\n        pointRadius: 0,\n        pointHoverRadius: 4,\n        pointHoverBackgroundColor: '#18BE66',\n        pointHoverBorderColor: '#fff',\n        pointHoverBorderWidth: 2,\n      }]\n    },\n    options: {\n      responsive: true,\n      maintainAspectRatio: false,\n      plugins: { legend: { display: false }, tooltip: { mode: 'index', intersect: false } },\n      scales: {\n        x: { display: false },\n        y: { \n          beginAtZero: false, \n          suggestedMin: 40, \n          suggestedMax: 120,\n          grid: { color: '#E4E4E7', drawBorder: false },\n          ticks: { color: '#A1A1AA', font: { family: 'Geist Mono', size: 10 } }\n        }\n      }\n    }\n  });\n\n  // Blood Pressure Chart\n  const bpCtx = document.getElementById('bpChart').getContext('2d');\n  new Chart(bpCtx, {\n    type: 'line',\n    data: {\n      labels: labels,\n      datasets: [\n        {\n          label: 'Systolic',\n          data: labels.map(() => 110 + Math.random() * 15),\n          borderColor: '#18BE66',\n          borderWidth: 2,\n          fill: false,\n          tension: 0.4,\n          pointRadius: 0\n        },\n        {\n          label: 'Diastolic',\n          data: labels.map(() => 70 + Math.random() * 12),\n          borderColor: '#52525B',\n          borderWidth: 2,\n          borderDash: [5, 5],\n          fill: false,\n          tension: 0.4,\n          pointRadius: 0\n        }\n      ]\n    },\n    options: {\n      responsive: true,\n      maintainAspectRatio: false,\n      plugins: { legend: { display: false }, tooltip: { mode: 'index', intersect: false } },\n      scales: {\n        x: { display: false },\n        y: { \n          beginAtZero: false,\n          suggestedMin: 50,\n          suggestedMax: 150,\n          grid: { color: '#E4E4E7', drawBorder: false },\n          ticks: { color: '#A1A1AA', font: { family: 'Geist Mono', size: 10 } }\n        }\n      }\n    }\n  });\n</script>\n",
