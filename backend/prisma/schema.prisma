generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Staff {
  Id           String         @id(map: "PK__Staff__3214EC07A0920845") @db.NVarChar(50)
  Name         String         @db.NVarChar(200)
  Role         String         @db.NVarChar(100)
  Status       String         @db.NVarChar(100)
  Department   String         @db.NVarChar(100)
  Phone        String         @db.NVarChar(20)
  Email        String         @db.NVarChar(200)
  Location     String         @db.NVarChar(200)
  Avatar       String?        @db.NVarChar(Max)
  Available    Boolean        @default(true, map: "DF__Staff__Available__37A5467C")
  IsNew        Boolean        @default(false, map: "DF__Staff__IsNew__38996AB5")
  PatientStaff PatientStaff[]
  Visit        Visit[]
}

model Patient {
  Id            String         @id(map: "PK__Patient__3214EC073C30341E") @db.NVarChar(50)
  Name          String         @db.NVarChar(200)
  Age           Int
  Gender        String         @db.NVarChar(20)
  LastVisit     String?        @db.NVarChar(100)
  LastVisitTime String?        @db.NVarChar(100)
  Status        String?        @db.NVarChar(100)
  Summary       String?        @db.NVarChar(Max)
  PatientStaff  PatientStaff[]
  Visit         Visit[]
}

model Visit {
  Id            String   @id(map: "PK__Visit__3214EC07DB2D450F") @db.NVarChar(50)
  Type          String?  @db.NVarChar(100)
  PatientId     String?  @db.NVarChar(50)
  UserId        String?  @db.NVarChar(50)
  StaffId       String   @db.NVarChar(50)
  Time          String?  @db.NVarChar(100)
  StartTime     String?  @db.NVarChar(100)
  EndTime       String?  @db.NVarChar(100)
  Duration      String?  @db.NVarChar(100)
  Status        String?  @db.NVarChar(100)
  PaymentMethod String?  @db.NVarChar(100)
  PaymentAmount String?  @db.NVarChar(100)
  PaymentNote   String?  @db.NVarChar(Max)
  PaymentStatus String?  @db.NVarChar(100)
  Patient       Patient? @relation(fields: [PatientId], references: [Id], onUpdate: NoAction, map: "FK_Visit_Patient")
  User          User?    @relation(fields: [UserId], references: [Id], onUpdate: NoAction, map: "FK_Visit_User")
  Staff         Staff    @relation(fields: [StaffId], references: [Id], onUpdate: NoAction, map: "FK_Visit_Staff")
}

model ActivityLog {
  Id        String    @id(map: "PK__Activity__3214EC072A9F69A4") @db.NVarChar(50)
  Status    String?   @db.NVarChar(50)
  Title     String?   @db.NVarChar(200)
  Desc      String?   @db.NVarChar(Max)
  Time      String?   @db.NVarChar(50)
  Color     String?   @db.NVarChar(50)
  CreatedAt DateTime? @default(now(), map: "DF__ActivityL__Creat__412EB0B6") @db.DateTime
}

model PatientStaff {
  PatientId String  @db.NVarChar(50)
  StaffId   String  @db.NVarChar(50)
  Patient   Patient @relation(fields: [PatientId], references: [Id], onUpdate: NoAction, map: "FK__PatientSt__Patie__440B1D61")
  Staff     Staff   @relation(fields: [StaffId], references: [Id], onUpdate: NoAction, map: "FK__PatientSt__Staff__44FF419A")

  @@id([PatientId, StaffId], map: "PK__PatientS__FE6389D7F530403A")
}

model User {
  Id           String   @id @default(uuid()) @db.NVarChar(50)
  Email        String   @unique @db.NVarChar(200)
  PasswordHash String   @db.NVarChar(500)
  FullName     String   @db.NVarChar(200)
  Phone        String?  @db.NVarChar(30)
  Role         String   @default("customer") @db.NVarChar(20)
  CreatedAt    DateTime @default(now()) @db.DateTime
  Visit        Visit[]
}
