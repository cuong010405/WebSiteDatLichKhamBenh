datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Staff {
  id         String    @id
  name       String
  role       String
  status     String    // "Sẵn sàng" | "Đang bận" | "Nghỉ phép"
  department String
  phone      String
  email      String
  location   String
  avatar     String?
  available  Boolean   @default(true)
  isNew      Boolean   @default(false)
  patients   Patient[] @relation("PatientStaff")
  visits     Visit[]
}

model Patient {
  id            String   @id // Ví dụ: BN-0842
  name          String
  age           Int
  gender        String   // "Nam" | "Nữ"
  lastVisit     String
  lastVisitTime String
  status        String   // "Đang điều trị" | "Chờ tái khám" | "Đã xuất viện"
  summary       String?
  assignedStaff Staff[]  @relation("PatientStaff")
  visits        Visit[]
}

model Visit {
  id          String   @id
  type        String
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  staffId     String
  staff       Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  time        String   // Ví dụ: "08:00 - 09:00"
  startTime   String?
  endTime     String?
  duration    String
  status      String   // "Đang thực hiện" | "Đã xác nhận" | "Đã hoàn tất" | "Đã hủy" | "Chờ duyệt"
}

model ActivityLog {
  id        String   @id
  status    String   // "completed" | "assigned" | "review"
  title     String
  desc      String
  time      String   // Ví dụ: "14:22 PM"
  color     String
  createdAt DateTime @default(now())
}
